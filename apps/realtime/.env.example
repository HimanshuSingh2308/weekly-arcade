# Port for the realtime service
PORT=3001

# Firebase project ID
FIREBASE_PROJECT_ID=weekly-arcade

# Google Application Credentials (for local development)
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# API service URL (for internal calls to POST /internal/game-results)
API_BASE_URL=http://localhost:8080/api

# Internal API key (shared secret between realtime and API services)
INTERNAL_API_KEY=your-internal-api-key-here
