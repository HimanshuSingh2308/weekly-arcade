{
  "name": "web-astro",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/web-astro/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd apps/web-astro && npx astro build",
        "cwd": "{workspaceRoot}"
      },
      "outputs": ["{workspaceRoot}/dist/apps/web-astro"]
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd apps/web-astro && npx astro dev --port 4201",
        "cwd": "{workspaceRoot}"
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd apps/web-astro && npx astro preview --port 4201",
        "cwd": "{workspaceRoot}"
      },
      "dependsOn": ["build"]
    },
    "check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd apps/web-astro && npx astro check",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
