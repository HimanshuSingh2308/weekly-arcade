---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';

// Dynamic game count — auto-updates when game JSON files are added
const gameModules = import.meta.glob('../data/games/*.json', { eager: true });
const gameCount = Object.keys(gameModules).length;
---

<BaseLayout title="Weekly Arcade | New Free Browser Games Every Week">
  <Fragment slot="head">
    <!-- Preconnect -->
    <link rel="preconnect" href="https://www.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://firestore.googleapis.com" crossorigin>

    <!-- SEO -->
    <meta name="description" content={`Play ${gameCount}+ free browser games — no downloads, no ads, no signup. 100% original puzzle, arcade, strategy, and 3D games added weekly.`}>
    <meta name="keywords" content="free browser games, online games, no download games, free games, browser games 2026, arcade games, puzzle games, play online free, browser games no ads, free games no ads, browser games with leaderboards, original browser games">
    <link rel="canonical" href="https://weeklyarcade.games/">

    <!-- Open Graph -->
    <meta property="og:title" content="Weekly Arcade | New Free Browser Games Every Week">
    <meta property="og:description" content={`Play ${gameCount}+ free browser games instantly — no downloads, no signup. New games added every week.`}>
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://weeklyarcade.games/">
    <meta property="og:image" content="https://weeklyarcade.games/og-image.png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="Weekly Arcade — free browser games, no downloads required">
    <meta property="og:site_name" content="Weekly Arcade">
    <meta property="og:locale" content="en_US">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Weekly Arcade | New Free Browser Games Every Week">
    <meta name="twitter:description" content={`Play ${gameCount}+ free browser games instantly — no downloads, no signup. New games added every week.`}>
    <meta name="twitter:image" content="https://weeklyarcade.games/og-image.png">
    <meta name="twitter:image:alt" content="Weekly Arcade — free browser games, no downloads required">

    <!-- Structured Data: Organization -->
    <script type="application/ld+json">{
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Weekly Arcade",
      "url": "https://weeklyarcade.games",
      "logo": "https://weeklyarcade.games/icons/icon-512.png",
      "description": "Free browser games released every week — no downloads, no signup. Puzzle, arcade, strategy, 3D, and multiplayer games playable instantly on any device.",
      "foundingDate": "2026"
    }</script>

    <!-- Structured Data: FAQPage -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Are all the games on Weekly Arcade free?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `Yes, every game on Weekly Arcade is 100% free to play with no hidden paywalls, no premium tiers, and no ads. All ${gameCount}+ games are accessible immediately. Sign-in via Google is optional and only needed for global leaderboards, cloud saves, and achievements. Guest play has no restrictions.`
          }
        },
        {
          "@type": "Question",
          "name": "Do I need to download or install anything?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No downloads or installations required. All games are HTML5 browser games that run directly in Chrome, Safari, Firefox, or Edge on any device — desktop, tablet, or phone. Average game size is under 50KB, loading in under 1.5 seconds on a 4G connection. Weekly Arcade also works as a Progressive Web App (PWA) for offline play."
          }
        },
        {
          "@type": "Question",
          "name": "How often are new games added?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `Weekly Arcade releases one new original game every week. Each game is designed, built, and playtested in a 7-day cycle. The library currently has ${gameCount}+ games spanning 8 genres including arcade, puzzle, strategy, 3D, card, simulation, action, and casual.`
          }
        },
        {
          "@type": "Question",
          "name": "Can I play on my phone?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. All Weekly Arcade games are designed mobile-first with touch controls, responsive layouts from 320px to 2560px screens, and optimized performance targeting 60fps. Touch targets meet Apple's 44x44px minimum and all games support the prefers-reduced-motion accessibility standard."
          }
        },
        {
          "@type": "Question",
          "name": "Are there ads in the games?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Weekly Arcade is 100% ad-free. Unlike most browser game sites that rely on advertising, we have zero ads, zero pop-ups, and zero tracking scripts from ad networks. This also means faster load times and no interruptions during gameplay."
          }
        },
        {
          "@type": "Question",
          "name": "Are the games original or copied from other sites?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `Every game on Weekly Arcade is 100% original, designed and built in-house. We don't host third-party games or re-skin existing titles. Each game is crafted from scratch in a 7-day development cycle with ${gameCount}+ games shipped so far.`
          }
        },
        {
          "@type": "Question",
          "name": "Can I play games offline?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Weekly Arcade is a Progressive Web App (PWA). After your first visit, games are cached on your device via Service Worker. Install Weekly Arcade to your home screen for offline play on planes, subways, or anywhere without internet."
          }
        },
        {
          "@type": "Question",
          "name": "Are the games safe for kids?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. All Weekly Arcade games are family-friendly with no violent content, no chat features, no ads, and no in-app purchases. No personal information is collected from guest players. Games work on school Chromebooks and iPads."
          }
        },
        {
          "@type": "Question",
          "name": "What are the best games on Weekly Arcade?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The most popular games include Drift Legends (3D racing), Wordle (daily word puzzle), Chess 3D (strategy), Snake (classic arcade), and 2048 (number puzzle). All games are ranked and reviewed in the Best Browser Games 2026 guide."
          }
        },
        {
          "@type": "Question",
          "name": "Do you have multiplayer games?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Drift Legends features real-time multiplayer racing via WebSocket, and Chess 3D supports online play against friends with ELO rating. All games include global leaderboards with daily, weekly, and monthly rankings."
          }
        },
        {
          "@type": "Question",
          "name": "What browser do I need?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Any modern browser works: Chrome, Safari, Firefox, or Edge on desktop, tablet, or mobile. Games use HTML5 Canvas and standard web APIs, so no special plugins are needed. For 3D games like Drift Legends, WebGL support is required (included in all modern browsers)."
          }
        }
      ]
    })} />

    <!-- Structured Data: WebSite (enables sitelinks search box) -->
    <script type="application/ld+json">{
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Weekly Arcade",
      "url": "https://weeklyarcade.games"
    }</script>

    <!-- Structured Data: ItemList (game catalog for AI extraction) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "Weekly Arcade Games",
      "description": `${gameCount}+ free browser games playable instantly — no downloads, no signup required.`,
      "numberOfItems": gameCount,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Drift Legends", "url": "https://weeklyarcade.games/games/drift-legends/" },
        { "@type": "ListItem", "position": 2, "name": "Cricket Blitz", "url": "https://weeklyarcade.games/games/cricket-blitz/" },
        { "@type": "ListItem", "position": 3, "name": "Chess 3D", "url": "https://weeklyarcade.games/games/chess-3d/" },
        { "@type": "ListItem", "position": 4, "name": "Coin Cascade", "url": "https://weeklyarcade.games/games/coin-cascade/" },
        { "@type": "ListItem", "position": 5, "name": "Solitaire Roguelite", "url": "https://weeklyarcade.games/games/solitaire-roguelite/" },
        { "@type": "ListItem", "position": 6, "name": "Wordle", "url": "https://weeklyarcade.games/games/wordle/" },
        { "@type": "ListItem", "position": 7, "name": "Snake", "url": "https://weeklyarcade.games/games/snake/" },
        { "@type": "ListItem", "position": 8, "name": "2048", "url": "https://weeklyarcade.games/games/2048/" },
        { "@type": "ListItem", "position": 9, "name": "Fieldstone", "url": "https://weeklyarcade.games/games/fieldstone/" },
        { "@type": "ListItem", "position": 10, "name": "Voidbreak", "url": "https://weeklyarcade.games/games/voidbreak/" }
      ]
    })} />

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#e94560">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Weekly Arcade">
    <link rel="apple-touch-icon" href="/icons/icon-180.png">
  </Fragment>

  <SiteHeader activePage="games" />

  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-content">
        <h1>New <span class="highlight">Free Browser Games</span> Every Week</h1>
        <p class="hero-desc">Play {gameCount}+ games instantly in your browser - no downloads, no signup, no ads. 100% original games added weekly.</p>
        <div class="hero-featured">
          <div class="hero-badge">NEW THIS WEEK</div>
          <h2 class="hero-game-name">Drift Legends</h2>
          <p class="hero-game-desc">3D arcade racing game with story mode, drift mechanics, and multiplayer. Master 15 tracks across 5 chapters — from neon city streets to sky-high circuits.</p>
          <div class="hero-tags">
            <span class="hero-tag">Racing</span>
            <span class="hero-tag">3D</span>
            <span class="hero-tag">Multiplayer</span>
          </div>
        </div>
        <a href="/games/drift-legends/" class="hero-cta">
          Play Drift Legends <span class="hero-cta-arrow">→</span>
        </a>
      </div>
      <a href="/games/drift-legends/" class="hero-thumb">
        <img src="/images/thumbnails/drift-legends.svg" alt="Drift Legends - 3D arcade racing game with drift mechanics and multiplayer">
      </a>
    </div>
  </section>

  <!-- Stats Banner -->
  <div class="stats-banner">
    <div class="stats-inner">
      <div class="stat-item">
        <span class="stat-icon">🎮</span>
        <span class="stat-value">{gameCount}</span> Games
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-icon">💰</span>
        <span class="stat-value">100%</span> Free
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-icon">🔥</span>
        <span class="stat-value">New</span> Every Week
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-icon">⚡</span>
        <span class="stat-value">Zero</span> Downloads
      </div>
    </div>
  </div>

  <!-- About Section (GEO-optimized for AI extraction) -->
  <section class="about-blurb">
    <p><strong>Weekly Arcade</strong> is a free browser gaming platform that releases a new HTML5 game every week &mdash; playable instantly on any device without downloads, installations, or account creation. The library includes {gameCount}+ original games across 8 genres: arcade, puzzle, strategy, action, card, simulation, casual, and 3D. All games load in under 1.5 seconds, run at 60fps on modern browsers, and support both touch and keyboard controls. Weekly Arcade is built on <a href="https://astro.build/">Astro</a> and deployed globally via Firebase Hosting.</p>
  </section>

  <!-- Genre Filters -->
  <div class="filters">
    <div class="filter-row" id="filterRow">
      <button class="filter-chip active" data-filter="all">All Games</button>
      <button class="filter-chip" data-filter="arcade">Arcade</button>
      <button class="filter-chip" data-filter="puzzle">Puzzle</button>
      <button class="filter-chip" data-filter="strategy">Strategy</button>
      <button class="filter-chip" data-filter="action">Action</button>
      <button class="filter-chip" data-filter="card">Card</button>
      <button class="filter-chip" data-filter="simulation">Simulation</button>
      <button class="filter-chip" data-filter="casual">Casual</button>
      <button class="filter-chip" data-filter="3d">3D</button>
      <button class="filter-chip" data-filter="sports">Sports</button>
      <button class="filter-chip" data-filter="multiplayer">Multiplayer</button>
    </div>
  </div>

  <main class="container">
    <div class="section-header">
      <h2 class="section-title">Free Browser Games to Play Now</h2>
      <span class="game-count" id="gameCount">{gameCount} games</span>
    </div>

    <div class="games-grid" id="gamesGrid">
      <!-- Week 5: Drift Legends (Apr 4) -->
      <a href="/games/drift-legends/" class="game-card" data-genres="action,arcade,3d,multiplayer">
        <div class="game-thumb">
          <span class="thumb-badge">NEW</span>
          <img src="/images/thumbnails/drift-legends.svg" alt="Drift Legends - 3D arcade racing game with drift mechanics" loading="lazy">
        </div>
        <div class="game-info">
          <div class="game-title">Drift Legends</div>
          <div class="game-desc">3D arcade racing with story mode, drift mechanics, and multiplayer. 15 tracks across 5 chapters!</div>
          <div class="game-tags"><span class="tag">Racing</span><span class="tag">3D</span></div>
        </div>
      </a>

      <!-- Week 4: Chess 3D (Mar 31) -->
      <a href="/games/chess-3d/" class="game-card" data-genres="strategy,board,3d,multiplayer">
        <div class="game-thumb"><img src="/images/thumbnails/chess-3d.svg" alt="Chess 3D - free 3D chess game vs AI" loading="lazy"></div>
        <div class="game-info">
          <div class="game-title">Chess 3D</div>
          <div class="game-desc">3D chess with smart AI! 4 difficulty levels, ELO rating, rotatable board.</div>
          <div class="game-tags"><span class="tag">Strategy</span><span class="tag">3D</span><span class="tag">Multiplayer</span></div>
        </div>
      </a>

      <!-- Week 3: Cricket Blitz (Mar 29) -->
      <a href="/games/cricket-blitz/" class="game-card" data-genres="arcade,sports">
        <div class="game-thumb"><img src="/images/thumbnails/cricket-blitz.svg" alt="Cricket Blitz - free IPL-style 3D cricket game" loading="lazy"></div>
        <div class="game-info">
          <div class="game-title">Cricket Blitz</div>
          <div class="game-desc">3D IPL-style cricket! Bat, bowl, win the match. Toss, powerplay, super over!</div>
          <div class="game-tags"><span class="tag">Sports</span><span class="tag">3D</span></div>
        </div>
      </a>

      <!-- Week 2 (Mar 22) -->
      <a href="/games/tiny-tycoon/" class="game-card" data-genres="simulation,casual">
        <div class="game-thumb"><img src="/images/thumbnails/tiny-tycoon.svg" alt="Tiny Tycoon - free boba tea shop simulator game" loading="lazy"></div>
        <div class="game-info">
          <div class="game-title">Tiny Tycoon</div>
          <div class="game-desc">Run a boba tea shop in 60-second days. Serve customers, earn coins, upgrade!</div>
          <div class="game-tags"><span class="tag">Simulation</span><span class="tag">Idle</span></div>
        </div>
      </a>

      <a href="/games/lumble/" class="game-card" data-genres="3d,action">
        <div class="game-thumb"><img src="/images/thumbnails/lumble.svg" alt="Lumble - free 3D platformer browser game" loading="lazy"></div>
        <div class="game-info">
          <div class="game-title">Lumble</div>
          <div class="game-desc">3D platformer! Latch, swing, and collect 50 Sparks!</div>
          <div class="game-tags"><span class="tag">3D</span><span class="tag">Platformer</span></div>
        </div>
      </a>

      <a href="/games/voidbreak/" class="game-card" data-genres="action,arcade">
        <div class="game-thumb"><img src="/images/thumbnails/voidbreak.svg" alt="Voidbreak - free asteroid shooter roguelite game" loading="lazy"></div>
        <div class="game-info">
          <div class="game-title">Voidbreak</div>
          <div class="game-desc">Smash asteroids, upgrade your ship, go deeper. How far can you get?</div>
          <div class="game-tags"><span class="tag">Action</span><span class="tag">Roguelite</span></div>
        </div>
      </a>

      <a href="/games/fieldstone/" class="game-card" data-genres="strategy,puzzle">
        <div class="game-thumb"><img src="/images/thumbnails/fieldstone.svg" alt="Fieldstone - free Tetris kingdom builder strategy game" loading="lazy"></div>
        <div class="game-info">
          <div class="game-title">Fieldstone</div>
          <div class="game-desc">Tetris meets kingdom builder! Place terrain, harvest rows, defend your realm!</div>
          <div class="game-tags"><span class="tag">Strategy</span><span class="tag">Puzzle</span></div>
        </div>
      </a>

      <a href="/games/chaos-kitchen/" class="game-card" data-genres="action,casual">
        <div class="game-thumb"><img src="/images/thumbnails/chaos-kitchen.svg" alt="Chaos Kitchen - free cooking time management game" loading="lazy"></div>
        <div class="game-info">
          <div class="game-title">Chaos Kitchen</div>
          <div class="game-desc">Run a chaotic kitchen! Fulfill orders and survive chaos events!</div>
          <div class="game-tags"><span class="tag">Action</span><span class="tag">Time Management</span></div>
        </div>
      </a>

      <a href="/games/memory-match/" class="game-card" data-genres="casual,puzzle">
        <div class="game-thumb"><img src="/images/thumbnails/memory-match.svg" alt="Memory Match - free card matching puzzle game" loading="lazy"></div>
        <div class="game-info">
          <div class="game-title">Memory Match</div>
          <div class="game-desc">Flip cards and find matching pairs. Test your memory!</div>
          <div class="game-tags"><span class="tag">Casual</span><span class="tag">Memory</span></div>
        </div>
      </a>

      <a href="/games/wordle/" class="game-card" data-genres="puzzle">
        <div class="game-thumb"><img src="/images/thumbnails/wordle.svg" alt="Wordle - free daily word puzzle game" loading="lazy"></div>
        <div class="game-info">
          <div class="game-title">Wordle</div>
          <div class="game-desc">Guess the 5-letter word in 6 tries. A new word every day!</div>
          <div class="game-tags"><span class="tag">Puzzle</span><span class="tag">Daily</span></div>
        </div>
      </a>

      <a href="/games/solitaire-roguelite/" class="game-card" data-genres="card,puzzle">
        <div class="game-thumb"><img src="/images/thumbnails/solitaire-roguelite.svg" alt="Solitaire Roguelite - free card game with Joker powers" loading="lazy"></div>
        <div class="game-info">
          <div class="game-title">Solitaire Roguelite</div>
          <div class="game-desc">Classic Solitaire with rule-breaking Joker cards. How high can you score?</div>
          <div class="game-tags"><span class="tag">Card</span><span class="tag">Roguelite</span></div>
        </div>
      </a>

      <a href="/games/coin-cascade/" class="game-card" data-genres="arcade,casual">
        <div class="game-thumb"><img src="/images/thumbnails/coin-cascade.svg" alt="Coin Cascade - free physics coin pusher arcade game" loading="lazy"></div>
        <div class="game-info">
          <div class="game-title">Coin Cascade</div>
          <div class="game-desc">Drop coins onto a physics pusher to cascade prizes off the edge!</div>
          <div class="game-tags"><span class="tag">Arcade</span><span class="tag">Physics</span></div>
        </div>
      </a>

      <a href="/games/stack-tower/" class="game-card" data-genres="arcade,casual">
        <div class="game-thumb"><img src="/images/thumbnails/stack-tower.svg" alt="Stack Tower - free block stacking arcade game" loading="lazy"></div>
        <div class="game-info">
          <div class="game-title">Stack Tower</div>
          <div class="game-desc">Stack blocks with perfect timing to build the tallest tower!</div>
          <div class="game-tags"><span class="tag">Arcade</span><span class="tag">Timing</span></div>
        </div>
      </a>

      <!-- Week 1 (Mar 15) -->
      <a href="/games/2048/" class="game-card" data-genres="puzzle,strategy">
        <div class="game-thumb"><img src="/images/thumbnails/2048.svg" alt="2048 - free number merge puzzle game" loading="lazy"></div>
        <div class="game-info">
          <div class="game-title">2048</div>
          <div class="game-desc">Slide tiles and merge numbers to reach 2048.</div>
          <div class="game-tags"><span class="tag">Puzzle</span><span class="tag">Strategy</span></div>
        </div>
      </a>

      <a href="/games/snake/" class="game-card" data-genres="arcade">
        <div class="game-thumb"><img src="/images/thumbnails/snake.svg" alt="Snake - free classic arcade game" loading="lazy"></div>
        <div class="game-info">
          <div class="game-title">Snake</div>
          <div class="game-desc">Classic snake game. Eat, grow, don't hit the walls!</div>
          <div class="game-tags"><span class="tag">Arcade</span><span class="tag">Classic</span></div>
        </div>
      </a>

      <!-- No Results Message -->
      <div class="no-results" id="noResults">
        <div class="no-results-icon">🔍</div>
        <div class="no-results-text">No games match this filter</div>
      </div>
    </div>

    <div class="browse-all">
      <a href="/games/" class="browse-all-link">Browse All Games <span>→</span></a>
    </div>
  </main>

  <!-- FAQ Section -->
  <section class="faq-section">
    <h2 class="faq-title">Frequently Asked Questions</h2>
    <div class="faq-list">
      <div class="faq-item open">
        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
          Are all the games on Weekly Arcade free?
          <span class="faq-arrow">▼</span>
        </button>
        <div class="faq-answer"><div class="faq-answer-inner">Yes, every game on Weekly Arcade is 100% free to play with no hidden paywalls, no premium tiers, and no ads. All {gameCount}+ games are accessible immediately. Sign-in via Google is optional and only needed for global leaderboards, cloud saves, and achievements. Guest play has no restrictions.</div></div>
      </div>
      <div class="faq-item">
        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
          Do I need to download or install anything?
          <span class="faq-arrow">▼</span>
        </button>
        <div class="faq-answer"><div class="faq-answer-inner">No downloads or installations required. All games are HTML5 browser games that run directly in Chrome, Safari, Firefox, or Edge on any device &mdash; desktop, tablet, or phone. Average game size is under 50KB, loading in under 1.5 seconds on a 4G connection. Weekly Arcade also works as a Progressive Web App (PWA) for offline play.</div></div>
      </div>
      <div class="faq-item">
        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
          How often are new games added?
          <span class="faq-arrow">▼</span>
        </button>
        <div class="faq-answer"><div class="faq-answer-inner">Weekly Arcade releases one new original game every week. Each game is designed, built, and playtested in a 7-day cycle. The library currently has {gameCount}+ games spanning 8 genres including arcade, puzzle, strategy, 3D, card, simulation, action, and casual. <a href="/how-we-build-games/">Learn how we build a new game every week</a>.</div></div>
      </div>
      <div class="faq-item">
        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
          Can I play on my phone?
          <span class="faq-arrow">▼</span>
        </button>
        <div class="faq-answer"><div class="faq-answer-inner">Yes. All Weekly Arcade games are designed mobile-first with touch controls, responsive layouts from 320px to 2560px screens, and optimized performance targeting 60fps. Touch targets meet Apple's 44&times;44px minimum and all games support the <code>prefers-reduced-motion</code> accessibility standard.</div></div>
      </div>
      <div class="faq-item">
        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
          Are there ads in the games?
          <span class="faq-arrow">▼</span>
        </button>
