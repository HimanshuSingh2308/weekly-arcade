  <script is:inline>
    // ─── Genre Filter ───
    const filterRow = document.getElementById('filterRow');
    const gamesGrid = document.getElementById('gamesGrid');
    const gameCount = document.getElementById('gameCount');
    const noResults = document.getElementById('noResults');

    filterRow.addEventListener('click', (e) => {
      const chip = e.target.closest('.filter-chip');
      if (!chip) return;

      filterRow.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
      chip.classList.add('active');

      const filter = chip.dataset.filter;
      const cards = gamesGrid.querySelectorAll('.game-card');
      let visible = 0;

      cards.forEach(card => {
        const genres = card.dataset.genres || '';
        const show = filter === 'all' || genres.includes(filter);
        card.dataset.hidden = !show;
        if (show) visible++;
      });

      gameCount.textContent = visible + (visible === 1 ? ' game' : ' games');
      noResults.classList.toggle('show', visible === 0);
    });

    // ─── Service Worker with Update Detection ───
    let newWorker;
    const updateBanner = document.getElementById('pwaUpdateBanner');
    const updateBtn = document.getElementById('pwaUpdateBtn');
    const updateDismiss = document.getElementById('pwaUpdateDismiss');

    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js')
          .then(reg => {
            console.log('SW registered');
            reg.update();
            setInterval(() => reg.update(), 60 * 60 * 1000);

            if (reg.waiting) {
              newWorker = reg.waiting;
              showUpdateBanner();
            }

            reg.addEventListener('updatefound', () => {
              newWorker = reg.installing;
              newWorker.addEventListener('statechange', () => {
                if (newWorker.state === 'installed' && navigator.serviceWorker.controller) {
                  showUpdateBanner();
                }
              });
            });
          })
          .catch(err => console.log('SW registration failed:', err));

        let refreshing = false;
        navigator.serviceWorker.addEventListener('controllerchange', () => {
          if (!refreshing) {
            refreshing = true;
            window.location.reload();
          }
        });
      });
    }

    function showUpdateBanner() { updateBanner.classList.add('show'); }
    function hideUpdateBanner() { updateBanner.classList.remove('show'); }

    updateBtn.addEventListener('click', () => {
      if (newWorker) newWorker.postMessage({ type: 'SKIP_WAITING' });
      hideUpdateBanner();
    });

    updateDismiss.addEventListener('click', () => { hideUpdateBanner(); });

    // ─── PWA Install Experience ───
    const INSTALL_DISMISS_KEY = 'pwa-install-dismissed';
    const INSTALL_DISMISS_DAYS = 14;
    let deferredPrompt = null;

    function isIOS() {
      return /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
    }

    function isInStandaloneMode() {
      return window.matchMedia('(display-mode: standalone)').matches ||
             window.navigator.standalone === true;
    }

    function wasRecentlyDismissed() {
      const dismissed = localStorage.getItem(INSTALL_DISMISS_KEY);
      if (!dismissed) return false;
      return Date.now() - parseInt(dismissed, 10) < INSTALL_DISMISS_DAYS * 86400000;
    }

    function showInstallBanner() {
      if (isInStandaloneMode() || wasRecentlyDismissed()) return;
      if (!deferredPrompt && !isIOS()) return;

      const banner = document.getElementById('pwaInstallBanner');
      const subtitle = document.getElementById('pwaInstallSubtitle');
      const btn = document.getElementById('pwaInstallBtn');

      if (isIOS()) {
        subtitle.innerHTML = 'Tap <span>⬆️ Share</span> then <span>➕ Add to Home Screen</span>';
        btn.textContent = 'Got it';
        btn.onclick = dismissInstallBanner;
      } else {
        subtitle.textContent = 'Play offline, get notifications, and launch instantly from your home screen.';
        btn.textContent = 'Install';
        btn.onclick = triggerInstall;
      }

      banner.classList.add('show');
    }

    function dismissInstallBanner() {
      document.getElementById('pwaInstallBanner').classList.remove('show');
      localStorage.setItem(INSTALL_DISMISS_KEY, Date.now().toString());
    }

    async function triggerInstall() {
      if (!deferredPrompt) return;
      deferredPrompt.prompt();
      const { outcome } = await deferredPrompt.userChoice;
      deferredPrompt = null;
      document.getElementById('pwaInstallBanner').classList.remove('show');

      if (outcome === 'accepted') {
        localStorage.removeItem(INSTALL_DISMISS_KEY);
        showInstalledToast();
      }
    }

    function showInstalledToast() {
      const toast = document.getElementById('pwaInstalledToast');
      toast.classList.add('show');
      setTimeout(() => { toast.classList.remove('show'); }, 4000);
    }

    // Capture the install prompt (Android/Desktop Chrome, Edge, etc.)
    window.addEventListener('beforeinstallprompt', (e) => {
      e.preventDefault();
      deferredPrompt = e;
      // Show after engagement delay (10s or scroll)
      setTimeout(showInstallBanner, 10000);
    });

    // Show installed toast if app was just installed
    window.addEventListener('appinstalled', () => {
      deferredPrompt = null;
      document.getElementById('pwaInstallBanner').classList.remove('show');
      showInstalledToast();
    });

    // iOS: show banner after scroll engagement (not immediately)
    if (isIOS() && !isInStandaloneMode() && !wasRecentlyDismissed()) {
      let iosShown = false;
      const showOnScroll = () => {
        if (!iosShown && window.scrollY > 200) {
          iosShown = true;
          showInstallBanner();
          window.removeEventListener('scroll', showOnScroll);
        }
      };
      window.addEventListener('scroll', showOnScroll, { passive: true });
      // Fallback: show after 15s even without scroll
      setTimeout(() => { if (!iosShown) { iosShown = true; showInstallBanner(); } }, 15000);
    }

    // Wire up dismiss button
    document.getElementById('pwaInstallDismiss').addEventListener('click', dismissInstallBanner);

    // ─── Auth UI Functions ───
    function showAuthModal() { document.getElementById('authModal').classList.add('show'); }
    function hideAuthModal() { document.getElementById('authModal').classList.remove('show'); }
    function toggleUserMenu() { document.getElementById('userMenu').classList.toggle('open'); }

    function toggleMobileMenu() {
      const nav = document.getElementById('mobileNav');
      const btn = document.getElementById('mobileMenuBtn');
      nav.classList.toggle('open');
      btn.textContent = nav.classList.contains('open') ? '\u2715' : '☰';
    }

    function closeMobileMenu() {
      const nav = document.getElementById('mobileNav');
      const btn = document.getElementById('mobileMenuBtn');
      nav.classList.remove('open');
      btn.textContent = '☰';
    }

    document.addEventListener('click', (e) => {
      const userMenu = document.getElementById('userMenu');
      if (!userMenu.contains(e.target)) userMenu.classList.remove('open');
    });

    document.getElementById('authModal').addEventListener('click', (e) => {
      if (e.target.id === 'authModal') hideAuthModal();
    });

    async function signInWithGoogle() {
      try {
        await window.authManager.signInWithGoogle();
        hideAuthModal();
      } catch (error) {
        console.error('Sign in failed:', error);
        alert('Sign in failed. Please try again.');
      }
    }

    function handleSignOut(e) {
      e.preventDefault();
      e.stopPropagation();
      window.authManager.signOut();
      document.getElementById('userMenu').classList.remove('open');
    }

    function showProfile(e) {
      e.preventDefault();
      e.stopPropagation();
      alert('Profile page coming soon!');
    }

    function showLeaderboards(e) {
      e.preventDefault();
      e.stopPropagation();
      alert('Leaderboards page coming soon!');
    }

    function updateAuthUI(user) {
      const signInBtn = document.getElementById('signInBtn');
      const userMenu = document.getElementById('userMenu');
      const userAvatar = document.getElementById('userAvatar');
      const userName = document.getElementById('userName');

      if (user) {
        signInBtn.style.display = 'none';
        userMenu.classList.add('signed-in');
        userAvatar.src = user.photoURL || 'https://via.placeholder.com/36?text=' + (user.displayName?.[0] || 'U');
        userName.textContent = user.displayName || user.email?.split('@')[0] || 'Player';
      } else {
        signInBtn.style.display = 'block';
        userMenu.classList.remove('signed-in');
      }
    }

    window.addEventListener('load', () => {
      const checkAuth = setInterval(() => {
        if (window.authManager?.isInitialized) {
          clearInterval(checkAuth);
          window.authManager.onAuthStateChanged(updateAuthUI);
        }
      }, 100);
    });
  </script>

</BaseLayout>

