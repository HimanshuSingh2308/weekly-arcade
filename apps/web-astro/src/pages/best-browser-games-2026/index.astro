---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';

const gameModules = import.meta.glob('../../data/games/*.json', { eager: true });
const gameCount = Object.keys(gameModules).length;

const siteUrl = 'https://weeklyarcade.games';
const pageUrl = '/best-browser-games-2026/';
const pageTitle = `${gameCount} Best Free Browser Games in 2026 — No Downloads | Weekly Arcade`;
const pageDescription = `The ${gameCount} best free browser games you can play right now in 2026. Puzzle, arcade, racing, strategy, and 3D games — no downloads, no signup. Updated weekly.`;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: `${gameCount} Best Free Browser Games in 2026`,
  description: pageDescription,
  url: `${siteUrl}${pageUrl}`,
  datePublished: '2026-04-08',
  dateModified: '2026-04-08',
  author: { '@type': 'Organization', name: 'Weekly Arcade', url: siteUrl },
  publisher: {
    '@type': 'Organization',
    name: 'Weekly Arcade',
    url: siteUrl,
    logo: { '@type': 'ImageObject', url: `${siteUrl}/icons/icon-512.png` },
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What are the best free browser games in 2026?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: `The top free browser games in 2026 include Drift Legends (3D racing), Chess 3D (online chess with AI), Wordle (daily word puzzle), 2048 (number merge), Solitaire Roguelite (card game), and Snake (classic arcade). All ${gameCount}+ games on Weekly Arcade are free with no downloads required.`,
      },
    },
    {
      '@type': 'Question',
      name: 'Can I play browser games without downloading anything?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Modern HTML5 browser games run directly in Chrome, Safari, Firefox, or Edge with no downloads, plugins, or installations. Games on Weekly Arcade average under 50KB and load in under 1.5 seconds.',
      },
    },
    {
      '@type': 'Question',
      name: 'Are browser games free to play?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Many browser games are completely free. All games on Weekly Arcade are 100% free with no ads, no paywalls, and no premium tiers. Guest play has no restrictions.',
      },
    },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Best Browser Games 2026', item: `${siteUrl}${pageUrl}` },
  ],
};
---

<BaseLayout title={pageTitle}>
  <Fragment slot="head">
    <link rel="preconnect" href="https://www.gstatic.com" crossorigin>
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#e94560">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Weekly Arcade">
    <link rel="apple-touch-icon" href="/icons/icon-180.png">
    <meta name="description" content={pageDescription}>
    <meta name="keywords" content="best browser games 2026, best free browser games, top browser games, browser games ranking, free online games 2026, best HTML5 games, best no download games">
    <link rel="canonical" href={`${siteUrl}${pageUrl}`}>
    <meta property="og:title" content={pageTitle}>
    <meta property="og:description" content={pageDescription}>
    <meta property="og:type" content="article">
    <meta property="og:url" content={`${siteUrl}${pageUrl}`}>
    <meta property="og:image" content={`${siteUrl}/og-image.png`}>
    <meta property="og:site_name" content="Weekly Arcade">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={pageTitle}>
    <meta name="twitter:description" content={pageDescription}>
    <meta name="twitter:image" content={`${siteUrl}/og-image.png`}>
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <SiteHeader showAuth={false} activePage="games" />

  <section class="hero">
    <h1>{gameCount} Best Free <span class="highlight">Browser Games</span> in 2026</h1>
    <p>No downloads, no signup, no ads &mdash; just the best browser games you can play right now, ranked and reviewed.</p>
  </section>

  <main class="container">
    <div class="tldr-box">
      <strong>Updated April 2026:</strong> We tested and ranked {gameCount}+ free browser games across puzzle, arcade, racing, strategy, and 3D categories. Every game loads in under 1.5 seconds, works on mobile, and is 100% free. Here are the best ones.
    </div>

    <nav class="toc content-card">
      <h2>Table of Contents</h2>
      <ol>
        <li><a href="#best-overall">Best Overall: Drift Legends</a></li>
        <li><a href="#best-puzzle">Best Puzzle: Wordle</a></li>
        <li><a href="#best-strategy">Best Strategy: Chess 3D</a></li>
        <li><a href="#best-arcade">Best Arcade: Coin Cascade</a></li>
        <li><a href="#best-card">Best Card Game: Solitaire Roguelite</a></li>
        <li><a href="#best-classic">Best Classic: Snake</a></li>
        <li><a href="#best-casual">Best Casual: 2048</a></li>
        <li><a href="#best-action">Best Action: Voidbreak</a></li>
        <li><a href="#best-creative">Best Creative: Fieldstone</a></li>
        <li><a href="#best-sim">Best Simulation: Tiny Tycoon</a></li>
        <li><a href="#comparison">Full Comparison Table</a></li>
        <li><a href="#how-we-ranked">How We Ranked These Games</a></li>
        <li><a href="#faq">FAQ</a></li>
      </ol>
    </nav>

    <article class="article-content">

      <section id="best-overall" class="content-card game-pick">
        <div class="pick-badge">Best Overall</div>
        <h2>Drift Legends</h2>
        <p><strong>Genre:</strong> 3D Racing &bull; <strong>Session:</strong> 5&ndash;15 min &bull; <strong>Multiplayer:</strong> Yes</p>
        <p>Drift Legends is a full 3D arcade racing game with a 5-chapter story mode, real-time multiplayer, and 15 tracks ranging from neon city streets to sky-high circuits. The drift mechanics feel satisfying from the first lap, and the progression system keeps you coming back. Built with Babylon.js, it proves that browser games can rival mobile app quality.</p>
        <p><strong>Why it's #1:</strong> Deepest content of any browser game we've tested &mdash; story mode, multiplayer, 15 tracks, and persistent progression. All in a browser.</p>
        <a href="/games/drift-legends/" class="pick-cta">Play Drift Legends &rarr;</a>
      </section>

      <section id="best-puzzle" class="content-card game-pick">
        <div class="pick-badge">Best Puzzle</div>
        <h2>Wordle</h2>
        <p><strong>Genre:</strong> Word Puzzle &bull; <strong>Session:</strong> 2&ndash;3 min &bull; <strong>Multiplayer:</strong> No (daily challenge)</p>
        <p>The viral word guessing game that needs no introduction. Guess a 5-letter word in 6 tries with color-coded feedback. A new word every day keeps it fresh, and the sub-3-minute sessions make it the perfect daily ritual.</p>
        <p><strong>Why it's top puzzle:</strong> Perfect difficulty curve, daily engagement hook, and universally accessible. The gold standard for browser puzzle games.</p>
        <a href="/games/wordle/" class="pick-cta">Play Wordle &rarr;</a>
      </section>

      <section id="best-strategy" class="content-card game-pick">
        <div class="pick-badge">Best Strategy</div>
        <h2>Chess 3D</h2>
        <p><strong>Genre:</strong> Board / Strategy &bull; <strong>Session:</strong> 5&ndash;30 min &bull; <strong>Multiplayer:</strong> Yes</p>
        <p>A beautifully rendered 3D chess experience with 4 AI difficulty levels, ELO rating tracking, and online multiplayer. The rotatable board adds a tactile quality that flat chess sites can't match. Supports both casual and serious play.</p>
        <p><strong>Why it's top strategy:</strong> Full chess experience with AI + multiplayer + ELO, all in a browser with no account required.</p>
        <a href="/games/chess-3d/" class="pick-cta">Play Chess 3D &rarr;</a>
      </section>

      <section id="best-arcade" class="content-card game-pick">
        <div class="pick-badge">Best Arcade</div>
        <h2>Coin Cascade</h2>
        <p><strong>Genre:</strong> Physics Arcade &bull; <strong>Session:</strong> 3&ndash;5 min &bull; <strong>Multiplayer:</strong> No</p>
        <p>Drop coins onto a physics-driven pusher and watch chain reactions cascade prizes off the edge. Simple to understand, deeply satisfying thanks to polished physics and coin-clink sound effects. The "just one more drop" factor is strong.</p>
        <p><strong>Why it's top arcade:</strong> Best "juice" of any game on this list &mdash; every interaction feels rewarding thanks to physics feedback and sound design.</p>
        <a href="/games/coin-cascade/" class="pick-cta">Play Coin Cascade &rarr;</a>
      </section>

      <section id="best-card" class="content-card game-pick">
        <div class="pick-badge">Best Card Game</div>
        <h2>Solitaire Roguelite</h2>
        <p><strong>Genre:</strong> Card / Roguelite &bull; <strong>Session:</strong> 5&ndash;10 min &bull; <strong>Multiplayer:</strong> No</p>
        <p>Classic Klondike Solitaire with a twist: rule-breaking Joker cards that add strategic depth and replay value. Each run feels different as you decide when to use your Jokers for maximum impact.</p>
        <p><strong>Why it's top card game:</strong> Familiar enough for solitaire fans, innovative enough to keep experienced players engaged. The roguelite layer adds genuine replayability.</p>
        <a href="/games/solitaire-roguelite/" class="pick-cta">Play Solitaire Roguelite &rarr;</a>
      </section>

      <section id="best-classic" class="content-card game-pick">
        <div class="pick-badge">Best Classic</div>
        <h2>Snake</h2>
        <p><strong>Genre:</strong> Classic Arcade &bull; <strong>Session:</strong> 2&ndash;5 min &bull; <strong>Multiplayer:</strong> No</p>
        <p>The timeless snake game with modern polish. Eat, grow, avoid walls. Simple controls, escalating difficulty, and leaderboard competition give this classic surprising longevity.</p>
        <p><strong>Why it's top classic:</strong> Purest gameplay loop on this list. One mechanic, instant understanding, infinite replayability.</p>
        <a href="/games/snake/" class="pick-cta">Play Snake &rarr;</a>
      </section>

      <section id="best-casual" class="content-card game-pick">
        <div class="pick-badge">Best Casual</div>
        <h2>2048</h2>
        <p><strong>Genre:</strong> Number Puzzle &bull; <strong>Session:</strong> 3&ndash;10 min &bull; <strong>Multiplayer:</strong> No</p>
        <p>Slide tiles to merge matching numbers and reach 2048. Deceptively simple, strategically deep. Every swipe matters, and the spatial reasoning required makes it genuinely addictive.</p>
        <p><strong>Why it's top casual:</strong> Perfect for any skill level. Easy to start, hard to master, impossible to play just once.</p>
        <a href="/games/2048/" class="pick-cta">Play 2048 &rarr;</a>
      </section>

      <section id="best-action" class="content-card game-pick">
        <div class="pick-badge">Best Action</div>
        <h2>Voidbreak</h2>
        <p><strong>Genre:</strong> Space Shooter / Roguelite &bull; <strong>Session:</strong> 5&ndash;10 min &bull; <strong>Multiplayer:</strong> No</p>
        <p>Smash asteroids, collect upgrades, and go deeper into the void. Each run offers different upgrade choices, creating a roguelite experience where no two sessions are the same.</p>
        <p><strong>Why it's top action:</strong> Best upgrade system on this list. The "one more run" pull is powerful, and the difficulty scaling feels fair.</p>
        <a href="/games/voidbreak/" class="pick-cta">Play Voidbreak &rarr;</a>
      </section>

      <section id="best-creative" class="content-card game-pick">
        <div class="pick-badge">Most Creative</div>
        <h2>Fieldstone</h2>
        <p><strong>Genre:</strong> Strategy / Puzzle &bull; <strong>Session:</strong> 5&ndash;15 min &bull; <strong>Multiplayer:</strong> No</p>
        <p>Tetris meets kingdom builder. Place terrain pieces, harvest completed rows, and defend your realm from invaders. A genre mashup that shouldn't work but absolutely does.</p>
        <p><strong>Why it's most creative:</strong> The most original game concept on this list. Combines puzzle mechanics with strategy in a way we haven't seen elsewhere.</p>
        <a href="/games/fieldstone/" class="pick-cta">Play Fieldstone &rarr;</a>
      </section>

      <section id="best-sim" class="content-card game-pick">
        <div class="pick-badge">Best Simulation</div>
        <h2>Tiny Tycoon</h2>
        <p><strong>Genre:</strong> Business Simulation &bull; <strong>Session:</strong> 3&ndash;10 min &bull; <strong>Multiplayer:</strong> No</p>
        <p>Run a boba tea shop in 60-second days. Serve customers, earn coins, unlock upgrades. The time pressure creates a satisfying rhythm, and the upgrade system gives you clear goals to chase.</p>
        <p><strong>Why it's top simulation:</strong> Best progression loop for a browser sim. Short days keep sessions snappy while upgrades provide long-term motivation.</p>
        <a href="/games/tiny-tycoon/" class="pick-cta">Play Tiny Tycoon &rarr;</a>
      </section>

      <section id="comparison" class="content-card">
        <h2>Full Comparison Table</h2>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Game</th>
                <th>Genre</th>
                <th>Session</th>
                <th>Multiplayer</th>
                <th>Best For</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><a href="/games/drift-legends/">Drift Legends</a></td><td>3D Racing</td><td>5&ndash;15 min</td><td>Yes</td><td>Deep experience</td></tr>
              <tr><td><a href="/games/wordle/">Wordle</a></td><td>Word Puzzle</td><td>2&ndash;3 min</td><td>No</td><td>Daily ritual</td></tr>
              <tr><td><a href="/games/chess-3d/">Chess 3D</a></td><td>Strategy</td><td>5&ndash;30 min</td><td>Yes</td><td>Competitive play</td></tr>
              <tr><td><a href="/games/coin-cascade/">Coin Cascade</a></td><td>Physics Arcade</td><td>3&ndash;5 min</td><td>No</td><td>Satisfying feedback</td></tr>
              <tr><td><a href="/games/solitaire-roguelite/">Solitaire Roguelite</a></td><td>Card</td><td>5&ndash;10 min</td><td>No</td><td>Card game fans</td></tr>
              <tr><td><a href="/games/snake/">Snake</a></td><td>Classic Arcade</td><td>2&ndash;5 min</td><td>No</td><td>Quick fun</td></tr>
              <tr><td><a href="/games/2048/">2048</a></td><td>Number Puzzle</td><td>3&ndash;10 min</td><td>No</td><td>Any skill level</td></tr>
              <tr><td><a href="/games/voidbreak/">Voidbreak</a></td><td>Space Shooter</td><td>5&ndash;10 min</td><td>No</td><td>Action fans</td></tr>
              <tr><td><a href="/games/fieldstone/">Fieldstone</a></td><td>Strategy/Puzzle</td><td>5&ndash;15 min</td><td>No</td><td>Original concepts</td></tr>
              <tr><td><a href="/games/tiny-tycoon/">Tiny Tycoon</a></td><td>Simulation</td><td>3&ndash;10 min</td><td>No</td><td>Progression chasers</td></tr>
            </tbody>
          </table>
        </div>
      </section>

      <section id="how-we-ranked" class="content-card">
        <h2>How We Ranked These Games</h2>
        <p><strong>A browser game</strong> is a video game that runs entirely in a web browser using HTML5, JavaScript, and CSS &mdash; requiring no downloads, plugins, or installations. The browser gaming market is projected to reach $35.1 billion by 2027 according to <a href="https://www.mordorintelligence.com/industry-reports/browser-games-market" target="_blank" rel="noopener">Mordor Intelligence</a>, driven by improvements in WebGL, Web Audio API, and mobile browser performance.</p>
        <p>We evaluated each game on five criteria:</p>
        <ol>
          <li><strong>Fun factor (30%)</strong> &mdash; Does the core loop create genuine "one more round" moments? We measured this by average session duration and return rate.</li>
          <li><strong>Polish (25%)</strong> &mdash; Sound, animation, and visual quality relative to browser game standards. Games with synthesized audio via the <a href="https://developer.mozilla.org/en-US/docs/Web/API/Web_Audio_API" target="_blank" rel="noopener">Web Audio API</a> scored higher for responsiveness.</li>
          <li><strong>Accessibility (20%)</strong> &mdash; Can anyone understand and enjoy it within 10 seconds? We tested with first-time players across ages 12&ndash;65.</li>
          <li><strong>Replayability (15%)</strong> &mdash; Is there a reason to come back tomorrow? Daily challenges, leaderboards, and progression systems all contribute.</li>
          <li><strong>Performance (10%)</strong> &mdash; Load time under 1.5 seconds on 4G, 60fps on modern browsers, and mobile compatibility from 320px screens.</li>
        </ol>
        <p>All games on this list are 100% free with no ads. This ranking is updated as new games are added to Weekly Arcade. <a href="/how-we-build-games/">Learn how we build a new game every week</a>.</p>
        <p><strong>Limitations:</strong> This ranking only covers games on Weekly Arcade. We don't evaluate games from other platforms, and our scoring is based on internal playtesting data rather than external review aggregators.</p>
      </section>

      <section id="faq" class="content-card">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
          <h3>What are the best free browser games in 2026?</h3>
          <p>The top free browser games in 2026 include Drift Legends (3D racing with multiplayer), Chess 3D (online chess with AI and ELO), Wordle (daily word puzzle), 2048 (number merge), Solitaire Roguelite (card game with Joker mechanics), and Snake (classic arcade). All {gameCount}+ games on Weekly Arcade are free with no downloads.</p>
        </div>

        <div class="faq-item">
          <h3>Can I play browser games without downloading anything?</h3>
          <p>Yes. Modern HTML5 browser games run directly in Chrome, Safari, Firefox, or Edge with no downloads, plugins, or installations needed. Games on Weekly Arcade average under 50KB and load in under 1.5 seconds on a 4G connection.</p>
        </div>

        <div class="faq-item">
          <h3>Are browser games free to play?</h3>
          <p>Many browser games are free, though some include ads or microtransactions. All games on Weekly Arcade are 100% free with no ads, no paywalls, and no premium tiers. Guest play has no restrictions &mdash; signing in is optional for leaderboards and cloud saves.</p>
        </div>

        <div class="faq-item">
          <h3>What is the best browser game for a quick break?</h3>
          <p>For a 2&ndash;3 minute break, Wordle and Snake are ideal. For 5 minutes, try Coin Cascade or Stack Tower. All <a href="/games/quick/">quick browser games</a> are designed for short, satisfying sessions with no commitment.</p>
        </div>

        <div class="faq-item">
          <h3>Can I play browser games on my phone?</h3>
          <p>Yes. All games on this list are designed mobile-first with touch controls, responsive layouts, and optimized performance. They work on any modern smartphone or tablet without an app download.</p>
        </div>
      </section>
    </article>

    <div class="cta">
      <a href="/games/" class="cta-btn">Browse All {gameCount} Games &rarr;</a>
    </div>
  </main>

  <footer class="footer">
    <p><strong>Weekly Arcade</strong> &mdash; New free browser games every week.</p>
    <p style="margin-top: 0.5rem;">
      <a href="/">Home</a> &nbsp;|&nbsp; <a href="/games/">Games</a> &nbsp;|&nbsp; <a href="/how-we-build-games/">How We Build Games</a> &nbsp;|&nbsp; <a href="/about/">About</a> &nbsp;|&nbsp; <a href="/privacy/">Privacy</a> &nbsp;|&nbsp; <a href="/terms/">Terms</a>
    </p>
    <p style="margin-top: 0.5rem; font-size: 0.75rem;">&copy; 2026 Weekly Arcade. All rights reserved.</p>
  </footer>

  <script is:inline src="/js/api-client.js"></script>
  <script is:inline src="/js/auth.js"></script>
  <script is:inline>
    function toggleMobileMenu() {
      const nav = document.getElementById('mobileNav');
      const btn = document.getElementById('mobileMenuBtn');
      nav.classList.toggle('open');
      btn.textContent = nav.classList.contains('open') ? '\u2715' : '\u2630';
    }
    function toggleUserMenu() { document.getElementById('userMenu').classList.toggle('open'); }
    function handleSignOut(e) { e.preventDefault(); e.stopPropagation(); window.authManager.signOut(); document.getElementById('userMenu').classList.remove('open'); }
    function updateAuthUI(user) {
      const s = document.getElementById('signInBtn'), m = document.getElementById('userMenu'), a = document.getElementById('userAvatar'), n = document.getElementById('userName');
      if (user) { if(s) s.style.display='none'; if(m) m.classList.add('signed-in'); if(a) a.src=user.photoURL||''; if(n) n.textContent=user.displayName||'Player'; }
      else { if(s) s.style.display='block'; if(m) m.classList.remove('signed-in'); }
    }
    document.addEventListener('click', (e) => { const m=document.getElementById('userMenu'); if(m&&!m.contains(e.target)) m.classList.remove('open'); });
    const checkAuth = setInterval(() => { if(window.authManager?.isInitialized){clearInterval(checkAuth);window.authManager.onAuthStateChanged(updateAuthUI);} }, 100);
  </script>
</BaseLayout>

<style is:global>
  :root {
    --bg-primary: #0a0a12;
    --bg-secondary: #12121f;
    --bg-card: rgba(22, 33, 62, 0.6);
    --bg-card-solid: #16213e;
    --accent: #e94560;
    --accent-hover: #ff6b6b;
    --accent-glow: rgba(233, 69, 96, 0.3);
    --purple: #7c3aed;
    --text-primary: #f0f0f5;
    --text-secondary: #8888a8;
    --border: rgba(255, 255, 255, 0.06);
    --glass: rgba(255, 255, 255, 0.03);
    --gold: #ffd700;
    --radius: 16px;
    --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: var(--bg-primary);
    color: var(--text-primary);
    min-height: 100vh;
    line-height: 1.6;
    background-image: radial-gradient(rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 32px 32px;
  }

  .hero {
    position: relative; text-align: center; padding: 4rem 2rem 3rem; overflow: hidden;
  }
  .hero::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse 70% 60% at 50% 0%, rgba(233,69,96,0.1) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 80% 10%, rgba(124,58,237,0.06) 0%, transparent 50%);
    pointer-events: none;
  }
  .hero h1 { font-size: 2.5rem; font-weight: 800; letter-spacing: -0.03em; margin-bottom: 0.75rem; position: relative; }
  .hero h1 .highlight {
    background: linear-gradient(135deg, var(--accent), var(--purple));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 600px; margin: 0 auto; position: relative; }

  .container { max-width: 800px; margin: 0 auto; padding: 0 2rem 3rem; }

  .tldr-box {
    background: linear-gradient(135deg, rgba(233,69,96,0.08), rgba(124,58,237,0.08));
    border: 1px solid rgba(233,69,96,0.2); border-radius: var(--radius);
    padding: 1.25rem 1.5rem; margin-bottom: 1.5rem; color: var(--text-secondary); line-height: 1.7; font-size: 0.95rem;
  }
  .tldr-box strong { color: var(--accent); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; }

  .toc { margin-bottom: 1.5rem; }
  .toc h2 { font-size: 1rem; margin-bottom: 0.75rem; }
  .toc ol { margin: 0; padding-left: 1.25rem; columns: 2; column-gap: 2rem; }
  .toc li { margin-bottom: 0.4rem; font-size: 0.9rem; break-inside: avoid; }
  .toc a { color: var(--accent); text-decoration: none; }
  .toc a:hover { text-decoration: underline; }

  .content-card {
    background: var(--bg-card); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    border: 1px solid var(--border); border-radius: var(--radius); padding: 2rem; margin-bottom: 1.25rem;
    transition: border-color var(--transition);
  }
