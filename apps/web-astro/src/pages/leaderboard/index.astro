---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
---

<BaseLayout title="Global Leaderboards — Compete Worldwide | Weekly Arcade">
  <Fragment slot="head">
    <link rel="preconnect" href="https://www.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://firestore.googleapis.com" crossorigin>
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#e94560">
    <link rel="apple-touch-icon" href="/icons/icon-180.png">
    <meta name="description" content="Compete on global leaderboards across 15+ free browser games. Daily, weekly, and monthly rankings. Sign in to track your scores and climb the charts.">
    <link rel="canonical" href="https://weeklyarcade.games/leaderboard/">
    <meta property="og:title" content="Global Leaderboards — Compete Worldwide | Weekly Arcade">
    <meta property="og:description" content="Compete on global leaderboards across 15+ free browser games. Daily, weekly, and monthly rankings.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://weeklyarcade.games/leaderboard/">
    <meta property="og:image" content="https://weeklyarcade.games/og-image.png">
    <meta property="og:site_name" content="Weekly Arcade">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Global Leaderboards — Compete Worldwide | Weekly Arcade">
    <meta name="twitter:description" content="Compete on global leaderboards across 15+ free browser games. Daily, weekly, and monthly rankings.">
    <meta name="twitter:image" content="https://weeklyarcade.games/og-image.png">
  </Fragment>

  <SiteHeader activePage="leaderboards" />

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="page-hero-inner">
      <h1>Global <span class="highlight">Leaderboards</span></h1>
      <p>Compete with players worldwide. Pick a game and claim your spot.</p>
    </div>
  </section>

  <!-- Game Picker -->
  <div class="game-picker">
    <div class="game-picker-scroll" id="gamePickerScroll"></div>
  </div>

  <!-- Leaderboard -->
  <main class="lb-container">
    <div class="lb-controls">
      <div class="lb-game-title" id="lbGameTitle">
        <span class="lb-game-title-icon">🎮</span>
        <div>
          <h2>Leaderboard</h2>
          <span class="lb-subtitle">Select a game above</span>
        </div>
      </div>
      <div class="period-tabs" id="periodTabs">
        <button class="period-tab active" data-period="daily">Today</button>
        <button class="period-tab" data-period="weekly">Week</button>
        <button class="period-tab" data-period="monthly">Month</button>
        <button class="period-tab" data-period="allTime">All Time</button>
      </div>
    </div>

    <!-- Your Rank -->
    <div class="your-rank-card" id="yourRankCard" style="display: none;">
      <div class="your-rank-badge" id="yourRankBadge">#-</div>
      <div class="your-rank-info">
        <h3>Your Rank</h3>
        <p id="yourRankSubtitle">Keep playing to climb!</p>
      </div>
      <div class="your-rank-score">
        <div class="score" id="yourScore">0</div>
        <div class="label">points</div>
      </div>
    </div>

    <div class="sign-in-card" id="signInCard">
      <p>Sign in to track your rank and compete on the leaderboard!</p>
      <button class="auth-btn" onclick="showAuthModal()">Sign In</button>
    </div>

    <!-- Podium -->
    <div class="podium" id="podium" style="display: none;"></div>

    <!-- Remaining ranks -->
    <div class="lb-list" id="lbList">
      <div class="lb-header-row">
        <div>Rank</div>
        <div>Player</div>
        <div style="text-align: right;">Score</div>
      </div>
      <div id="leaderboardContent">
        <div class="loading-state">
          <div class="loading-spinner"></div>
          <p>Loading scores...</p>
        </div>
      </div>
    </div>
  </main>

  <footer class="footer">
    <p><strong>Weekly Arcade</strong> &mdash; New free browser games every week.</p>
    <p style="margin-top: 0.5rem;">
      <a href="/">Games</a> &nbsp;|&nbsp; <a href="/privacy/">Privacy</a> &nbsp;|&nbsp; <a href="/terms/">Terms</a>
    </p>
  </footer>

  <!-- Auth Modal -->
  <div class="modal-overlay" id="authModal">
    <div class="modal">
      <button class="modal-close" onclick="hideAuthModal()">&times;</button>
      <h2>Join the Competition</h2>
      <p>Sign in to submit scores and climb the ranks!</p>
      <button class="google-btn" onclick="signInWithGoogle()">
        <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" alt="Google">
        Continue with Google
      </button>
    </div>
  </div>

  <!-- Firebase SDK -->

  <!-- API & Auth Scripts -->


  <script is:inline src="/js/api-client.js"></script>
  <script is:inline src="/js/auth.js"></script>
    
  <script is:inline>
    // ─── Game Configuration — inline fallback + API refresh ───
    let GAMES = [
      { id: 'stack-tower', name: 'Stack Tower', icon: '🏗️', description: 'Timing arcade' },
      { id: 'voidbreak', name: 'Voidbreak', icon: '☄️', description: 'Asteroid roguelite' },
      { id: 'wordle', name: 'Wordle', icon: '🔤', description: 'Word puzzle' },
      { id: 'snake', name: 'Snake', icon: '🐍', description: 'Classic arcade' },
      { id: '2048', name: '2048', icon: '🔢', description: 'Number puzzle' },
      { id: 'chaos-kitchen', name: 'Chaos Kitchen', icon: '👨‍🍳', description: 'Cooking game' },
      { id: 'memory-match', name: 'Memory Match', icon: '🃏', description: 'Card matching' },
      { id: 'lumble', name: 'Lumble', icon: '🫧', description: '3D platformer' },
      { id: 'fieldstone', name: 'Fieldstone', icon: '🏰', description: 'Kingdom builder' },
      { id: 'solitaire-roguelite', name: 'Solitaire Roguelite', icon: '🃏', description: 'Klondike with Jokers' },
      { id: 'coin-cascade', name: 'Coin Cascade', icon: '🪙', description: 'Physics coin pusher' },
      { id: 'tiny-tycoon', name: 'Tiny Tycoon', icon: '🧋', description: 'Boba shop simulator' },
      { id: 'cricket-blitz', name: 'Cricket Blitz', icon: '🏏', description: '3D IPL-style cricket' },
    ];

    const urlGame = new URLSearchParams(window.location.search).get('game');
    let currentGame = urlGame || 'stack-tower';
    let currentPeriod = 'daily';
    let currentUser = null;

    async function loadGameCatalog() {
      try {
        const catalog = await window.apiClient.getGameCatalog();
        if (catalog && catalog.length > 0) {
          GAMES = catalog;
          // Validate URL param against real catalog
          if (!GAMES.some(g => g.id === currentGame)) {
            currentGame = GAMES[0].id;
          }
        }
      } catch (e) {
        console.warn('Failed to load game catalog, using fallback', e);
      }
    }

    // ─── Build Game Picker Chips ───
    function initGamePicker() {
      const scroll = document.getElementById('gamePickerScroll');
      scroll.innerHTML = GAMES.map(g => `
        <button class="game-chip ${g.id === currentGame ? 'active' : ''}" data-game="${g.id}">
          <span class="game-chip-icon">${g.icon}</span>
          ${g.name}
        </button>
      `).join('');

      scroll.addEventListener('click', (e) => {
        const chip = e.target.closest('.game-chip');
        if (!chip) return;
        selectGame(chip.dataset.game);
      });
    }

    // ─── Period Tabs ───
    function initPeriodTabs() {
      document.querySelectorAll('.period-tab').forEach(tab => {
        tab.addEventListener('click', () => selectPeriod(tab.dataset.period));
      });
    }

    // ─── Select Game ───
    function selectGame(gameId) {
      currentGame = gameId;
      const game = GAMES.find(g => g.id === gameId);

      // Update URL so the link is shareable
      const url = new URL(window.location);
      url.searchParams.set('game', gameId);
      history.replaceState(null, '', url);

      document.querySelectorAll('.game-chip').forEach(c => {
        c.classList.toggle('active', c.dataset.game === gameId);
      });

      // Scroll active chip into view
      const activeChip = document.querySelector('.game-chip.active');
      if (activeChip) activeChip.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });

      document.getElementById('lbGameTitle').innerHTML = `
        <span class="lb-game-title-icon">${game.icon}</span>
        <div>
          <h2>${game.name}</h2>
          <span class="lb-subtitle">${game.description}</span>
        </div>
      `;

      loadLeaderboard();
      if (currentUser) loadUserRank();
    }

    // ─── Select Period ───
    function selectPeriod(period) {
      currentPeriod = period;
      document.querySelectorAll('.period-tab').forEach(tab => {
        tab.classList.toggle('active', tab.dataset.period === period);
      });
      loadLeaderboard();
      if (currentUser) loadUserRank();
    }

    // ─── Avatar URL helper ───
    function avatarUrl(url, name) {
      return url || `https://ui-avatars.com/api/?name=${encodeURIComponent(name || 'P')}&background=e94560&color=fff&size=72`;
    }

    function avatarErrorFallback(el) {
      el.src = "https://ui-avatars.com/api/?name=P&background=e94560&color=fff";
    }

    // ─── Load Leaderboard ───
    async function loadLeaderboard() {
      const content = document.getElementById('leaderboardContent');
      const podiumEl = document.getElementById('podium');

      content.innerHTML = `<div class="loading-state"><div class="loading-spinner"></div><p>Loading scores...</p></div>`;
      podiumEl.style.display = 'none';

      try {
        const data = await window.apiClient.getLeaderboard(currentGame, currentPeriod, 50);

        if (!data || data.length === 0) {
          podiumEl.style.display = 'none';
          content.innerHTML = `
            <div class="empty-state">
              <div class="empty-icon">🏆</div>
              <h3>No scores yet!</h3>
              <p>Be the first to set a high score.</p>
            </div>
          `;
          return;
        }

        // Build podium (top 3)
        const top3 = data.slice(0, 3);
        const medals = ['🥇', '🥈', '🥉'];

        if (top3.length >= 2) {
          podiumEl.style.display = 'flex';
          podiumEl.innerHTML = top3.map((entry, i) => {
            const name = entry.odName || entry.displayName || 'Player';
            const avatar = avatarUrl(entry.odAvatarUrl || entry.avatarUrl, name);
            return `
              <div class="podium-slot" data-rank="${i + 1}">
                <div class="podium-medal">${medals[i]}</div>
                <img class="podium-avatar" src="${avatar}" alt="${name}" onerror="avatarErrorFallback(this)">
                <div class="podium-name">${name}</div>
                <div class="podium-score">${entry.score?.toLocaleString() || 0} pts</div>
              </div>
            `;
          }).join('');
        } else {
          podiumEl.style.display = 'none';
        }

        // Build remaining rows (rank 4+)
        const rest = data.slice(3);

        if (rest.length === 0) {
          content.innerHTML = '';
          return;
        }

        content.innerHTML = rest.map((entry, index) => {
          const rank = index + 4;
          const odId = entry.odId || entry.odId;
          const name = entry.odName || entry.displayName || 'Player';
          const avatar = avatarUrl(entry.odAvatarUrl || entry.avatarUrl, name);
          const isCurrentUser = currentUser && odId === currentUser.uid;
          const level = entry.level || 1;

          return `
            <div class="lb-row ${isCurrentUser ? 'highlight' : ''}">
              <div class="rank ${rank <= 10 ? 'top' : ''}">#${rank}</div>
              <div class="player">
                <img class="player-avatar" src="${avatar}" alt="${name}" onerror="avatarErrorFallback(this)">
                <div class="player-info">
                  <div class="player-name">${name}</div>
                  <div class="player-meta">Level ${level}</div>
                </div>
              </div>
              <div class="score-cell">${entry.score?.toLocaleString() || 0}</div>
            </div>
          `;
        }).join('');
      } catch (error) {
        console.error('Failed to load leaderboard:', error);
        podiumEl.style.display = 'none';
        content.innerHTML = `
          <div class="empty-state">
            <div class="empty-icon">😕</div>
            <h3>Couldn't load leaderboard</h3>
            <p>Please try again later.</p>
          </div>
        `;
      }
    }

    // ─── Load User Rank ───
    async function loadUserRank() {
      if (!currentUser) return;

      try {
        const rankData = await window.apiClient.getMyRank(currentGame, currentPeriod);
        const badge = document.getElementById('yourRankBadge');
        const score = document.getElementById('yourScore');
        const subtitle = document.getElementById('yourRankSubtitle');

        if (rankData && rankData.rank) {
          badge.textContent = `#${rankData.rank}`;
          score.textContent = rankData.score?.toLocaleString() || '0';
          subtitle.textContent = rankData.rank <= 3 ? "You're on the podium! 🎉" :
                                  rankData.rank <= 10 ? "Top 10! Amazing!" : "Keep playing to climb!";
        } else {
          badge.textContent = '#-';
          score.textContent = '0';
          subtitle.textContent = "Play to get ranked!";
        }
      } catch (error) {
        console.error('Failed to load user rank:', error);
      }
    }

    // ─── Auth Functions ───
    function showAuthModal() { document.getElementById('authModal').classList.add('show'); }
    function hideAuthModal() { document.getElementById('authModal').classList.remove('show'); }
    function toggleUserMenu() { document.getElementById('userMenu').classList.toggle('open'); }

    function toggleMobileMenu() {
      const nav = document.getElementById('mobileNav');
      const btn = document.getElementById('mobileMenuBtn');
      nav.classList.toggle('open');
      btn.textContent = nav.classList.contains('open') ? '\u2715' : '☰';
    }

    async function signInWithGoogle() {
      try {
        await window.authManager.signInWithGoogle();
        hideAuthModal();
      } catch (error) {
        console.error('Sign in failed:', error);
      }
    }

    function handleSignOut(e) {
      e.preventDefault();
      e.stopPropagation();
      window.authManager.signOut();
      document.getElementById('userMenu').classList.remove('open');
    }

    function updateAuthUI(user) {
      currentUser = user;
      const signInBtn = document.getElementById('signInBtn');
      const userMenu = document.getElementById('userMenu');
      const userAvatar = document.getElementById('userAvatar');
      const signInCard = document.getElementById('signInCard');
      const yourRankCard = document.getElementById('yourRankCard');

      if (user) {
        signInBtn.style.display = 'none';
        userMenu.classList.add('signed-in');
        userAvatar.src = user.photoURL || avatarUrl(null, user.displayName || 'U');
        signInCard.style.display = 'none';
        yourRankCard.style.display = 'flex';
        loadUserRank();
      } else {
        signInBtn.style.display = 'block';
        userMenu.classList.remove('signed-in');
        signInCard.style.display = 'flex';
        yourRankCard.style.display = 'none';
      }
    }

    // ─── Click Outside Handlers ───
    document.addEventListener('click', (e) => {
      const userMenu = document.getElementById('userMenu');
      if (!userMenu.contains(e.target)) userMenu.classList.remove('open');
    });

    document.getElementById('authModal').addEventListener('click', (e) => {
      if (e.target.id === 'authModal') hideAuthModal();
    });

    // ─── Initialize ───
    window.addEventListener('load', async () => {
      await loadGameCatalog();
      initGamePicker();
      initPeriodTabs();
      selectGame(currentGame);

      const checkAuth = setInterval(() => {
        if (window.authManager?.isInitialized) {
          clearInterval(checkAuth);
          window.authManager.onAuthStateChanged(updateAuthUI);
        }
      }, 100);
    });
  </script>

</BaseLayout>

<style is:global>

    :root {
      --bg-primary: #0a0a12;
      --bg-secondary: #12121f;
      --bg-card: rgba(22, 33, 62, 0.6);
      --bg-card-solid: #16213e;
      --accent: #e94560;
      --accent-hover: #ff6b6b;
      --accent-glow: rgba(233, 69, 96, 0.3);
      --purple: #7c3aed;
      --purple-glow: rgba(124, 58, 237, 0.2);
      --text-primary: #f0f0f5;
      --text-secondary: #8888a8;
      --border: rgba(255, 255, 255, 0.06);
      --glass: rgba(255, 255, 255, 0.03);
      --gold: #ffd700;
      --gold-glow: rgba(255, 215, 0, 0.15);
      --silver: #c0c0c0;
      --silver-glow: rgba(192, 192, 192, 0.1);
      --bronze: #cd7f32;
      --bronze-glow: rgba(205, 127, 50, 0.1);
      --radius: 16px;
      --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: var(--bg-primary);
      color: var(--text-primary);
      min-height: 100vh;
      background-image: radial-gradient(rgba(255,255,255,0.03) 1px, transparent 1px);
      background-size: 32px 32px;
    }

    /* ─── Header ─── */
    .header {
      background: rgba(18, 18, 31, 0.8);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
      padding: 0.8rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 50;
    }

    .logo {
      font-size: 1.4rem;
      font-weight: 800;
      color: var(--text-primary);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      letter-spacing: -0.02em;
    }

    .logo-icon { font-size: 1.6rem; }

    .logo span.brand {
      background: linear-gradient(135deg, var(--accent), var(--purple));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .nav { display: flex; gap: 0.25rem; }

    .nav a {
      color: var(--text-secondary);
      text-decoration: none;
      font-weight: 500;
      font-size: 0.9rem;
      padding: 0.5rem 1rem;
      border-radius: 10px;
      transition: color var(--transition), background var(--transition);
    }

    .nav a:hover { color: var(--text-primary); background: var(--glass); }
    .nav a.active { color: var(--accent); background: rgba(233, 69, 96, 0.08); }

    .mobile-menu-btn {
      display: none;
      background: none;
      border: 1px solid var(--border);
      color: var(--text-primary);
      font-size: 1.2rem;
      padding: 0.4rem 0.6rem;
      border-radius: 8px;
      cursor: pointer;
      line-height: 1;
      transition: border-color var(--transition);
    }
    .mobile-menu-btn:hover { border-color: var(--accent); }

    .header-right {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .auth-btn {
      background: linear-gradient(135deg, var(--accent), #c73e54);
      color: white;
      border: none;
      padding: 0.5rem 1.2rem;
      border-radius: 12px;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      transition: transform var(--transition), box-shadow var(--transition);
    }

    .auth-btn:hover {
      transform: scale(1.05);
      box-shadow: 0 4px 16px rgba(233, 69, 96, 0.3);
    }

    .user-menu { position: relative; display: none; }

    .user-menu.signed-in {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      cursor: pointer;
    }

    .user-avatar {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      border: 2px solid var(--accent);
      object-fit: cover;
    }

    .user-dropdown {
      position: absolute;
      top: calc(100% + 0.5rem);
      right: 0;
      background: var(--bg-card-solid);
      border: 1px solid var(--border);
      border-radius: 12px;
      min-width: 170px;
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
      opacity: 0;
      visibility: hidden;
      transform: translateY(-10px);
      transition: all 0.2s;
      z-index: 100;
    }

    .user-menu.open .user-dropdown {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }

    .dropdown-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.7rem 1rem;
      color: var(--text-primary);
      text-decoration: none;
      font-size: 0.85rem;
      transition: background var(--transition);
    }

    .dropdown-item:hover { background: rgba(255, 255, 255, 0.04); }
    .dropdown-item:first-child { border-radius: 12px 12px 0 0; }
    .dropdown-item:last-child { border-radius: 0 0 12px 12px; }
    .dropdown-divider { height: 1px; background: var(--border); }
    .dropdown-item.sign-out { color: var(--accent); }

    /* ─── Page Header ─── */
    .page-hero {
      position: relative;
      padding: 2.5rem 2rem 0;
      overflow: hidden;
    }

    .page-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 70% 60% at 50% 0%, rgba(233, 69, 96, 0.1) 0%, transparent 60%),
        radial-gradient(ellipse 50% 40% at 80% 10%, rgba(124, 58, 237, 0.06) 0%, transparent 50%);
      pointer-events: none;
    }

    .page-hero-inner {
      max-width: 900px;
      margin: 0 auto;
      position: relative;
      text-align: center;
    }

    .page-hero h1 {
      font-size: 2.2rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      margin-bottom: 0.5rem;
    }

    .page-hero h1 .highlight {
      background: linear-gradient(135deg, var(--accent), var(--purple));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .page-hero p {
      color: var(--text-secondary);
      font-size: 1rem;
      margin-bottom: 2rem;
    }

    /* ─── Game Picker ─── */
    .game-picker {
      max-width: 900px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    .game-picker-scroll {
      display: flex;
      gap: 0.5rem;
      overflow-x: auto;
      padding: 0.5rem 0 1rem;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .game-picker-scroll::-webkit-scrollbar { display: none; }

    .game-chip {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.55rem 1rem;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: var(--glass);
      color: var(--text-secondary);
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      transition: all var(--transition);
      white-space: nowrap;
    }

    .game-chip:hover {
      color: var(--text-primary);
      border-color: rgba(255, 255, 255, 0.12);
      background: rgba(255, 255, 255, 0.06);
    }

    .game-chip.active {
      color: white;
      background: linear-gradient(135deg, var(--accent), #c73e54);
      border-color: transparent;
      box-shadow: 0 2px 12px rgba(233, 69, 96, 0.3);
    }

    .game-chip-icon { font-size: 1.1rem; }

    /* ─── Leaderboard Panel ─── */
    .lb-container {
      max-width: 900px;
      margin: 0 auto;
      padding: 1.5rem 2rem 3rem;
    }

    /* Controls Row */
    .lb-controls {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.25rem;
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .lb-game-title {
      display: flex;
      align-items: center;
