---
import GameLayout from '../../layouts/GameLayout.astro';
import gameData from '../../data/games/coin-cascade.json';
---

<GameLayout
  title={gameData.title}
  gameName={gameData.name}
  gameId={gameData.id}
  icon={gameData.icon}
  description={gameData.description}
  keywords={gameData.keywords}
  url={gameData.url}
  themeColor={gameData.themeColor}
  accentColor={gameData.accentColor}
  genres={gameData.genres}
  ratingValue={gameData.ratingValue}
  ratingCount={gameData.ratingCount}
  tips={gameData.tips}
  howToPlay={gameData.howToPlay}
  similarTo={gameData.similarTo}
  aboutGame={gameData.aboutGame}
  faq={gameData.faq}
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/games/coin-cascade/styles.css">
  </Fragment>


  <!-- Header -->

  <!-- HUD -->
  <div class="hud">
    <div class="hud-item">
      <div class="hud-label">Score</div>
      <div class="hud-value" id="hudScore">0</div>
    </div>
    <div class="hud-item">
      <div class="hud-label">Coins Left</div>
      <div class="hud-value" id="hudCoins">40</div>
    </div>
    <div class="hud-item">
      <div class="hud-label">Combo</div>
      <div class="hud-value combo" id="hudCombo">-</div>
    </div>
    <div class="hud-item">
      <div class="hud-label">Best</div>
      <div class="hud-value" id="hudBest">0</div>
    </div>
  </div>

  <!-- Game Canvas -->
  <canvas id="gameCanvas" role="img" aria-label="Coin Cascade game board — drop coins onto a pusher to cascade them off the edge and score points"></canvas>
  <div id="srAnnounce" class="sr-only" aria-live="polite" aria-atomic="true"></div>

  <!-- Start Overlay -->
  <div class="overlay" id="startOverlay" role="dialog" aria-modal="true" aria-labelledby="startTitle">
    <div class="modal">
      <h2 id="startTitle">&#x1FA99; Coin Cascade</h2>
      <p>Tap to drop coins onto the pusher. Cascade them off the edge to score!</p>
      <button class="btn btn-primary" id="startBtn">Drop First Coin!</button>
    </div>
  </div>

  <!-- Game Over Overlay -->
  <div class="overlay hidden" id="gameOverOverlay" role="dialog" aria-modal="true" aria-labelledby="goTitle">
    <div class="modal">
      <h2 id="goTitle">Round Over!</h2>
      <div class="stat-grid">
        <div class="stat-box">
          <div class="label">Score</div>
          <div class="value" id="goScore">0</div>
        </div>
        <div class="stat-box">
          <div class="label">Best</div>
          <div class="value" id="goBest">0</div>
        </div>
        <div class="stat-box">
          <div class="label">Collected</div>
          <div class="value" id="goCollected">0</div>
        </div>
        <div class="stat-box">
          <div class="label">Max Combo</div>
          <div class="value" id="goCombo">0</div>
        </div>
      </div>
      <button class="btn btn-primary" id="retryBtn">Play Again</button>
      <button class="btn btn-secondary" id="homeBtn">Home</button>
    </div>
  </div>

    <Fragment slot="scripts">
    <script is:inline src="/games/coin-cascade/game.js"></script>
  </Fragment>
</GameLayout>


