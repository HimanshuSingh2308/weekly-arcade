---
import GameLayout from '../../layouts/GameLayout.astro';
import gameData from '../../data/games/stack-tower.json';
---

<GameLayout
  title={gameData.title}
  gameName={gameData.name}
  gameId={gameData.id}
  icon={gameData.icon}
  description={gameData.description}
  keywords={gameData.keywords}
  url={gameData.url}
  themeColor={gameData.themeColor}
  accentColor={gameData.accentColor}
  genres={gameData.genres}
  ratingValue={gameData.ratingValue}
  ratingCount={gameData.ratingCount}
  tips={gameData.tips}
  howToPlay={gameData.howToPlay}
  similarTo={gameData.similarTo}
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/games/stack-tower/styles.css">
  </Fragment>


  <div class="stats-bar">
    <div class="stat">
      <div class="stat-value" id="scoreDisplay">0</div>
      <div class="stat-label">Score</div>
    </div>
    <div class="stat">
      <div class="stat-value" id="heightDisplay">0</div>
      <div class="stat-label">Height</div>
    </div>
    <div class="stat">
      <div class="stat-value" id="comboDisplay">0x</div>
      <div class="stat-label">Combo</div>
    </div>
    <div class="stat">
      <div class="stat-value" id="highScoreDisplay">0</div>
      <div class="stat-label">Best</div>
    </div>
  </div>

  <div class="game-container">
    <canvas id="gameCanvas"></canvas>
  </div>

  <div class="combo-indicator" id="comboIndicator"></div>

  <!-- Start Screen -->
  <div class="game-overlay" id="startOverlay">
    <div class="overlay-content">
      <div class="overlay-icon">🏗️</div>
      <h2 class="overlay-title">Stack Tower</h2>
      <p class="overlay-subtitle">Stack blocks with perfect timing to build the tallest tower!</p>
      <button class="play-btn" onclick="startGame()">Play</button>
      <p class="controls-hint">Tap anywhere or press Space to drop</p>
    </div>
  </div>

  <!-- Game Over Screen -->
  <div class="game-overlay hidden" id="gameOverOverlay">
    <div class="overlay-content">
      <div class="overlay-icon">🏗️</div>
      <h2 class="overlay-title">Tower Complete!</h2>
      <div class="overlay-score" id="finalScore">0</div>
      <p class="overlay-high-score" id="newHighScore" style="display: none;">🎉 New High Score!</p>
      <div class="game-stats">
        <div class="game-stat">
          <div class="game-stat-value" id="finalHeight">0</div>
          <div class="game-stat-label">Height</div>
        </div>
        <div class="game-stat">
          <div class="game-stat-value" id="finalCombo">0</div>
          <div class="game-stat-label">Max Combo</div>
        </div>
        <div class="game-stat">
          <div class="game-stat-value" id="finalPerfects">0%</div>
          <div class="game-stat-label">Perfects</div>
        </div>
      </div>
      <button class="play-btn" onclick="startGame()">Play Again</button>
    </div>
  </div>

  <!-- Auth Modal -->
  <div class="auth-modal-overlay" id="authModal">
    <div class="auth-modal">
      <button class="auth-modal-close" onclick="hideAuthModal()">×</button>
      <h2>Save Your Score</h2>
      <p>Sign in to compete on the leaderboard!</p>
      <button class="google-btn" onclick="signInWithGoogle()">
        <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" alt="Google">
        Continue with Google
      </button>
    </div>
  </div>

  <!-- Firebase SDK -->

  <!-- API & Auth Scripts --><!-- More Games Section -->
</body>

    <Fragment slot="scripts">
    <script is:inline src="/games/stack-tower/game.js"></script>
  </Fragment>
</GameLayout>


