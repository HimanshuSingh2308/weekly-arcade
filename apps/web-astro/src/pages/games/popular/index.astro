---
import CategoryPage from '../../../components/CategoryPage.astro';

const games = [
  { slug: 'snake', title: 'Snake', description: "Classic snake game. Eat, grow, don't hit the walls!", thumbnail: 'snake.svg', alt: 'Snake - most popular free browser game', tags: [{ label: 'Arcade' }, { label: 'Classic' }] },
  { slug: '2048', title: '2048', description: 'Slide tiles and merge numbers to reach 2048.', thumbnail: '2048.svg', alt: '2048 - popular free number puzzle game', tags: [{ label: 'Puzzle' }, { label: 'Strategy' }] },
  { slug: 'wordle', title: 'Wordle', description: 'Guess the 5-letter word in 6 tries. A new word every day!', thumbnail: 'wordle.svg', alt: 'Wordle - popular free daily word puzzle', tags: [{ label: 'Puzzle' }, { label: 'Daily' }] },
  { slug: 'drift-legends', title: 'Drift Legends', description: '3D arcade racing with story mode, drift mechanics, and real-time multiplayer. 15 tracks across 5 chapters!', thumbnail: 'drift-legends.svg', alt: 'Drift Legends - popular free 3D racing game', tags: [{ label: 'Racing' }, { label: '3D' }, { label: 'Multiplayer' }] },
  { slug: 'stack-tower', title: 'Stack Tower', description: 'Stack blocks with perfect timing to build the tallest tower!', thumbnail: 'stack-tower.svg', alt: 'Stack Tower - popular free stacking arcade game', tags: [{ label: 'Arcade' }, { label: 'Timing' }] },
  { slug: 'chess-3d', title: 'Chess 3D', description: '3D chess with smart AI and online multiplayer! 4 difficulty levels, ELO rating, rotatable board.', thumbnail: 'chess-3d.svg', alt: 'Chess 3D - popular free online chess game', tags: [{ label: 'Strategy' }, { label: '3D' }] },
  { slug: 'coin-cascade', title: 'Coin Cascade', description: 'Drop coins onto a physics pusher to cascade prizes off the edge!', thumbnail: 'coin-cascade.svg', alt: 'Coin Cascade - popular free physics arcade game', tags: [{ label: 'Arcade' }, { label: 'Physics' }] },
  { slug: 'solitaire-roguelite', title: 'Solitaire Roguelite', description: 'Classic Solitaire with rule-breaking Joker cards. How high can you score?', thumbnail: 'solitaire-roguelite.svg', alt: 'Solitaire Roguelite - popular free card game', tags: [{ label: 'Card' }, { label: 'Roguelite' }] },
  { slug: 'tiny-tycoon', title: 'Tiny Tycoon', description: 'Run a boba tea shop in 60-second days. Serve customers, earn coins, upgrade!', thumbnail: 'tiny-tycoon.svg', alt: 'Tiny Tycoon - popular free business simulation game', tags: [{ label: 'Simulation' }, { label: 'Idle' }] },
  { slug: 'voidbreak', title: 'Voidbreak', description: 'Smash asteroids, upgrade your ship, go deeper. How far can you get?', thumbnail: 'voidbreak.svg', alt: 'Voidbreak - popular free space shooter game', tags: [{ label: 'Action' }, { label: 'Roguelite' }] },
];
---

<CategoryPage
  category="Popular"
  categorySlug="popular"
  title="Most Popular Free Browser Games - Top 10 | Weekly Arcade"
  metaDescription="The 10 most popular free browser games on Weekly Arcade. Snake, 2048, Wordle, Drift Legends, and more - ranked by player engagement. No downloads, no ads."
  keywords="most popular browser games, top browser games, popular free games, best free online games, most played browser games, trending browser games, top 10 browser games"
  h1="Most Popular Games"
  introText="The <strong>10 most popular games</strong> on Weekly Arcade, ranked by player sessions and leaderboard activity. These are the games players keep coming back to - from classic arcade to 3D racing."
  seoHeading="Top 10 Most Played Browser Games"
  seoText="This ranking is based on actual player engagement data: total sessions, average session duration, return rate, and leaderboard submissions. Games with simple one-tap mechanics and strong 'one more round' hooks consistently perform best. Our data shows that games with sub-1-second load times see 40% longer sessions than slower-loading alternatives. This list is updated as engagement patterns change."
  seoBullets={[
    '<strong>#1 Snake</strong> - The timeless classic remains our most-played game with the highest return rate',
    '<strong>#2 2048</strong> - Number merge puzzle with the longest average session time',
    '<strong>#3 Wordle</strong> - Daily word puzzle drives consistent daily engagement',
    '<strong>#4 Drift Legends</strong> - 3D racing with the deepest content and multiplayer competition',
    '<strong>#5 Stack Tower</strong> - One-tap arcade with the strongest "one more try" pull',
    '<strong>#6 Chess 3D</strong> - Strategy game with the most leaderboard submissions',
    '<strong>#7 Coin Cascade</strong> - Physics arcade with the highest satisfaction ratings',
    '<strong>#8 Solitaire Roguelite</strong> - Card game with the best replay value',
    '<strong>#9 Tiny Tycoon</strong> - Business sim with the strongest progression loop',
    '<strong>#10 Voidbreak</strong> - Space roguelite with the most dedicated player base',
  ]}
  games={games}
/>
