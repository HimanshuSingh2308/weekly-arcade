---
import CategoryPage from '../../../components/CategoryPage.astro';

const games = [
  { slug: 'doodle-dash', title: 'Doodle Dash', description: 'Multiplayer drawing and guessing party game! Speed Draw mode has everyone drawing simultaneously. Up to 30 players per room!', thumbnail: 'doodle-dash.svg', alt: 'Doodle Dash - free multiplayer drawing and guessing party game', tags: [{ label: 'Party' }, { label: 'Drawing' }, { label: 'Multiplayer' }], isNew: true },
  { slug: 'drift-legends', title: 'Drift Legends', description: '3D arcade racing with story mode, drift mechanics, and real-time multiplayer. 15 tracks across 5 chapters!', thumbnail: 'drift-legends.svg', alt: 'Drift Legends - free multiplayer 3D racing browser game', tags: [{ label: 'Racing' }, { label: '3D' }, { label: 'Multiplayer' }] },
  { slug: 'chess-3d', title: 'Chess 3D', description: '3D chess with smart AI and online multiplayer! 4 difficulty levels, ELO rating, rotatable board.', thumbnail: 'chess-3d.svg', alt: 'Chess 3D - free multiplayer chess browser game', tags: [{ label: 'Strategy' }, { label: '3D' }, { label: 'Multiplayer' }] },
  { slug: 'cricket-blitz', title: 'Cricket Blitz', description: '3D IPL-style cricket! Bat, bowl, win the match. Toss, powerplay, super over!', thumbnail: 'cricket-blitz.svg', alt: 'Cricket Blitz - free multiplayer cricket browser game', tags: [{ label: 'Sports' }, { label: '3D' }] },
