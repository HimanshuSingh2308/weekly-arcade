---
import GameLayout from '../../layouts/GameLayout.astro';
import gameData from '../../data/games/chaos-kitchen.json';
---

<GameLayout
  title={gameData.title}
  gameName={gameData.name}
  gameId={gameData.id}
  icon={gameData.icon}
  description={gameData.description}
  keywords={gameData.keywords}
  url={gameData.url}
  themeColor={gameData.themeColor}
  accentColor={gameData.accentColor}
  genres={gameData.genres}
  ratingValue={gameData.ratingValue}
  ratingCount={gameData.ratingCount}
  tips={gameData.tips}
  howToPlay={gameData.howToPlay}
  similarTo={gameData.similarTo}
  aboutGame={gameData.aboutGame}
  faq={gameData.faq}
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/games/chaos-kitchen/styles.css">
  </Fragment>


  <div class="stats-bar">
    <div class="stat-group">
      <div class="stat">
        <div class="stat-value" id="scoreDisplay">0</div>
        <div class="stat-label">Score</div>
      </div>
      <div class="stat">
        <div class="stat-value multiplier" id="multiplierDisplay">1.0x</div>
        <div class="stat-label">Combo</div>
      </div>
    </div>
    <div class="timer-container">
      <div class="timer-bar">
        <div class="timer-fill" id="timerFill"></div>
      </div>
      <div class="timer-text" id="timerLabel">2:00</div>
    </div>
    <div class="stat-group right">
      <div class="stat">
        <div class="stat-value" id="ordersDisplay">0</div>
        <div class="stat-label">Served</div>
      </div>
      <div class="stat">
        <div class="stat-value" id="levelDisplay">1</div>
        <div class="stat-label">Level</div>
      </div>
    </div>
  </div>

  <div class="chaos-banner" id="chaosBanner">CHAOS EVENT!</div>
  <div class="served-banner" id="servedBanner">🍽️ ORDER SERVED!</div>

  <div class="game-container">
    <div class="kitchen-area" id="kitchenArea">
      <div class="kitchen-floor"></div>

      <!-- Chef Character -->
      <div class="chef" id="chef" style="left: calc(50% - 30px); top: calc(50% - 40px);">
        <div class="chef-body">
          <div class="chef-hat"></div>
          <div class="chef-head">
            <div class="chef-face">&#x1F60A;</div>
          </div>
          <div class="chef-torso">
            <div class="chef-apron"></div>
          </div>
          <div class="chef-held-item" id="chefHeldItem" style="display: none;"></div>
        </div>
      </div>

      <!-- Cooking Stations -->
      <div class="stations-top">
        <div class="station" id="chopStation" onclick="useStation('chop')">
          <div class="station-icon">&#x1F52A;</div>
          <div class="station-label">Chop</div>
          <div class="station-progress" id="chopProgress">
            <div class="station-progress-fill"></div>
          </div>
        </div>
        <div class="station stove" id="cookStation" onclick="useStation('cook')">
          <div class="station-icon">&#x1F373;</div>
          <div class="station-label">Cook</div>
          <div class="station-progress" id="cookProgress">
            <div class="station-progress-fill"></div>
          </div>
        </div>
        <div class="station" id="mixStation" onclick="useStation('mix')">
          <div class="station-icon">&#x1F963;</div>
          <div class="station-label">Mix</div>
          <div class="station-progress" id="mixProgress">
            <div class="station-progress-fill"></div>
          </div>
        </div>
      </div>

      <!-- Ingredient Shelf -->
      <div class="ingredient-shelf" id="ingredientShelf">
        <div class="ingredient" onclick="pickupIngredient('tomato', '&#x1F345;')">
          <span>&#x1F345;</span>
          <span class="ingredient-label">Tomato</span>
        </div>
        <div class="ingredient" onclick="pickupIngredient('lettuce', '&#x1F96C;')">
          <span>&#x1F96C;</span>
          <span class="ingredient-label">Lettuce</span>
        </div>
        <div class="ingredient" onclick="pickupIngredient('meat', '&#x1F969;')">
          <span>&#x1F969;</span>
          <span class="ingredient-label">Meat</span>
        </div>
        <div class="ingredient" onclick="pickupIngredient('cheese', '&#x1F9C0;')">
          <span>&#x1F9C0;</span>
          <span class="ingredient-label">Cheese</span>
        </div>
        <div class="ingredient" onclick="pickupIngredient('bread', '&#x1F35E;')">
          <span>&#x1F35E;</span>
          <span class="ingredient-label">Bread</span>
        </div>
        <div class="ingredient" onclick="pickupIngredient('egg', '&#x1F95A;')">
          <span>&#x1F95A;</span>
          <span class="ingredient-label">Egg</span>
        </div>
      </div>
    </div>

    <!-- Side Panel -->
    <div class="side-panel">
      <!-- Delivery Zone -->
      <div class="panel-section delivery-zone" onclick="deliverPlate()">
        <div class="delivery-icon">&#x1F37D;&#xFE0F;</div>
        <div class="delivery-label">SERVE ORDER</div>
      </div>

      <!-- Current Plate -->
      <div class="panel-section">
        <div class="panel-title">&#x1F958; Current Plate</div>
        <div class="plate-container" id="plateContainer">
          <div class="plate-empty">Click ingredients to add</div>
        </div>
        <button class="clear-plate-btn" onclick="clearPlate()">&#x1F5D1; Clear Plate</button>
      </div>

      <!-- Orders -->
      <div class="panel-section" style="flex: 1; overflow: hidden;">
        <div class="panel-title">&#x1F4CB; Orders</div>
        <div class="orders-list" id="ordersList"></div>
      </div>
    </div>
  </div>

  <!-- Start Overlay -->
  <div class="game-overlay" id="startOverlay">
    <div class="overlay-content">
      <div class="overlay-icon">&#x1F468;&#x200D;&#x1F373;</div>
      <h2 class="overlay-title">Chaos Kitchen</h2>
      <p class="overlay-subtitle">Run a chaotic kitchen! Fulfill orders before time runs out while surviving crazy chaos events!</p>
      <button class="play-btn" onclick="startGame()">&#x1F525; Start Cooking!</button>
      <div class="how-to-play">
        <h4>How to Play</h4>
        <p>1. Click ingredients to pick them up<br>
           2. Use stations to chop, cook, or mix<br>
           3. Serve complete orders to earn points<br>
           4. Watch out for chaos events!</p>
      </div>
    </div>
  </div>

  <!-- Game Over Overlay -->
  <div class="game-overlay hidden" id="gameOverOverlay">
    <div class="overlay-content">
      <div class="overlay-icon" id="endIcon">&#x2B50;</div>
      <h2 class="overlay-title" id="endTitle">Kitchen Closed!</h2>
      <div class="stars-display" id="starsDisplay">&#x2B50;&#x2B50;&#x2B50;</div>
      <div class="overlay-score" id="finalScore">0</div>
      <div class="overlay-stats">
        <div class="overlay-stat">
          <div class="overlay-stat-value" id="finalOrders">0</div>
          <div class="overlay-stat-label">Orders Served</div>
        </div>
        <div class="overlay-stat">
          <div class="overlay-stat-value" id="finalChaos">0</div>
          <div class="overlay-stat-label">Chaos Survived</div>
        </div>
      </div>
      <button class="play-btn" onclick="startGame()">&#x1F504; Play Again</button>
    </div>
  </div>

  <!-- Scripts --><!-- More Games Section -->
</body>

    <Fragment slot="scripts">
    <script is:inline src="/games/chaos-kitchen/game.js"></script>
  </Fragment>
</GameLayout>


