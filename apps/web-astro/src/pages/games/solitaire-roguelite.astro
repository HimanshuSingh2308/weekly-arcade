---
import GameLayout from '../../layouts/GameLayout.astro';
import gameData from '../../data/games/solitaire-roguelite.json';
---

<GameLayout
  title={gameData.title}
  gameName={gameData.name}
  gameId={gameData.id}
  icon={gameData.icon}
  description={gameData.description}
  keywords={gameData.keywords}
  url={gameData.url}
  themeColor={gameData.themeColor}
  accentColor={gameData.accentColor}
  genres={gameData.genres}
  ratingValue={gameData.ratingValue}
  ratingCount={gameData.ratingCount}
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/games/solitaire-roguelite/styles.css">
    <style is:global>
      body {
        background: #1a5c2a !important;
        color: #fff;
      }
      /* Solitaire uses its own TIME/SCORE header — hide the shared GameHeader */
      #gameHeader {
        display: none !important;
      }
    </style>
  </Fragment>


  <div class="game-header">
    <div class="header-stats">
      <div class="stat-group">
        <span class="stat-label">Time</span>
        <span class="timer-display" id="timer">10:00</span>
      </div>
      <div class="stat-group">
        <span class="stat-label">Score</span>
        <span class="score-display" id="scoreDisplay">0</span>
      </div>
    </div>
  </div>

  <div class="jokers-bar" id="jokersBar"></div>

  <div class="game-area" id="gameArea">
    <div class="top-row" id="topRow"></div>
    <div class="tableau" id="tableau"></div>
  </div>

  <!-- How to Play -->
  <div class="help-overlay" id="helpOverlay" onclick="if(event.target===this)hideHelp()">
    <div class="help-modal">
      <h2>🃏 How to Play</h2>

      <div class="help-section">
        <h3>🎯 Goal</h3>
        <p>Move all 52 cards to the 4 foundation piles, building each from Ace to King by suit. Score as many points as possible before you run out of moves or time.</p>
      </div>

      <hr class="help-divider">

      <div class="help-section">
        <h3>🃏 Basics (Classic Klondike)</h3>
        <ul>
          <li><strong>Tableau</strong> — Stack cards in descending order, alternating colours (red 6 on black 7)</li>
          <li><strong>Foundations</strong> — Build Ace → King by suit (top-right slots)</li>
          <li><strong>Stock</strong> — Tap the deck (top-left) to draw cards to the waste pile</li>
          <li><strong>Controls</strong> — Tap a card to select it, then tap where to move it</li>
        </ul>
      </div>

      <hr class="help-divider">

      <div class="help-section">
        <h3>✨ The Twist: Joker Cards</h3>
        <p>Every time you complete a foundation pile (Ace through King), a <strong>Joker Shop</strong> appears. Pick 1 of 3 Joker cards that <strong>change the rules</strong> for the rest of your run!</p>
        <ul>
          <li><span style="color:var(--joker-common)">Grey = Common</span> — Helpful tweaks</li>
          <li><span style="color:var(--joker-rare)">Blue = Rare</span> — Powerful modifiers</li>
          <li><span style="color:var(--joker-epic)">Gold = Epic</span> — Run-defining (from foundation 2+)</li>
        </ul>
      </div>

      <hr class="help-divider">

      <div class="help-section">
        <h3>🌈 Example Jokers</h3>
        <ul>
          <li><strong>Colour Blind</strong> — Stack same colour (ignore alternating rule)</li>
          <li><strong>Wild King</strong> — Any card can fill an empty column</li>
          <li><strong>Rank Skip</strong> — Cards can stack with a gap of 1 rank</li>
          <li><strong>Foundation Bonus</strong> — +50 pts per card on foundation</li>
          <li><strong>Risk/Reward</strong> — No undo, but all scores ×2</li>
        </ul>
      </div>

      <hr class="help-divider">

      <div class="help-section">
        <h3>📊 Scoring</h3>
        <ul>
          <li>Card to foundation: <strong>+100 pts</strong></li>
          <li>Flip face-down card: <strong>+25 pts</strong></li>
          <li>Complete a foundation pile: <strong>+1,000 pts</strong></li>
          <li>Perfect clear (all 4): <strong>+5,000 bonus</strong></li>
          <li>Time bonus: <strong>+1 pt per second remaining</strong></li>
          <li>Joker multipliers stack on top!</li>
        </ul>
      </div>

      <hr class="help-divider">

      <div class="help-section">
        <h3>⏱️ Timer & Game End</h3>
        <p>You have <strong>10 minutes</strong>. The game ends when time runs out, you get stuck, or you clear all 4 foundations. Remaining time becomes bonus points!</p>
      </div>

      <button class="help-close-btn" onclick="hideHelp()">Got it — Deal me in!</button>
      <button class="help-close-btn btn-daily" onclick="hideHelp(); startDailyChallenge();" style="margin-top:0.5rem;">🎯 Daily Challenge</button>
    </div>
  </div>

  <!-- Joker Shop -->
  <div class="shop-overlay" id="shopOverlay">
    <div class="shop-title">🃏 Joker Shop</div>
    <div class="shop-subtitle" id="shopSubtitle">Foundation complete! Pick a Joker to bend the rules.</div>
    <div class="shop-cards" id="shopCards"></div>
    <button class="shop-skip" id="shopSkip">Skip</button>
  </div>

  <!-- Game Over -->
  <div class="modal-overlay" id="gameOverModal">
    <div class="modal">
      <h2 id="modalTitle">Game Over</h2>
      <div class="final-score" id="finalScore">0</div>
      <div class="stats-grid" id="statsGrid"></div>
      <div class="jokers-used" id="jokersUsed"></div>
      <div id="bestScore"></div>
      <div style="margin-top:1rem;">
        <button class="modal-btn" onclick="startNewGame()">Play Again</button>
        <button class="modal-btn btn-daily" onclick="startDailyChallenge()">🎯 Daily</button>
        <button class="modal-btn" style="background:linear-gradient(135deg,#ffd700,#ff8c00);color:#000;" onclick="showPrestigeShop()">⭐ Prestige</button>
        <button class="modal-btn secondary" onclick="window.location.href='/leaderboard/?game=solitaire-roguelite'">🏆</button>
      </div>
    </div>
  </div>

  <!-- Prestige Shop -->
  <div class="modal-overlay" id="prestigeModal">
    <div class="modal" style="max-width:380px;">
      <h2>⭐ Prestige Shop</h2>
      <div style="text-align:center;margin-bottom:0.75rem;">
        <span style="color:var(--gold);font-size:1.2rem;font-weight:700;" id="prestigeBalance">0</span>
        <span style="color:var(--text-muted);font-size:0.8rem;"> points</span>
      </div>
      <div id="prestigeItems"></div>
      <div style="margin-top:1rem;display:flex;gap:0.5rem;justify-content:center;flex-wrap:wrap;">
        <button class="modal-btn secondary" onclick="hidePrestigeShop()">Close</button>
      </div>
    </div>
  </div>

  <!-- Firebase SDK --></body>

    <Fragment slot="scripts">
    <script is:inline src="/games/solitaire-roguelite/game.js"></script>
  </Fragment>
</GameLayout>


