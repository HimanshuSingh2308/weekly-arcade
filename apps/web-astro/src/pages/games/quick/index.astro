  { slug: 'memory-match', title: 'Memory Match', description: 'Flip cards and find matching pairs. Test your memory!', thumbnail: 'memory-match.svg', alt: 'Memory Match - free quick card matching game', tags: [{ label: 'Casual' }, { label: 'Memory' }] },
  { slug: 'snake', title: 'Snake', description: "Classic snake game. Eat, grow, don't hit the walls!", thumbnail: 'snake.svg', alt: 'Snake - free quick classic arcade game', tags: [{ label: 'Arcade' }, { label: 'Classic' }] },
