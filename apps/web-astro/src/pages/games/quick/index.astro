  { slug: 'bir-glider', title: 'Bir Glider', description: 'One-tap paragliding through the Himalayas. Quick to pick up, hard to master — a single run takes 1-3 minutes.', thumbnail: 'bir-glider.svg', alt: 'Bir Glider - free quick paragliding game', tags: [{ label: 'Endless' }, { label: 'Zen' }], isNew: true },
