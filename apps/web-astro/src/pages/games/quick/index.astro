  { slug: 'stack-tower', title: 'Stack Tower', description: 'Stack blocks with perfect timing to build the tallest tower!', thumbnail: 'stack-tower.svg', alt: 'Stack Tower - free quick browser game to play at work', tags: [{ label: 'Arcade' }, { label: 'Timing' }] },
