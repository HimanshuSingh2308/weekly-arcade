---
/**
 * Tiny Tycoon — Boba Tea Shop Simulator.
 *
 * BEFORE (tiny-tycoon/index.html): 4,629 lines
 * AFTER  (tiny-tycoon.astro):      ~4,550 lines (game-specific only, no duplicated boilerplate)
 *
 * GameLayout handles: meta, SEO, structured data, header, shared modules, fallback, more-games.
 */
import GameLayout from '../../layouts/GameLayout.astro';
import gameData from '../../data/games/tiny-tycoon.json';
---

<GameLayout
  title={gameData.title}
  gameName={gameData.name}
  gameId={gameData.id}
  icon={gameData.icon}
  description={gameData.description}
  keywords={gameData.keywords}
  url={gameData.url}
  themeColor={gameData.themeColor}
  accentColor={gameData.accentColor}
  genres={gameData.genres}
  ratingValue={gameData.ratingValue}
  ratingCount={gameData.ratingCount}
>
  <!-- ═══ Game-specific CSS variables & body override ═══ -->
  <Fragment slot="head">
    <link rel="stylesheet" href="/games/tiny-tycoon/styles.css">
    <style is:global>
      /* Header theming — scoped to .gh so it doesn't affect modal/body text */
      #gameHeader, .gh {
        --bg-secondary: rgba(92, 61, 46, 0.92);
        --border: rgba(255, 255, 255, 0.06);
        --text-primary: #FFF8F0;
        --text-secondary: rgba(255, 248, 240, 0.7);
        --accent: #F5C542;
        background: rgba(92, 61, 46, 0.92) !important;
        color: #FFF8F0;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: #E8D5C0;
        color: #5C3D2E;
        touch-action: manipulation;
        overflow: hidden;
      }
    </style>
  </Fragment>

  <!-- ═══ Game-specific HTML ═══ -->

  <!-- Shared game header -->

  <!-- HUD -->
  <div class="hud" id="hud" style="display:none;">
    <span class="day-badge" id="dayBadge">Day 1</span>
    <div class="hud-item">💰 <span id="hudCoins">0</span></div>
    <div class="hud-item"><span class="hud-timer" id="hudTimer">1:00</span></div>
    <div class="hud-item hud-combo" id="hudCombo">🔥 x1.0</div>
    <button id="pauseBtn" aria-label="Pause game" style="background:none;border:none;color:rgba(255,255,255,0.7);font-size:1.1rem;min-width:44px;min-height:44px;cursor:pointer;">⏸</button>
  </div>

  <!-- Rush Hour Banner -->
  <div class="rush-banner" id="rushBanner">⚡ RUSH HOUR! ⚡</div>

  <!-- Game Area -->
  <div class="game-wrap" id="gameWrap">
    <div class="game-area" id="gameArea">
      <!-- Shop background -->
      <div class="shop-bg">
        <div class="shop-wall"></div>
        <div class="shop-floor"></div>

        <!-- Ceiling lights -->
        <div class="ceiling-light" style="left:20%;">
          <div class="ceiling-glow"></div>
        </div>
        <div class="ceiling-light" style="left:50%;">
          <div class="ceiling-glow"></div>
        </div>
        <div class="ceiling-light" style="left:78%;">
          <div class="ceiling-glow"></div>
        </div>

        <!-- Shelves with items -->
        <div class="shelf shelf-1">
          <span class="shelf-item" style="left:4px;">🍵</span>
          <span class="shelf-item" style="left:22px;">🧋</span>
          <span class="shelf-item" style="left:40px;">☕</span>
        </div>
        <div class="shelf shelf-2">
          <span class="shelf-item" style="left:4px;">🥤</span>
          <span class="shelf-item" style="left:22px;">🍓</span>
        </div>
        <div class="shelf shelf-3">
          <span class="shelf-item" style="left:4px;">🫧</span>
          <span class="shelf-item" style="left:26px;">🧋</span>
          <span class="shelf-item" style="left:48px;">🍵</span>
        </div>

        <!-- Shop evolution decorations -->
        <div class="shop-plant">🌿</div>
        <div class="shop-picture"></div>

        <!-- Menu board -->
        <div class="menu-board"></div>

        <!-- Wall clock -->
        <div class="wall-clock" id="wallClock">
          <div class="clock-hand" id="clockHand"></div>
        </div>

        <!-- Equipment behind counter -->
        <div class="equipment-area">
          <div class="boba-machine"></div>
          <div class="blender"></div>
        </div>

        <!-- Steam particles -->
        <div class="steam-container">
          <div class="steam"></div>
          <div class="steam"></div>
          <div class="steam"></div>
          <div class="steam"></div>
          <div class="steam"></div>
        </div>
      </div>

      <!-- Main Barista behind counter -->
      <div class="barista main-barista" id="mainBarista">
        <div class="barista-head"></div>
        <div class="barista-arm left"></div>
        <div class="barista-arm right"></div>
        <div class="barista-body"></div>
      </div>

      <!-- Auto-serve stations (barista workers) -->
      <div class="auto-stations" id="autoStations"></div>

      <!-- Counter -->
      <div class="counter"></div>

      <!-- Queue area for customers -->
      <div class="queue-area" id="queueArea"></div>

      <!-- Gold Rope Divider -->
      <div class="rope-divider"></div>

      <!-- VIP Lounge (bottom half) -->
      <div class="vip-lounge locked" id="vipLounge">
        <div class="vip-lounge-floor"></div>
        <div class="vip-label">VIP</div>
        <div class="vip-lock">🔒</div>
        <div id="vipTablesContainer"></div>
        <!-- Waiter character -->
        <div class="waiter" id="vipWaiter" style="display:none;">
          <div class="barista-head"></div>
          <div class="barista-arm left"></div>
          <div class="barista-arm right"></div>
          <div class="barista-body"></div>
          <div class="waiter-tray"></div>
        </div>
      </div>

      <!-- VIP customer area (overlaps lounge, for rendering VIP customers) -->
      <div class="vip-customer-area" id="vipCustomerArea"></div>
    </div>
  </div>

  <!-- Title Overlay -->
  <div class="overlay visible" id="titleOverlay" role="dialog" aria-modal="true" aria-label="Tiny Tycoon - Start">
    <div class="modal">
      <div class="title-logo">🧋</div>
      <div class="title-name">Tiny Tycoon</div>
      <div class="title-tagline">Run your own cozy boba shop!</div>
      <div class="title-best" id="titleBest"></div>
      <div id="titleButtons"></div>
    </div>
  </div>

  <!-- Day End Overlay -->
  <div class="overlay" id="dayEndOverlay" role="dialog" aria-modal="true" aria-label="Day results">
    <div class="modal" id="dayEndModal"></div>
  </div>

  <!-- Upgrade Shop Overlay -->
  <div class="overlay" id="shopOverlay" role="dialog" aria-modal="true" aria-label="Upgrade shop">
    <div class="modal shop-modal" id="shopModal"></div>
  </div>

  <!-- Stats Overlay -->
  <div class="overlay" id="statsOverlay" role="dialog" aria-modal="true" aria-label="Player statistics">
    <div class="modal" id="statsModal"></div>
  </div>

  <!-- Achievements Overlay -->
  <div class="overlay" id="achievementsOverlay" role="dialog" aria-modal="true" aria-label="Achievements">
    <div class="modal" id="achievementsModal"></div>
  </div>

  <!-- Store Hub Overlay -->
  <div class="overlay" id="hubOverlay" role="dialog" aria-modal="true" aria-label="Store Hub">
    <div class="modal" id="hubModal" style="max-width:420px;"></div>
  </div>

  <!-- Pause Overlay -->
  <div class="overlay" id="pauseOverlay" role="dialog" aria-modal="true" aria-label="Game paused">
    <div class="modal pause-content">
      <h2>⏸ Paused</h2>
      <br>
      <button class="btn" id="resumeBtn">Resume</button>
      <button class="btn btn-danger" id="quitBtn">Quit to Menu</button>
    </div>
  </div>

  <!-- Achievement Toast -->
  <div class="achievement-toast" id="achievementToast" role="alert"></div>
  <div id="srAnnounce" class="sr-only" aria-live="polite" aria-atomic="true"></div>


  <!-- ═══ Game-specific scripts ═══ -->
    <Fragment slot="scripts">
    <script is:inline src="/games/tiny-tycoon/game.js"></script>
    <script is:inline>if(window._ttInitHeader)window._ttInitHeader();</script>
  </Fragment>
</GameLayout>

<!-- ═══ Tiny Tycoon CSS (game-specific, no shared reset/body) ═══ -->

