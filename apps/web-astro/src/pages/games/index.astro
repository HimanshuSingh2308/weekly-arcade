---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';

// Dynamic game data — auto-updates when game JSON files are added
const gameModules = import.meta.glob('../../data/games/*.json', { eager: true });
const allGames = Object.values(gameModules).map((mod: any) => mod.default || mod) as Array<{ id: string; name: string; icon: string }>;
const gameCount = allGames.length;

const siteUrl = 'https://weeklyarcade.games';

const itemListSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Free Browser Games on Weekly Arcade',
  description: 'All free browser games available on Weekly Arcade — play instantly, no downloads required.',
  numberOfItems: gameCount,
  itemListElement: allGames.map((g, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: g.name,
    url: `${siteUrl}/games/${g.id}/`,
  })),
});
---

<BaseLayout title="Free Browser Games — Play Online Instantly | Weekly Arcade">
  <Fragment slot="head">
    <!-- Preconnect -->
    <link rel="preconnect" href="https://www.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://firestore.googleapis.com" crossorigin>

    <!-- SEO -->
    <meta name="description" content={`Browse all ${gameCount} free browser games on Weekly Arcade. Puzzle, arcade, strategy, 3D, and card games — no downloads, no signup. New games weekly.`}>
    <meta name="keywords" content="free browser games, play online games, no download games, free arcade games, free puzzle games, browser games 2026, online games no signup">
    <link rel="canonical" href="https://weeklyarcade.games/games/">

    <!-- Open Graph -->
    <meta property="og:title" content="Free Browser Games — Play Online Instantly | Weekly Arcade">
    <meta property="og:description" content={`Browse all ${gameCount} free browser games. Puzzle, arcade, strategy, 3D, sports, and card games — no downloads, no signup.`}>
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://weeklyarcade.games/games/">
    <meta property="og:image" content="https://weeklyarcade.games/og-image.png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="Weekly Arcade — free browser games catalog">
    <meta property="og:site_name" content="Weekly Arcade">
    <meta property="og:locale" content="en_US">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Free Browser Games — Play Online Instantly | Weekly Arcade">
    <meta name="twitter:description" content={`Browse all ${gameCount} free browser games. Puzzle, arcade, strategy, 3D, sports, and card games — no downloads, no signup.`}>
    <meta name="twitter:image" content="https://weeklyarcade.games/og-image.png">
    <meta name="twitter:image:alt" content="Weekly Arcade — free browser games catalog">

    <!-- Structured Data: BreadcrumbList -->
    <script type="application/ld+json">{
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://weeklyarcade.games/" },
        { "@type": "ListItem", "position": 2, "name": "Games", "item": "https://weeklyarcade.games/games/" }
      ]
    }</script>

    <!-- Structured Data: ItemList (dynamically generated from game data files) -->
    <script type="application/ld+json" set:html={itemListSchema} />

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#e94560">
    <link rel="apple-touch-icon" href="/icons/icon-180.png">
  </Fragment>

  <SiteHeader activePage="games" />

  <!-- Breadcrumb nav -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="breadcrumb-sep">/</span>
    <span class="breadcrumb-current">Games</span>
  </nav>

  <!-- Page Header -->
  <section class="page-hero">
    <h1>Free Browser Games</h1>
    <p class="page-desc">Play <strong>{gameCount} free browser games</strong> instantly — no downloads, no signup, no ads. From puzzles and card games to 3D action and sports, every game works on desktop, tablet, and mobile. New games added every week.</p>
  </section>

  <!-- Genre Filters -->
