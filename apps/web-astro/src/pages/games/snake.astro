---
/**
 * Snake — Classic arcade game.
 *
 * BEFORE (snake/index.html): 1,125 lines (82 meta/SEO + 335 shared CSS + 487 shared JS/fallback + game logic)
 * AFTER  (snake.astro):       ~400 lines (game-specific CSS + HTML + game logic ONLY)
 *
 * GameLayout handles: meta, SEO, structured data, header, shared modules, fallback, more-games.
 */
import GameLayout from '../../layouts/GameLayout.astro';
import snakeData from '../../data/games/snake.json';
---

<GameLayout
  title={snakeData.title}
  gameName={snakeData.name}
  gameId={snakeData.id}
  icon={snakeData.icon}
  description={snakeData.description}
  keywords={snakeData.keywords}
  url={snakeData.url}
  themeColor={snakeData.themeColor}
  accentColor={snakeData.accentColor}
  genres={snakeData.genres}
  ratingValue={snakeData.ratingValue}
  ratingCount={snakeData.ratingCount}
  tips={snakeData.tips}
  howToPlay={snakeData.howToPlay}
  similarTo={snakeData.similarTo}
  aboutGame={snakeData.aboutGame}
  faq={snakeData.faq}
>
  <!-- ═══ Game-specific CSS variables ═══ -->
  <Fragment slot="head">
    <link rel="stylesheet" href="/games/snake/styles.css">
    <style>
      :root {
        --bg-primary: #0a0a0a;
        --bg-secondary: #1a1a1a;
        --bg-card: #141414;
        --accent: #4ade80;
        --accent-dark: #22c55e;
        --danger: #ef4444;
        --warning: #fbbf24;
        --text-primary: #fff;
        --text-secondary: #888;
        --border: #333;
        --snake-head: #4ade80;
        --snake-body: #22c55e;
        --food: #ef4444;
        --grid-line: #1a1a1a;
      }
    </style>
  </Fragment>

  <!-- ═══ Game-specific HTML (only game UI, no header/meta/boilerplate) ═══ -->

  <div class="stats-bar">
    <div class="stat">
      <div class="stat-value" id="scoreDisplay">0</div>
      <div class="stat-label">Score</div>
    </div>
    <div class="stat">
      <div class="stat-value" id="levelDisplay">1</div>
      <div class="stat-label">Level</div>
    </div>
    <div class="stat">
      <div class="stat-value" id="highScoreDisplay">0</div>
      <div class="stat-label">Best</div>
    </div>
  </div>

  <div class="game-container">
    <canvas id="gameCanvas"></canvas>
  </div>

  <div class="pause-indicator" id="pauseIndicator">PAUSED</div>

  <!-- Start Screen -->
  <div class="game-overlay" id="startOverlay">
    <div class="overlay-content">
      <div class="overlay-icon">{snakeData.icon}</div>
      <h2 class="overlay-title">Snake</h2>
      <p class="overlay-subtitle">Eat food, grow longer, don't crash!</p>
      <button class="play-btn" id="startBtn">Play</button>
      <p class="controls-hint">Swipe or use arrow keys to move</p>
    </div>
  </div>

  <!-- Game Over Screen -->
  <div class="game-overlay hidden" id="gameOverOverlay">
    <div class="overlay-content">
      <div class="overlay-icon">{'\u{1F480}'}</div>
      <h2 class="overlay-title">Game Over</h2>
      <div class="overlay-score" id="finalScore">0</div>
      <p class="overlay-high-score" id="newHighScore" style="display: none;">{'\u{1F389}'} New High Score!</p>
      <p class="overlay-subtitle" id="gameOverSubtitle">You reached level 1</p>
      <button class="play-btn" id="restartBtn">Play Again</button>
    </div>
  </div>

  <!-- Auth Modal -->
  <div class="auth-modal-overlay" id="authModal">
    <div class="auth-modal">
      <button class="auth-modal-close" id="authModalClose">&times;</button>
      <h2>Save Your Score</h2>
      <p>Sign in to compete on the leaderboard!</p>
      <button class="google-btn" id="googleSignInBtn">
        <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" alt="Google">
        Continue with Google
      </button>
    </div>
  </div>

  <!-- ═══ Game-specific scripts ═══ -->
    <Fragment slot="scripts">
    <script is:inline src="/games/snake/game.js"></script>
  </Fragment>
</GameLayout>

<!-- ═══ Game-specific styles (ONLY snake-specific, no shared reset/body/header) ═══ -->

