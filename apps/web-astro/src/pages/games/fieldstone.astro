---
import GameLayout from '../../layouts/GameLayout.astro';
import gameData from '../../data/games/fieldstone.json';
---

<GameLayout
  title={gameData.title}
  gameName={gameData.name}
  gameId={gameData.id}
  icon={gameData.icon}
  description={gameData.description}
  keywords={gameData.keywords}
  url={gameData.url}
  themeColor={gameData.themeColor}
  accentColor={gameData.accentColor}
  genres={gameData.genres}
  ratingValue={gameData.ratingValue}
  ratingCount={gameData.ratingCount}
  tips={gameData.tips}
  howToPlay={gameData.howToPlay}
  similarTo={gameData.similarTo}
  aboutGame={gameData.aboutGame}
  faq={gameData.faq}
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/games/fieldstone/styles.css">
  </Fragment>

  <!-- Menu Screen -->
  <div class="menu-screen" id="menuScreen">
    <div class="menu-icon">🏰</div>
    <h1 class="menu-title">Fieldstone</h1>
    <p class="menu-subtitle">Build your kingdom, one tile at a time</p>

    <div class="menu-meta" id="menuMeta">
      <div class="meta-hearthstones">🔥 <span id="menuHearthstones">0</span> Hearthstones</div>
      <div class="meta-rank">Rank: <span id="menuRank">Peasant</span></div>
      <div class="meta-stats">Runs: <span id="menuRuns">0</span> | Wins: <span id="menuWins">0</span> | Best: <span id="menuBest">0</span></div>
    </div>

    <button class="menu-btn" id="startBtn">Start Game</button>
    <button class="menu-btn" id="tutorialBtn" style="background: var(--bg-card); border: 2px solid var(--border);">How to Play</button>

    <div class="deck-select">
      <button class="deck-btn selected" data-deck="farmer">
        <div class="deck-icon">🌾</div>
        <div class="deck-name">Farmer</div>
        <div class="deck-desc">Food focused</div>
      </button>
      <button class="deck-btn" data-deck="mason">
        <div class="deck-icon">🪨</div>
        <div class="deck-name">Mason</div>
        <div class="deck-desc">Stone & Walls</div>
      </button>
      <button class="deck-btn" data-deck="merchant">
        <div class="deck-icon">💰</div>
        <div class="deck-name">Merchant</div>
        <div class="deck-desc">Gold heavy</div>
      </button>
    </div>
  </div>

  <!-- Header -->

  <!-- Game Container -->
  <div class="game-container">
    <!-- Left Panel -->
    <div class="left-panel">
      <div class="panel-section">
        <div class="panel-title">Resources</div>
        <div class="resources-grid">
          <div class="resource">
            <div class="resource-icon">🪵</div>
            <div class="resource-value" id="lumber">0</div>
            <div class="resource-name">Lumber</div>
          </div>
          <div class="resource">
            <div class="resource-icon">🌾</div>
            <div class="resource-value" id="food">0</div>
            <div class="resource-name">Food</div>
          </div>
          <div class="resource">
            <div class="resource-icon">🪨</div>
            <div class="resource-value" id="stone">0</div>
            <div class="resource-name">Stone</div>
          </div>
          <div class="resource">
            <div class="resource-icon">💰</div>
            <div class="resource-value" id="gold">0</div>
            <div class="resource-name">Gold</div>
          </div>
        </div>
      </div>

      <div class="panel-section wave-info">
        <div class="panel-title">Wave</div>
        <div class="wave-number" id="waveNumber">1</div>
        <div class="wave-progress">
          <div class="wave-progress-fill" id="waveProgress" style="width: 0%"></div>
        </div>
      </div>

      <div class="panel-section cards-section">
        <div class="panel-title">Cards</div>
        <div id="cardsList"></div>
      </div>

      <div class="panel-section jokers-section" id="jokersSection" style="display: none;">
        <div class="panel-title">⭐ Jokers</div>
        <div id="jokersList"></div>
      </div>
    </div>

    <!-- Board -->
    <div class="board-container">
      <div class="game-board" id="gameBoard"></div>

      <div class="next-piece">
        <div class="next-label">NEXT</div>
        <div class="next-preview" id="nextPreview"></div>
      </div>
    </div>

    <!-- Right Panel -->
    <div class="right-panel">
      <div class="panel-section score-section">
        <div class="score-value" id="score">0</div>
        <div class="score-label">Score</div>
      </div>

      <div class="panel-section enemy-section">
        <div class="panel-title">Incoming</div>
        <div id="enemyList"></div>
      </div>
    </div>
  </div>

  <!-- Mobile UI -->
  <div class="mobile-ui">
    <div class="mobile-stats">
      <div class="mobile-stat">
        <span class="mobile-score" id="mobileScore">0</span>
        <span class="mobile-label">Score</span>
      </div>
      <div class="mobile-stat">
        <span class="mobile-wave">Wave <span id="mobileWave">1</span>/10</span>
      </div>
    </div>
    <div class="mobile-resources">
      <div class="mobile-res">🪵<span id="mobileLumber">0</span></div>
      <div class="mobile-res">🌾<span id="mobileFood">0</span></div>
      <div class="mobile-res">🪨<span id="mobileStone">0</span></div>
      <div class="mobile-res">💰<span id="mobileGold">0</span></div>
    </div>
  </div>

  <!-- Gesture Hint (shown once on first mobile play) -->
  <div class="gesture-hint" id="gestureHint" style="display: none;">
    <div class="gesture-hint-title">Touch Controls</div>
    <div class="gesture-hint-items">
      <div class="gesture-hint-item"><div class="gesture-hint-icon">👆</div><span>Tap to rotate</span></div>
      <div class="gesture-hint-item"><div class="gesture-hint-icon">👈👉</div><span>Swipe left/right to move</span></div>
      <div class="gesture-hint-item"><div class="gesture-hint-icon">👇</div><span>Swipe down to hard drop</span></div>
      <div class="gesture-hint-item"><div class="gesture-hint-icon">👆</div><span>Swipe up to rotate</span></div>
    </div>
    <button class="gesture-hint-dismiss" id="gestureHintDismiss">Got it</button>
  </div>

  <!-- Toast Container -->
  <div class="toast-container" id="toastContainer"></div>

  <!-- Controls Hint -->
  <div class="controls-hint">
    <kbd>←→</kbd> Move <kbd>↑</kbd> Rotate <kbd>↓</kbd> Drop <kbd>Space</kbd> Hard Drop
  </div>

  <!-- Shop Modal -->
  <div class="shop-modal" id="shopModal">
    <div class="shop-content">
      <h2 class="shop-title">🛒 Card Shop</h2>
      <div class="shop-cards" id="shopCards"></div>
      <button class="shop-skip" id="shopSkip">Skip (+2 Gold)</button>
    </div>
  </div>

  <!-- Attack Phase Overlay -->
  <div class="attack-overlay" id="attackOverlay">
    <div class="attack-content">
      <div class="attack-title">⚔️ ATTACK PHASE ⚔️</div>
      <div class="attack-enemies" id="attackEnemies"></div>
      <div class="attack-vs">VS</div>
      <div class="attack-defence" id="attackDefence">Your Defence: 0</div>
      <div class="attack-result" id="attackResult"></div>
      <button class="attack-btn" id="attackContinue">Continue</button>
    </div>
  </div>

  <!-- Game Over Modal -->
  <div class="gameover-modal" id="gameoverModal">
    <div class="gameover-content">
      <div class="gameover-icon" id="gameoverIcon">💀</div>
      <div class="gameover-title" id="gameoverTitle">Kingdom Fallen</div>
      <div class="gameover-score" id="gameoverScore">0</div>
      <div class="gameover-wave" id="gameoverWave">Reached Wave 1</div>

      <div class="gameover-meta">
        <div class="gameover-hearthstones" id="gameoverHearthstones">+0 🔥 Hearthstones</div>
        <div class="gameover-total" id="gameoverTotal">Total: 0 🔥</div>
        <div class="gameover-tier" id="gameoverTier">Rank: Peasant</div>
        <div class="gameover-next-tier" id="gameoverNextTier">Next: Apprentice (50 🔥)</div>
      </div>

      <div class="gameover-unlocks" id="gameoverUnlocks" style="display: none;"></div>

      <button class="gameover-btn" onclick="returnToMenu()">Play Again</button>
      <button class="gameover-btn" style="background: var(--bg-card);" onclick="window.location='/'">Home</button>
    </div>
  </div>

  <!-- Tutorial Modal -->
  <div class="tutorial-modal" id="tutorialModal">
    <div class="tutorial-content">
      <div class="tutorial-header">
        <h2 class="tutorial-title">📖 How to Play</h2>
        <button class="tutorial-close" onclick="closeTutorial()">&times;</button>
      </div>

      <div class="tutorial-section">
        <h3>🎯 Objective</h3>
        <p>Build and defend your kingdom! Place terrain tiles to harvest resources, then use those resources to defend against enemy waves. Survive 10 waves to win!</p>
      </div>

      <div class="tutorial-section">
        <h3>🧩 Gameplay Loop</h3>
        <p><strong>1. Place Tiles:</strong> Tetris-style pieces fall from the top. Move and rotate them to fill the board.</p>
        <p><strong>2. Complete Rows:</strong> Fill an entire row to <em>harvest</em> it! Unlike Tetris, rows STAY on the board as permanent kingdom land (shown with golden glow). You gain resources based on the terrain types.</p>
        <p><strong>3. Survive Attacks:</strong> After placing 10 tiles, enemies attack! Your defence (from walls + units) must beat enemy power or you lose tiles.</p>
        <p><strong>4. Shop & Upgrade:</strong> Between waves, buy cards to boost resource production or add defence units.</p>
        <p style="margin-top: 0.5rem; background: rgba(255,215,0,0.1); padding: 8px; border-radius: 6px; border-left: 3px solid var(--gold);">
          <strong>Key Insight:</strong> Group same terrain types together before completing a row for bonus resources!
        </p>
      </div>

      <div class="tutorial-section">
        <h3>🌍 Terrain Types</h3>
        <div class="tutorial-terrains">
          <div class="terrain-item"><span>🌲</span> Forest = 🪵 Lumber</div>
          <div class="terrain-item"><span>🌾</span> Plains = 🌾 Food</div>
          <div class="terrain-item"><span>⛰️</span> Mountain = 🪨 Stone</div>
          <div class="terrain-item"><span>💧</span> River = 💰 Gold</div>
          <div class="terrain-item"><span>🏠</span> Settlement = All</div>
        </div>
      </div>

      <div class="tutorial-section">
        <h3>⌨️ Controls</h3>
        <div class="tutorial-controls">
          <div class="control-item"><kbd>←</kbd><kbd>→</kbd> Move</div>
          <div class="control-item"><kbd>↑</kbd> Rotate</div>
          <div class="control-item"><kbd>↓</kbd> Soft Drop</div>
          <div class="control-item"><kbd>Space</kbd> Hard Drop</div>
        </div>
        <p style="margin-top: 0.5rem; font-size: 0.8rem;">📱 <em>Touch: Tap to rotate, swipe left/right to move, swipe down to hard drop, swipe up to rotate</em></p>
      </div>

      <div class="tutorial-section">
        <h3>💡 Pro Tips</h3>
        <ul class="tutorial-tips">
          <li>Place same terrain types adjacent to each other before completing a row = more resources!</li>
          <li>Clear multiple rows at once for big score bonuses (2 rows = 30pts, 3 = 60pts, 4 = 100pts!)</li>
          <li>Buy unit cards (🗡️🏹🐴) before tough waves - they add to your defence</li>
          <li>Building cards give permanent bonuses (Lumber Mill = +50% lumber forever)</li>
          <li>Watch the "NEXT" preview to plan where to place your current piece</li>
        </ul>
      </div>

      <button class="tutorial-start-btn" onclick="closeTutorial()">Got it!</button>
    </div>
  </div>

  <!-- Firebase --></body>

    <Fragment slot="scripts">
    <script is:inline src="/games/fieldstone/game.js"></script>
  </Fragment>
</GameLayout>


