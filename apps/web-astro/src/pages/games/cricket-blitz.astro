---
/**
 * Cricket Blitz -- IPL-Style Arcade Cricket (Three.js 3D).
 *
 * GameLayout handles: meta, SEO, structured data, header, shared modules, fallback, more-games.
 */
import GameLayout from '../../layouts/GameLayout.astro';
import gameData from '../../data/games/cricket-blitz.json';
---

<GameLayout
  title={gameData.title}
  gameName={gameData.name}
  gameId={gameData.id}
  icon={gameData.icon}
  description={gameData.description}
  keywords={gameData.keywords}
  url={gameData.url}
  themeColor={gameData.themeColor}
  accentColor={gameData.accentColor}
  genres={gameData.genres}
  ratingValue={gameData.ratingValue}
  ratingCount={gameData.ratingCount}
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/games/cricket-blitz/styles.css">
    <script type="importmap">
    {
      "imports": {
        "three": "https://cdn.jsdelivr.net/npm/three@0.170.0/build/three.module.js"
      }
    }
    </script>
    <style is:global>
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: linear-gradient(135deg, #0a0520 0%, #1a0a3e 40%, #2d1160 100%);
        color: #ffffff;
        touch-action: manipulation;
        overflow: hidden;
      }
    </style>
  </Fragment>

  <!-- Game Container -->
  <div class="cb-game-wrap" id="gameWrap">
    <div class="cb-game-container" id="gameContainer">
      <div id="threeContainer" style="position:absolute;inset:0;z-index:1;overflow:hidden;"></div>

      <!-- Touch zones (mobile) -->
      <div class="cb-touch-zones" id="touchZones">
        <div class="cb-touch-zone cb-zone-top" data-shot="straight" aria-label="Lofted drive">
          <span class="cb-zone-arrow">&uarr;</span>
        </div>
        <div class="cb-touch-zone cb-zone-left" data-shot="pull" aria-label="Pull shot">
          <span class="cb-zone-arrow">&larr;</span>
        </div>
        <div class="cb-touch-zone cb-zone-right" data-shot="cut" aria-label="Cut shot">
          <span class="cb-zone-arrow">&rarr;</span>
        </div>
        <div class="cb-touch-zone cb-zone-bottom" data-shot="defense" aria-label="Defensive block">
          <span class="cb-zone-arrow">&darr;</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Batting Scoreboard (TV Broadcast HUD) -->
  <div class="cb-scoreboard" id="scoreboardBat" style="display:none;">
    <div class="cb-sb-row1">
      <span class="cb-sb-teams" id="sbTeams">??? vs ???</span>
      <span class="cb-sb-score" id="sbScore">0/0</span>
      <span class="cb-sb-overs" id="sbOvers">0.0</span>
    </div>
    <div class="cb-sb-row2">
      <span class="cb-sb-target" id="sbTarget">5 overs</span>
      <span class="cb-sb-rr" id="sbRR">RR 0.00</span>
    </div>
    <div class="cb-sb-dots" id="sbDots"></div>
    <div class="cb-powerplay-badge" id="powerplayBadge">POWERPLAY 1.5x</div>
  </div>

  <!-- Bowling Scoreboard (TV Broadcast HUD) -->
  <div class="cb-scoreboard" id="scoreboardBowl" style="display:none;">
    <div class="cb-sb-row1">
      <span class="cb-sb-teams" id="sbBowlTeams">AI: ???</span>
      <span class="cb-sb-score" id="sbBowlScore">0/0</span>
      <span class="cb-sb-overs" id="sbBowlOvers">0.0</span>
    </div>
    <div class="cb-sb-row2">
      <span class="cb-sb-target" id="sbBowlTarget">Target: 0</span>
      <span class="cb-sb-rr" id="sbBowlRR">RR 0.00</span>
    </div>
    <div class="cb-sb-dots" id="sbBowlDots"></div>
  </div>

  <!-- Shot direction indicator (desktop) -->
  <div class="cb-shot-indicator" id="shotIndicator">
    <span id="shotArrow">&uarr;</span>
    <span id="shotLabel">Drive</span>
  </div>

  <!-- Pitch shot type overlay (mobile helper) -->
  <div class="cb-pitch-shot-overlay" id="pitchShotOverlay" aria-hidden="true">
    <span id="pitchShotIcon">&uarr;</span>
    <span id="pitchShotName">DRIVE</span>
  </div>

  <!-- Run chase tension edge glow -->
  <div class="cb-tension-edge" id="tensionEdge" aria-hidden="true"></div>

  <!-- Title / Team Select Overlay -->
  <div class="cb-overlay cb-visible" id="titleOverlay" role="dialog" aria-modal="true" aria-label="Cricket Blitz - Start">
    <div class="cb-modal cb-title-modal">
      <div class="cb-title-icon">🏏</div>
      <h1 class="cb-title-name">Cricket Blitz</h1>
      <p class="cb-title-tagline">IPL-Style Arcade Cricket</p>
      <div class="cb-title-bg-particles" aria-hidden="true"></div>
      <div class="cb-best-score" id="titleBest"></div>

      <h2 class="cb-section-heading">Select Your Team</h2>
      <div class="cb-team-grid" id="teamGrid"></div>

      <!-- Patch #19: Bat Skin Selector -->
      <div id="batSkinSelector" class="cb-bat-skin-selector"></div>

      <!-- Patch #18: Daily Challenge -->
      <div id="dailyChallenge" class="cb-daily-challenge"></div>

      <!-- Patch #23: Streak Badge -->
      <div id="streakBadge" class="cb-streak-badge" style="display:none;"></div>

      <button class="cb-btn cb-btn-play" id="playBtn" disabled>&#9654; START MATCH</button>

      <button class="cb-btn-link" id="howToPlayBtn">How to Play</button>
      <div class="cb-how-to-play" id="howToPlay">
        <button class="cb-htp-close" id="htpCloseBtn" aria-label="Close instructions">&times;</button>
        <h3 style="margin:0 0 12px;color:var(--cb-gold);font-size:1rem;">How to Play</h3>
        <p><strong>BATTING (1st Innings):</strong></p>
        <p><strong>Mobile:</strong> Swipe to choose direction, then tap to swing.</p>
        <p><strong>Desktop:</strong> Arrow keys for direction, <kbd>Space</kbd> to swing.</p>
        <p>Time your shot as the ball reaches you.</p>
        <p>Score as many runs as possible in 5 overs!</p>
        <div class="cb-zone-diagram">
          <div class="cb-zd-top">LOFTED (&uarr;)</div>
          <div class="cb-zd-mid">
            <span>PULL (&larr;)</span>
            <span>CUT (&rarr;)</span>
          </div>
          <div class="cb-zd-bottom">DEFENSE (&darr;)</div>
        </div>
        <p style="margin-top:12px;"><strong>BOWLING (2nd Innings):</strong></p>
        <p><strong>Mobile:</strong> Tap on the pitch to set where the ball lands. Top = bouncer, middle = good length, bottom = yorker. Swipe after tap for swing. Hold longer for a slower ball.</p>
        <p><strong>Desktop:</strong> <kbd>Q/W/E/A/S/D</kbd> or <kbd>1-6</kbd> for delivery type.</p>
        <p>Choose line with <kbd>&larr;</kbd> <kbd>&darr;</kbd> <kbd>&rarr;</kbd> (off/mid/leg).</p>
        <p>Press <kbd>Space</kbd> to start the accuracy meter, press again to stop.</p>
        <p>Hit the green zone for the best deliveries!</p>
        <p>Defend your batting total to win the match!</p>
      </div>
    </div>
  </div>

  <!-- Toss Overlay -->
  <div class="cb-overlay" id="tossOverlay" role="dialog" aria-modal="true" aria-label="Coin Toss">
    <div class="cb-modal cb-toss-modal" id="tossModal">
      <h2>COIN TOSS</h2>
      <div class="cb-coin-container" id="coinContainer">
        <div class="cb-coin" id="tossCoin">
          <div class="cb-coin-front">H</div>
          <div class="cb-coin-back">T</div>
        </div>
      </div>
      <div class="cb-toss-result" id="tossResult" style="display:none;">
        <p id="tossResultText"></p>
        <div class="cb-toss-choice" id="tossChoiceButtons" style="display:none;">
          <p style="color:var(--cb-gold);font-weight:700;margin:8px 0;">You won the toss! Choose to:</p>
          <div class="cb-btn-row">
            <button class="cb-btn" onclick="window._cbTossChoice('bat')">BAT FIRST</button>
            <button class="cb-btn" onclick="window._cbTossChoice('bowl')">BOWL FIRST</button>
          </div>
        </div>
        <div id="tossLostMsg" style="display:none;">
          <p id="tossLostText" style="color:var(--cb-text-dim);margin:8px 0;"></p>
          <button class="cb-btn" onclick="window._cbTossContinue()">CONTINUE</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Between Overs Overlay -->
  <div class="cb-overlay" id="overOverlay" role="dialog" aria-modal="true" aria-label="Over summary">
    <div class="cb-modal cb-over-modal" id="overModal"></div>
  </div>

  <!-- Level Complete Overlay -->
  <div class="cb-overlay" id="levelOverlay" role="dialog" aria-modal="true" aria-label="Level complete">
    <div class="cb-modal cb-level-modal" id="levelModal"></div>
  </div>

  <!-- Game Over Overlay -->
  <div class="cb-overlay" id="gameOverOverlay" role="dialog" aria-modal="true" aria-label="Game over">
    <div class="cb-modal cb-gameover-modal" id="gameOverModal"></div>
  </div>

  <!-- (Bowling HUD replaced by scoreboardBowl above) -->

  <!-- Bowling Delivery Panel (mobile + desktop) -->
  <div class="cb-bowling-panel" id="bowlingPanel" style="display:none;">
    <div class="cb-delivery-grid">
      <button class="cb-delivery-btn selected" data-delivery="straight" onclick="window._cbSelectDelivery('straight')">
        <span class="cb-delivery-key">Q/1</span>
        <span class="cb-delivery-name">Straight</span>
      </button>
      <button class="cb-delivery-btn" data-delivery="inswing" onclick="window._cbSelectDelivery('inswing')">
        <span class="cb-delivery-key">W/2</span>
        <span class="cb-delivery-name">Inswing</span>
      </button>
      <button class="cb-delivery-btn" data-delivery="outswing" onclick="window._cbSelectDelivery('outswing')">
        <span class="cb-delivery-key">E/3</span>
        <span class="cb-delivery-name">Outswing</span>
      </button>
      <button class="cb-delivery-btn" data-delivery="bouncer" onclick="window._cbSelectDelivery('bouncer')">
        <span class="cb-delivery-key">A/4</span>
        <span class="cb-delivery-name">Bouncer</span>
      </button>
      <button class="cb-delivery-btn" data-delivery="yorker" onclick="window._cbSelectDelivery('yorker')">
        <span class="cb-delivery-key">S/5</span>
        <span class="cb-delivery-name">Yorker</span>
      </button>
      <button class="cb-delivery-btn" data-delivery="slower" onclick="window._cbSelectDelivery('slower')">
        <span class="cb-delivery-key">D/6</span>
        <span class="cb-delivery-name">Slower</span>
      </button>
    </div>
    <div class="cb-line-indicators" id="bowlingLineIndicators">
      <button class="cb-line-btn" data-line="off" onclick="window._cbSelectLine('off')">Off</button>
      <button class="cb-line-btn selected" data-line="middle" onclick="window._cbSelectLine('middle')">Mid</button>
      <button class="cb-line-btn" data-line="leg" onclick="window._cbSelectLine('leg')">Leg</button>
    </div>
    <button class="cb-bowl-btn" onclick="window._cbBowlingMeterTap()">
      <span id="bowlBtnLabel">SPACE: Bowl</span>
    </button>
  </div>

  <!-- Bowling Accuracy Meter -->
  <div class="cb-bowling-meter" id="bowlingMeter" style="display:none;">
    <div class="cb-meter-track">
      <div class="cb-meter-zone cb-meter-red-top"></div>
      <div class="cb-meter-zone cb-meter-yellow-top"></div>
      <div class="cb-meter-zone cb-meter-green"></div>
      <div class="cb-meter-zone cb-meter-yellow-bottom"></div>
      <div class="cb-meter-zone cb-meter-red-bottom"></div>
      <div class="cb-meter-indicator" id="bowlingMeterIndicator"></div>
    </div>
  </div>

  <!-- Innings Break Overlay -->
  <div class="cb-overlay" id="inningsBreakOverlay" role="dialog" aria-modal="true" aria-label="Innings break">
    <div class="cb-modal cb-innings-modal" id="inningsBreakModal"></div>
  </div>

  <!-- Match Result Overlay -->
  <div class="cb-overlay" id="matchResultOverlay" role="dialog" aria-modal="true" aria-label="Match result">
    <div class="cb-modal cb-match-result-modal" id="matchResultModal"></div>
  </div>

  <!-- Bowler Intro -->
  <div class="cb-bowler-intro" id="bowlerIntro" aria-live="polite"></div>

  <!-- Achievement Toast -->
  <div class="cb-achievement-toast" id="achievementToast" role="alert"></div>

  <!-- Screen reader announcements -->
  <div id="srAnnounce" class="sr-only" aria-live="polite" aria-atomic="true"></div>
  <div id="srAssertive" class="sr-only" aria-live="assertive" aria-atomic="true"></div>

  <!-- Ball Commentary Overlay -->
  <div id="ballCommentary" class="cb-ball-commentary"></div>

  <!-- Bowling Tap Hint (mobile) -->
  <div class="cb-bowling-tap-hint" id="bowlingTapHint">Tap pitch to bowl &bull; Swipe for swing</div>

  <!-- Gesture Direction Indicator (mobile) -->
  <div id="gestureIndicator" class="cb-gesture-indicator" aria-hidden="true">
    <span class="cb-gesture-arrow"></span>
    <span class="cb-gesture-name"></span>
  </div>

  <!-- Combo Streak Badge -->
  <div id="comboBadge" class="cb-combo-badge" aria-hidden="true"></div>

  <!-- Free Hit Badge -->
  <div id="freeHitBadge" class="cb-freehit-badge" aria-hidden="true">FREE HIT</div>

  <!-- Super Over Overlay -->
  <div class="cb-overlay" id="superOverOverlay" role="dialog" aria-modal="true" aria-label="Super Over">
    <div class="cb-modal cb-super-over-modal" id="superOverModal"></div>
  </div>

  <!-- Pause Overlay -->
  <div class="cb-overlay" id="pauseOverlay" role="dialog" aria-modal="true" aria-label="Game Paused">
    <div class="cb-modal" id="pauseModal">
      <h2>PAUSED</h2>
      <p style="color:var(--cb-text-dim);margin:0 0 16px;">Game paused</p>
      <div class="cb-btn-row" style="flex-direction:column;gap:12px;">
        <button class="cb-btn" onclick="window._cbResume()">▶ RESUME</button>
        <button class="cb-btn" style="background:#555;" onclick="window._cbQuitToMenu()">✕ QUIT TO MENU</button>
      </div>
    </div>
  </div>

  <Fragment slot="scripts">
    <script type="module" src="/games/cricket-blitz/game.js"></script>
  </Fragment>
</GameLayout>
