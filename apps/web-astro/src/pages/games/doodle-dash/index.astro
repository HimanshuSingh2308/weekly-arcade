    <!-- Sabotage vote screen -->
    <div id="ddSabotageVote" style="display:none;flex-direction:column;align-items:center;gap:20px;padding:32px 16px;text-align:center">
      <div style="font-size:3rem;animation:dd-thinking 1.5s ease-in-out infinite">🕵️</div>
      <div class="dd-result-title" id="sabotageVoteTitle">Was the drawer sabotaging?</div>
      <div style="color:#aaa;font-size:0.9rem" id="sabotageVoteWord"></div>
      <div style="display:flex;gap:16px;flex-wrap:wrap;justify-content:center">
        <button class="dd-btn-primary dd-vote-yes" id="btnSabotageYes" style="background:linear-gradient(135deg,#ef4444,#dc2626);box-shadow:0 4px 16px rgba(239,68,68,0.3)">🚨 Saboteur!</button>
        <button class="dd-btn-primary dd-vote-no" id="btnSabotageNo" style="background:linear-gradient(135deg,#22c55e,#16a34a);box-shadow:0 4px 16px rgba(34,197,94,0.3)">✅ Honest</button>
      </div>
      <div style="color:#aaa;font-size:0.85rem" id="sabotageVoteCountdown"></div>
      <div style="color:#666;font-size:0.8rem" id="sabotageVoteStatus"></div>
    </div>

    <!-- Sabotage reveal screen -->
    <div id="ddSabotageReveal" style="display:none;flex-direction:column;align-items:center;gap:16px;padding:32px 16px;text-align:center">
      <div class="dd-sabotage-reveal-icon" id="sabotageRevealIcon"></div>
      <div class="dd-sabotage-reveal-text" id="sabotageRevealText"></div>
      <div style="color:#aaa;font-size:0.9rem" id="sabotageRevealDetail"></div>
      <div class="dd-result-scores" id="sabotageRevealScores"></div>
      <div style="color:#aaa;font-size:0.85rem" id="sabotageRevealCountdown"></div>
    </div>

    <!-- Game over screen -->
    <div id="ddGameOver" style="display:none;flex-direction:column;align-items:center;gap:16px;padding:32px 16px;text-align:center">
      <div class="dd-gameover-title">Game Over!</div>
      <div class="dd-gameover-sub" id="gameoverSub"></div>
      <!-- Podium -->
      <div class="dd-podium-wrap" id="podiumWrap"></div>
      <div class="dd-result-scores" id="gameoverScores"></div>
      <div style="font-size:0.9rem;color:#aaa">XP Earned</div>
      <div class="dd-xp-bar-wrap">
        <div class="dd-xp-bar" id="xpBar" style="width:0%"></div>
      </div>
      <div style="font-size:0.85rem;color:#f5a623" id="xpLabel"></div>
      <div style="display:flex;gap:12px;flex-wrap:wrap;justify-content:center">
        <button class="dd-btn-primary" id="btnPlayAgain">Play Again</button>
        <button class="dd-btn-secondary" id="btnShareScore">📤 Share Score</button>
        <button class="dd-btn-secondary" id="btnBackLobby">Back to Lobby</button>
      </div>
    </div>

    <!-- Loading screen -->
    <div id="ddLoadingScreen" style="display:none">
      <div class="dd-loading-screen">
        <div class="dd-spinner"></div>
        <div id="loadingMsg">Connecting...</div>
        <button class="dd-btn-secondary" id="btnCancelLoading" style="margin-top:16px">Cancel</button>
      </div>
    </div>
  </div>

  <!-- Notifications -->
  <div id="ddNotifs" aria-live="assertive" role="log"></div>

  <Fragment slot="scripts">
    <script is:inline src="https://cdn.socket.io/4.8.1/socket.io.min.js"></script>
    <script is:inline src="/js/multiplayer-client.js"></script>
    <script is:inline src="/js/multiplayer-ui.js"></script>
    <link rel="stylesheet" href="/games/doodle-dash/style.css">
    <script is:inline src="/games/doodle-dash/game.js"></script>
  </Fragment>
</GameLayout>
