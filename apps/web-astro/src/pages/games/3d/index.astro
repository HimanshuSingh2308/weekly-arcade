---
import CategoryPage from '../../../components/CategoryPage.astro';

const games = [
  { slug: 'chess-3d', title: 'Chess 3D', description: '3D chess with smart AI! 4 difficulty levels, ELO rating, rotatable board.', thumbnail: 'chess-3d.svg', alt: 'Chess 3D - free 3D chess game vs AI', tags: [{ label: 'Strategy' }, { label: '3D' }, { label: 'Multiplayer' }], isNew: true },
  { slug: 'cricket-blitz', title: 'Cricket Blitz', description: '3D IPL-style cricket! Bat, bowl, win the match. Toss, powerplay, super over!', thumbnail: 'cricket-blitz.svg', alt: 'Cricket Blitz - free IPL-style 3D cricket game', tags: [{ label: 'Sports' }, { label: '3D' }], isNew: true },
  { slug: 'lumble', title: 'Lumble', description: '3D platformer! Latch, swing, and collect 50 Sparks!', thumbnail: 'lumble.svg', alt: 'Lumble - free 3D platformer browser game', tags: [{ label: '3D' }, { label: 'Platformer' }] },
