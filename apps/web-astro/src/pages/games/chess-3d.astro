---
/**
 * Chess 3D -- 3D Chess vs AI (Babylon.js WebGL).
 *
 * GameLayout handles: meta, SEO, structured data, header, shared modules, fallback, more-games.
 */
import GameLayout from '../../layouts/GameLayout.astro';
import gameData from '../../data/games/chess-3d.json';
---

<GameLayout
  title={gameData.title}
  gameName={gameData.name}
  gameId={gameData.id}
  icon={gameData.icon}
  description={gameData.description}
  keywords={gameData.keywords}
  url={gameData.url}
  themeColor={gameData.themeColor}
  accentColor={gameData.accentColor}
  genres={gameData.genres}
  ratingValue={gameData.ratingValue}
  ratingCount={gameData.ratingCount}
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/games/chess-3d/styles.css">
    <style is:global>
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: #1C1C2E;
        color: #E8DCC8;
        touch-action: manipulation;
        overflow: hidden;
      }
    </style>
  </Fragment>

  <!-- 3D Canvas Container -->
  <div class="chess3d-wrap" id="gameWrap">
    <canvas id="renderCanvas" role="application" aria-label="Chess 3D game board. Use mouse or touch to select and move pieces."></canvas>
  </div>

  <!-- Main Menu Overlay -->
  <div class="chess3d-overlay chess3d-visible" id="mainMenuOverlay" role="dialog" aria-modal="true" aria-label="Chess 3D - Main Menu">
    <div class="chess3d-modal chess3d-menu-modal">
      <div class="chess3d-menu-icon">{gameData.icon}</div>
      <h1 class="chess3d-menu-title">Chess 3D</h1>
      <p class="chess3d-menu-tagline">3D Chess with Smart AI</p>

      <div class="chess3d-elo-display" id="menuEloDisplay">
        <span class="chess3d-elo-badge" id="menuEloBadge"></span>
        <span class="chess3d-elo-value" id="menuEloValue"></span>
      </div>

      <div class="chess3d-menu-stats" id="menuStats"></div>

      <div class="chess3d-difficulty-select" id="difficultySelect" role="group" aria-labelledby="diffLabel">
        <span id="diffLabel" class="chess3d-label">Difficulty</span>
        <div class="chess3d-btn-group" role="radiogroup" aria-label="Select difficulty">
          <button class="chess3d-diff-btn" role="radio" aria-checked="false" data-diff="easy">Easy<span class="chess3d-diff-elo">~600</span></button>
          <button class="chess3d-diff-btn selected" role="radio" aria-checked="true" data-diff="medium">Medium<span class="chess3d-diff-elo">~1100</span></button>
          <button class="chess3d-diff-btn" role="radio" aria-checked="false" data-diff="hard">Hard<span class="chess3d-diff-elo">~1500</span></button>
          <button class="chess3d-diff-btn" role="radio" aria-checked="false" data-diff="expert">Expert<span class="chess3d-diff-elo">~1900</span></button>
        </div>
      </div>

      <div class="chess3d-color-select" id="colorSelect" role="group" aria-labelledby="colorLabel">
        <span id="colorLabel" class="chess3d-label">Play As</span>
        <div class="chess3d-btn-group" role="radiogroup" aria-label="Select color">
          <button class="chess3d-color-btn selected" role="radio" aria-checked="true" data-color="white">White</button>
          <button class="chess3d-color-btn" role="radio" aria-checked="false" data-color="random">Random</button>
          <button class="chess3d-color-btn" role="radio" aria-checked="false" data-color="black">Black</button>
        </div>
      </div>

      <button class="chess3d-btn chess3d-btn-play" id="playAIBtn">Play vs AI</button>

      <button class="chess3d-btn chess3d-btn-disabled" id="playFriendBtn" disabled>
        Play vs Friend <span class="chess3d-coming-soon">Coming Soon</span>
      </button>
    </div>
  </div>

  <!-- Game HUD -->
  <div class="chess3d-hud" id="gameHud" style="display:none;">
    <!-- Top player (opponent) -->
    <div class="chess3d-player-bar chess3d-player-top" id="playerTop">
      <div class="chess3d-player-info">
        <span class="chess3d-player-name" id="topName">AI</span>
        <span class="chess3d-player-elo" id="topElo"></span>
      </div>
      <div class="chess3d-captured" id="topCaptured"></div>
      <div class="chess3d-material-adv" id="topAdvantage"></div>
    </div>

    <!-- Bottom player (you) -->
    <div class="chess3d-player-bar chess3d-player-bottom" id="playerBottom">
      <div class="chess3d-player-info">
        <span class="chess3d-player-name" id="bottomName">You</span>
        <span class="chess3d-player-elo" id="bottomElo"></span>
      </div>
      <div class="chess3d-captured" id="bottomCaptured"></div>
      <div class="chess3d-material-adv" id="bottomAdvantage"></div>
    </div>

    <!-- Turn indicator -->
    <div class="chess3d-turn-indicator" id="turnIndicator">
      <span id="turnText">Your turn</span>
    </div>

    <!-- AI thinking indicator -->
    <div class="chess3d-thinking" id="thinkingIndicator" style="display:none;">
      <div class="chess3d-thinking-dots"><span></span><span></span><span></span></div>
      <span>Thinking...</span>
    </div>

    <!-- Move history panel -->
    <div class="chess3d-move-history" id="moveHistory">
      <div class="chess3d-move-list" id="moveList"></div>
    </div>

    <!-- HUD buttons -->
    <div class="chess3d-hud-buttons">
      <button class="chess3d-hud-btn" id="undoBtn" title="Undo (Z)" aria-label="Undo last move">&#x21A9;</button>
      <button class="chess3d-hud-btn" id="flipBtn" title="Flip board (F)" aria-label="Flip board">&#x21C5;</button>
      <button class="chess3d-hud-btn" id="resetCamBtn" title="Reset camera (R)" aria-label="Reset camera">&#x21BA;</button>
      <button class="chess3d-hud-btn chess3d-hud-btn-danger" id="resignBtn" title="Resign" aria-label="Resign">&#x2691;</button>
    </div>
  </div>

  <!-- Promotion Dialog -->
  <div class="chess3d-overlay" id="promotionOverlay" role="dialog" aria-modal="true" aria-label="Choose promotion piece">
    <div class="chess3d-modal chess3d-promotion-modal">
      <h2>Promote Pawn</h2>
      <div class="chess3d-promotion-choices" id="promotionChoices">
        <button class="chess3d-promo-btn" data-piece="q" aria-label="Queen">&#9813;</button>
        <button class="chess3d-promo-btn" data-piece="r" aria-label="Rook">&#9814;</button>
        <button class="chess3d-promo-btn" data-piece="b" aria-label="Bishop">&#9815;</button>
        <button class="chess3d-promo-btn" data-piece="n" aria-label="Knight">&#9816;</button>
      </div>
    </div>
  </div>

  <!-- Resign Confirm Dialog -->
  <div class="chess3d-overlay" id="resignOverlay" role="dialog" aria-modal="true" aria-label="Confirm resignation">
    <div class="chess3d-modal chess3d-resign-modal">
      <h2>Resign?</h2>
      <p>You will lose this game and it will affect your rating.</p>
      <div class="chess3d-btn-row">
        <button class="chess3d-btn" id="resignConfirmBtn">Resign</button>
        <button class="chess3d-btn chess3d-btn-secondary" id="resignCancelBtn">Cancel</button>
      </div>
    </div>
  </div>

  <!-- Game Over Overlay -->
  <div class="chess3d-overlay" id="gameOverOverlay" role="dialog" aria-modal="true" aria-label="Game over">
    <div class="chess3d-modal chess3d-gameover-modal">
      <h2 id="gameOverTitle">Game Over</h2>
      <p id="gameOverReason" class="chess3d-gameover-reason"></p>
      <div class="chess3d-elo-change" id="gameOverElo"></div>
      <div class="chess3d-gameover-stats" id="gameOverStats"></div>
      <div class="chess3d-btn-row">
        <button class="chess3d-btn chess3d-btn-play" id="rematchBtn">Rematch</button>
        <button class="chess3d-btn chess3d-btn-secondary" id="menuBtn">Menu</button>
      </div>
    </div>
  </div>

  <!-- Multiplayer Lobby Overlay -->
  <div class="chess3d-overlay" id="mpLobbyOverlay" role="dialog" aria-modal="true" aria-label="Multiplayer lobby">
    <div class="chess3d-modal chess3d-menu-modal">
      <h2 style="margin:0 0 8px;">Play vs Friend</h2>
      <p style="color:var(--c3d-text-dim);margin:0 0 20px;">Challenge a friend or find an opponent</p>
      <div id="mpErrorMsg" style="display:none;background:rgba(212,80,74,0.15);border:1px solid var(--c3d-red);color:var(--c3d-red);border-radius:8px;padding:10px 14px;margin-bottom:14px;font-size:0.85rem;"></div>
      <button class="chess3d-btn chess3d-btn-play" id="mpQuickMatchBtn">Quick Match</button>
      <button class="chess3d-btn" id="mpCreatePrivateBtn" style="margin-top:10px;">Create Private Game</button>
      <button class="chess3d-btn" id="mpJoinCodeBtn" style="margin-top:10px;">Join by Code</button>
      <button class="chess3d-btn chess3d-btn-secondary" id="mpBackBtn" style="margin-top:16px;">Back</button>
    </div>
  </div>

  <!-- Multiplayer Waiting Room Overlay -->
  <div class="chess3d-overlay" id="mpWaitingOverlay" role="dialog" aria-modal="true" aria-label="Waiting for opponent">
    <div class="chess3d-modal chess3d-menu-modal">
      <h2 style="margin:0 0 8px;">Waiting for Opponent</h2>
      <div class="chess3d-thinking" style="display:flex;margin:16px 0;">
        <div class="chess3d-thinking-dots"><span></span><span></span><span></span></div>
        <span>Looking for a challenger...</span>
      </div>

      <div style="margin:16px 0;text-align:center;">
        <p style="color:var(--c3d-text-dim);margin:0 0 8px;font-size:0.85rem;">Share this code with a friend:</p>
        <div style="font-size:2rem;font-weight:900;letter-spacing:0.2em;color:var(--c3d-gold);" id="mpJoinCode">------</div>
        <div style="display:flex;gap:8px;justify-content:center;margin-top:12px;">
          <button class="chess3d-btn" id="mpCopyCodeBtn" style="font-size:0.85rem;flex:1;">Copy Code</button>
          <button class="chess3d-btn" id="mpShareLinkBtn" style="font-size:0.85rem;flex:1;">Share Link</button>
        </div>
      </div>

      <div style="margin:12px 0;text-align:center;">
        <p style="color:var(--c3d-text-dim);margin:0 0 4px;font-size:0.75rem;">Or send this link:</p>
        <p id="mpInviteLink" style="font-size:0.7rem;color:var(--c3d-gold);word-break:break-all;margin:0;opacity:0.7;"></p>
      </div>

      <button class="chess3d-btn chess3d-btn-secondary" id="mpWaitingCancelBtn">Cancel</button>
    </div>
  </div>

  <!-- Screen reader announcements -->
  <div id="srAnnounce" class="sr-only" aria-live="polite" aria-atomic="true"></div>

  <Fragment slot="scripts">
    <script is:inline src="https://cdn.babylonjs.com/babylon.js"></script>
    <script is:inline src="https://cdn.socket.io/4.7.5/socket.io.min.js"></script>
    <script is:inline src="/js/multiplayer-client.js"></script>
    <script is:inline src="/js/multiplayer-ui.js"></script>
    <script is:inline src="/games/chess-3d/game.js"></script>
  </Fragment>
</GameLayout>
