---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';

// Dynamically load all game data JSON files — auto-updates when games are added
const gameModules = import.meta.glob('../../data/games/*.json', { eager: true });
const games = Object.values(gameModules).map((mod: any) => mod.default || mod) as Array<{ id: string; name: string; icon: string }>;
const gameCount = games.length;
---

<BaseLayout title="About | Weekly Arcade">
  <Fragment slot="head">
    <link rel="preconnect" href="https://www.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://firestore.googleapis.com" crossorigin>
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#e94560">
    <link rel="apple-touch-icon" href="/icons/icon-180.png">
  </Fragment>

  <SiteHeader showAuth={false} activePage="about" />

  <section class="hero">
    <h1>About <span class="highlight">Weekly Arcade</span></h1>
    <p>Free browser games, new releases every week. No downloads, no paywalls, just play.</p>
  </section>

  <main class="container">
    <div class="stats-banner">
      <div class="stat">
        <div class="stat-value">{gameCount}</div>
        <div class="stat-label">Games</div>
      </div>
      <div class="stat">
        <div class="stat-value">100%</div>
        <div class="stat-label">Free</div>
      </div>
      <div class="stat">
        <div class="stat-value">Weekly</div>
        <div class="stat-label">New Releases</div>
      </div>
      <div class="stat">
        <div class="stat-value">0</div>
        <div class="stat-label">Downloads Needed</div>
      </div>
    </div>

    <div class="content-card">
      <h2><span class="icon">🎯</span> Our Mission</h2>
      <p>Weekly Arcade is dedicated to bringing you high-quality browser games that you can play instantly &mdash; no downloads, no installations, no hassle.</p>
      <p>We believe gaming should be accessible to everyone. All our games are free to play, with optional cosmetics and customizations for those who want to personalize their experience.</p>
    </div>

    <div class="content-card">
      <h2><span class="icon">🕹️</span> Our Games</h2>
      <p>From classic arcade games to modern puzzles, we've got something for everyone:</p>
      <div class="games-grid">
        {games.map((game) => (
          <a href={`/games/${game.id}/`} class="game-card">
            <div class="game-icon">{game.icon}</div>
            <div class="game-name">{game.name}</div>
          </a>
        ))}
      </div>
    </div>

    <div class="content-card">
      <h2><span class="icon">✨</span> Features</h2>
      <div class="features-grid">
        <div class="feature"><div class="feature-icon">🎮</div><div class="feature-title">Free to Play</div><div class="feature-desc">All games, no paywalls</div></div>
        <div class="feature"><div class="feature-icon">📱</div><div class="feature-title">Play Anywhere</div><div class="feature-desc">Desktop, tablet, or mobile</div></div>
        <div class="feature"><div class="feature-icon">🏆</div><div class="feature-title">Leaderboards</div><div class="feature-desc">Compete worldwide</div></div>
        <div class="feature"><div class="feature-icon">💾</div><div class="feature-title">Cloud Saves</div><div class="feature-desc">Progress synced everywhere</div></div>
        <div class="feature"><div class="feature-icon">🎖️</div><div class="feature-title">Achievements</div><div class="feature-desc">Unlock badges and rewards</div></div>
        <div class="feature"><div class="feature-icon">🔄</div><div class="feature-title">Weekly Updates</div><div class="feature-desc">New games regularly</div></div>
      </div>
    </div>

    <div class="content-card">
      <h2><span class="icon">🤝</span> Join the Community</h2>
      <p>Create a free account to save your progress across all devices, compete on global leaderboards, unlock achievements, and customize your gaming experience.</p>
      <p>Don't want to sign up? No problem &mdash; you can still play all games as a guest.</p>
    </div>

    <div class="content-card">
      <h2><span class="icon">📬</span> Contact Us</h2>
      <p>Have feedback, suggestions, or found a bug? We'd love to hear from you!</p>
      <p><strong>Email:</strong> hello@weeklyarcade.games</p>
    </div>

    <div class="cta">
      <a href="/" class="cta-btn">Start Playing Now →</a>
    </div>
  </main>

  <footer class="footer">
    <p><strong>Weekly Arcade</strong> &mdash; New free browser games every week.</p>
    <p style="margin-top: 0.5rem;">
      <a href="/">Games</a> &nbsp;|&nbsp; <a href="/leaderboard/">Leaderboards</a> &nbsp;|&nbsp; <a href="/privacy/">Privacy</a> &nbsp;|&nbsp; <a href="/terms/">Terms</a>
    </p>
    <p style="margin-top: 0.5rem; font-size: 0.75rem;">&copy; 2026 Weekly Arcade. All rights reserved.</p>
  </footer>



  <script is:inline src="/js/api-client.js"></script>
  <script is:inline src="/js/auth.js"></script>
  <script is:inline>
    function toggleMobileMenu() {
      const nav = document.getElementById('mobileNav');
      const btn = document.getElementById('mobileMenuBtn');
      nav.classList.toggle('open');
      btn.textContent = nav.classList.contains('open') ? '\u2715' : '☰';
    }

    function toggleUserMenu() {
      document.getElementById('userMenu').classList.toggle('open');
    }

    function handleSignOut(e) {
      e.preventDefault();
      e.stopPropagation();
      window.authManager.signOut();
      document.getElementById('userMenu').classList.remove('open');
    }

    function updateAuthUI(user) {
      const signInBtn = document.getElementById('signInBtn');
      const userMenu = document.getElementById('userMenu');
      const userAvatar = document.getElementById('userAvatar');
      const userName = document.getElementById('userName');
      if (user) {
        if (signInBtn) signInBtn.style.display = 'none';
        if (userMenu) userMenu.classList.add('signed-in');
        if (userAvatar) userAvatar.src = user.photoURL || '';
        if (userName) userName.textContent = user.displayName || 'Player';
      } else {
        if (signInBtn) signInBtn.style.display = 'block';
        if (userMenu) userMenu.classList.remove('signed-in');
      }
    }

    document.addEventListener('click', (e) => {
      const userMenu = document.getElementById('userMenu');
      if (userMenu && !userMenu.contains(e.target)) userMenu.classList.remove('open');
    });

    const checkAuth = setInterval(() => {
      if (window.authManager?.isInitialized) {
        clearInterval(checkAuth);
        window.authManager.onAuthStateChanged(updateAuthUI);
      }
    }, 100);
  </script>

</BaseLayout>

<style is:global>

    :root {
      --bg-primary: #0a0a12;
      --bg-secondary: #12121f;
      --bg-card: rgba(22, 33, 62, 0.6);
      --bg-card-solid: #16213e;
      --accent: #e94560;
      --accent-hover: #ff6b6b;
      --accent-glow: rgba(233, 69, 96, 0.3);
      --purple: #7c3aed;
      --text-primary: #f0f0f5;
      --text-secondary: #8888a8;
      --border: rgba(255, 255, 255, 0.06);
      --glass: rgba(255, 255, 255, 0.03);
      --gold: #ffd700;
      --radius: 16px;
      --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: var(--bg-primary);
      color: var(--text-primary);
      min-height: 100vh;
      line-height: 1.6;
      background-image: radial-gradient(rgba(255,255,255,0.03) 1px, transparent 1px);
      background-size: 32px 32px;
    }

    /* ─── Header ─── */
    .header {
      background: rgba(18, 18, 31, 0.8);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
      padding: 0.8rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 50;
    }

    .logo {
      font-size: 1.4rem;
      font-weight: 800;
      color: var(--text-primary);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      letter-spacing: -0.02em;
    }

    .logo-icon { font-size: 1.6rem; }

    .logo span.brand {
      background: linear-gradient(135deg, var(--accent), var(--purple));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .nav { display: flex; gap: 0.25rem; }

    .nav a {
      color: var(--text-secondary);
      text-decoration: none;
      font-weight: 500;
      font-size: 0.9rem;
      padding: 0.5rem 1rem;
      border-radius: 10px;
      transition: color var(--transition), background var(--transition);
    }

    .nav a:hover { color: var(--text-primary); background: var(--glass); }
    .nav a.active { color: var(--accent); background: rgba(233, 69, 96, 0.08); }

    .mobile-menu-btn {
      display: none;
      background: none;
      border: 1px solid var(--border);
      color: var(--text-primary);
      font-size: 1.2rem;
      padding: 0.4rem 0.6rem;
      border-radius: 8px;
      cursor: pointer;
      line-height: 1;
    }

    /* ─── Hero ─── */
    .hero {
      position: relative;
      text-align: center;
      padding: 4rem 2rem 3rem;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 70% 60% at 50% 0%, rgba(233, 69, 96, 0.1) 0%, transparent 60%),
        radial-gradient(ellipse 50% 40% at 80% 10%, rgba(124, 58, 237, 0.06) 0%, transparent 50%);
      pointer-events: none;
    }

    .hero h1 {
      font-size: 2.5rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      margin-bottom: 0.75rem;
      position: relative;
    }

    .hero h1 .highlight {
      background: linear-gradient(135deg, var(--accent), var(--purple));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero p {
      color: var(--text-secondary);
      font-size: 1.1rem;
      max-width: 500px;
      margin: 0 auto;
      position: relative;
    }

    /* ─── Container ─── */
    .container {
      max-width: 800px;
      margin: 0 auto;
      padding: 0 2rem 3rem;
    }

    /* ─── Content Cards ─── */
    .content-card {
      background: var(--bg-card);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 2rem;
      margin-bottom: 1.25rem;
      transition: border-color var(--transition);
    }

    .content-card:hover {
      border-color: rgba(255, 255, 255, 0.1);
    }

    .content-card h2 {
      font-size: 1.25rem;
      font-weight: 700;
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      letter-spacing: -0.01em;
    }

    .content-card h2 .icon { font-size: 1.3rem; }

    .content-card p {
      margin-bottom: 1rem;
      color: var(--text-secondary);
      line-height: 1.7;
    }

    .content-card p:last-child { margin-bottom: 0; }

    .content-card ul {
      margin-left: 1.5rem;
      margin-bottom: 1rem;
      color: var(--text-secondary);
    }

    .content-card li { margin-bottom: 0.5rem; }

    .content-card a { color: var(--accent); text-decoration: none; }
    .content-card a:hover { text-decoration: underline; }
    .content-card strong { color: var(--text-primary); }

    /* ─── Stats Banner ─── */
    .stats-banner {
      display: flex;
      justify-content: center;
      gap: 2rem;
      padding: 1.5rem 2rem;
      background: var(--glass);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid var(--border);
      border-radius: 14px;
      margin-bottom: 2rem;
    }

    .stat { text-align: center; }

    .stat-value {
      font-size: 2.2rem;
      font-weight: 800;
      background: linear-gradient(135deg, var(--gold), #ffaa00);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .stat-label {
      font-size: 0.8rem;
      color: var(--text-secondary);
      font-weight: 500;
    }

    /* ─── Games Grid ─── */
    .games-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
      gap: 0.75rem;
      margin-top: 1rem;
    }

    .game-card {
      background: var(--glass);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1rem 0.75rem;
      text-align: center;
      text-decoration: none;
      color: var(--text-primary);
      transition: all var(--transition);
    }

    .game-card:hover {
      border-color: rgba(233, 69, 96, 0.2);
      transform: translateY(-3px);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
      text-decoration: none;
    }

    .game-card .game-icon { font-size: 1.8rem; margin-bottom: 0.4rem; }
    .game-card .game-name { font-weight: 600; font-size: 0.82rem; }

    /* ─── Features Grid ─── */
    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 0.75rem;
      margin-top: 1rem;
    }

    .feature {
      background: var(--glass);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.25rem 1rem;
      text-align: center;
      transition: border-color var(--transition);
    }

    .feature:hover { border-color: rgba(255, 255, 255, 0.1); }
    .feature-icon { font-size: 1.8rem; margin-bottom: 0.4rem; }
    .feature-title { font-weight: 700; font-size: 0.9rem; margin-bottom: 0.2rem; }
    .feature-desc { font-size: 0.8rem; color: var(--text-secondary); }

    /* ─── CTA ─── */
    .cta {
      text-align: center;
      padding: 2.5rem 0 1rem;
    }

    .cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: linear-gradient(135deg, var(--accent), #c73e54);
      color: white;
      padding: 1rem 2.5rem;
      border-radius: 14px;
      font-size: 1.05rem;
      font-weight: 700;
      text-decoration: none;
      transition: transform var(--transition), box-shadow var(--transition);
    }

    .cta-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 30px rgba(233, 69, 96, 0.35);
      text-decoration: none;
    }

    /* ─── Footer ─── */
    .footer {
      text-align: center;
      padding: 2rem;
      color: var(--text-secondary);
      font-size: 0.82rem;
      border-top: 1px solid var(--border);
      background: linear-gradient(180deg, transparent, rgba(18, 18, 31, 0.5));
    }

    .footer a { color: var(--accent); text-decoration: none; }

    /* ─── Responsive ─── */
    @media (max-width: 768px) {
      .header { padding: 0.7rem 1rem; }

      .mobile-menu-btn { display: block; order: -1; }
      .logo { order: 0; flex: 1; }

      .nav {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: rgba(18, 18, 31, 0.95);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        flex-direction: column;
        padding: 0.5rem;
        border-bottom: 1px solid var(--border);
        box-shadow: 0 8px 30px rgba(0,0,0,0.4);
        z-index: 49;
      }

      .nav.open { display: flex; }
      .nav a { padding: 0.8rem 1rem; border-radius: 8px; }

      .hero { padding: 2.5rem 1.25rem 2rem; }
      .hero h1 { font-size: 1.8rem; }
      .container { padding: 0 1.25rem 2rem; }
      .content-card { padding: 1.5rem; }

      .stats-banner {
        flex-wrap: wrap;
        gap: 1rem 1.5rem;
        padding: 1rem;
      }

      .stat-value { font-size: 1.8rem; }
    }

    @media (max-width: 480px) {
      .hero h1 { font-size: 1.5rem; }
      .features-grid { grid-template-columns: repeat(2, 1fr); }
      .games-grid { grid-template-columns: repeat(3, 1fr); }
    }

</style>
