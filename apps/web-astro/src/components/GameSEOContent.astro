---
/**
 * GameSEOContent — renders about, tips, how-to-play, FAQ, and "similar to" content
 * below the game for SEO depth. Emits HowTo + FAQPage JSON-LD schemas.
 * Only renders sections where data is provided.
 */
interface FaqItem {
  q: string;
  a: string;
}

interface Props {
  gameName: string;
  gameId: string;
  tips?: string[];
  howToPlay?: string;
  similarTo?: string[];
  aboutGame?: string;
  faq?: FaqItem[];
}

const { gameName, gameId, tips, howToPlay, similarTo, aboutGame, faq } = Astro.props;

const hasContent = tips?.length || howToPlay || similarTo?.length || aboutGame || faq?.length;

// HowTo schema for featured snippets
const howToSchema = (howToPlay && tips?.length) ? JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: `How to Play ${gameName}`,
  description: howToPlay,
  totalTime: 'PT2M',
  step: tips.map((tip, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    text: tip,
  })),
}) : null;

// FAQPage schema for FAQ featured snippets
const faqSchema = faq?.length ? JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
}) : null;
---

{howToSchema && (
  <script type="application/ld+json" set:html={howToSchema} />
)}

{faqSchema && (
  <script type="application/ld+json" set:html={faqSchema} />
)}

{hasContent && (
  <section class="game-seo-content">
    {aboutGame && (
      <div class="seo-block">
        <h2>About {gameName}</h2>
        <p>{aboutGame}</p>
      </div>
    )}

    {howToPlay && (
      <div class="seo-block">
        <h2>How to Play {gameName}</h2>
        <p>{howToPlay}</p>
      </div>
    )}

    {tips?.length && (
      <div class="seo-block">
        <h2>{gameName} Tips and Strategy</h2>
        <ol class="tips-list">
          {tips.map((tip) => <li>{tip}</li>)}
        </ol>
      </div>
    )}

    {faq?.length && (
      <div class="seo-block">
        <h2>{gameName} FAQ</h2>
        {faq.map((item) => (
          <div class="faq-item">
            <h3>{item.q}</h3>
            <p>{item.a}</p>
          </div>
        ))}
      </div>
    )}

    {similarTo?.length && (
      <div class="seo-block">
        <h2>Games Like {gameName}</h2>
        <p>If you enjoy {gameName}, you might also like: {similarTo.map((name, i) => {
          const slug = name.toLowerCase().replace(/\s+/g, '-');
          const isInternal = ['wordle', '2048', 'snake', 'memory-match', 'solitaire-roguelite', 'fieldstone', 'coin-cascade', 'stack-tower', 'tiny-tycoon', 'voidbreak', 'lumble', 'chaos-kitchen', 'chess-3d', 'cricket-blitz', 'drift-legends', 'chroma-sort'].includes(slug);
          return isInternal
            ? <><a href={`/games/${slug}/`}>{name}</a>{i < similarTo.length - 1 ? ', ' : ''}</>
            : <>{name}{i < similarTo.length - 1 ? ', ' : ''}</>;
        })}. {gameName} is available free on Weekly Arcade — <a href="/games/">browse all games</a>.</p>
      </div>
    )}
  </section>
)}

<style>
  .game-seo-content {
    background: var(--bg-secondary, #12121f);
    border-top: 1px solid var(--border, rgba(255,255,255,0.06));
    padding: 1.5rem 2rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .seo-block {
    margin-bottom: 1.5rem;
  }

  .seo-block:last-child {
    margin-bottom: 0;
  }

  .seo-block h2 {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-primary, #f0f0f5);
    margin-bottom: 0.5rem;
  }

  .seo-block h3 {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-primary, #f0f0f5);
    margin-bottom: 0.3rem;
  }

  .seo-block p {
    font-size: 0.85rem;
    color: var(--text-secondary, #8888a8);
    line-height: 1.65;
    margin-bottom: 0.75rem;
  }

  .seo-block p:last-child {
    margin-bottom: 0;
  }

  .seo-block a {
    color: var(--accent, #e94560);
    text-decoration: none;
  }

  .seo-block a:hover {
    text-decoration: underline;
  }

  .tips-list {
    padding-left: 1.25rem;
    margin: 0;
  }

  .tips-list li {
    font-size: 0.85rem;
    color: var(--text-secondary, #8888a8);
    line-height: 1.6;
    margin-bottom: 0.4rem;
  }

  .faq-item {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border, rgba(255,255,255,0.06));
  }

  .faq-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  @media (max-width: 768px) {
    .game-seo-content {
      padding: 1.25rem 1rem;
    }
  }
</style>
