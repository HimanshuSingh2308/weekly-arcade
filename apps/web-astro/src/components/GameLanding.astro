---
/**
 * GameLanding — optional landing/marketing section shown above the game.
 *
 * Shows a hero with game name, description, features, and a prominent
 * "Play Now" CTA. The CTA hides the landing and reveals the game.
 *
 * The CTA must always be visible in the first fold regardless of screen size.
 */
interface Props {
  gameName: string;
  icon?: string;
  tagline: string;
  description: string;
  themeColor: string;
  features?: { icon: string; title: string; desc: string }[];
  howToPlay?: string;
  screenshotSrc?: string;
  screenshots?: string[];
}

const { gameName, icon, tagline, description, themeColor, features, howToPlay, screenshotSrc, screenshots } = Astro.props;
---

<section class="gl-landing" id="gameLanding">
  <div class="gl-container">
    <!-- First fold: Hero + Carousel + CTA (always visible) -->
    <div class="gl-first-fold">
      <div class="gl-hero">
        {icon && <div class="gl-icon">{icon}</div>}
        <h2 class="gl-title">{gameName}</h2>
        <p class="gl-tagline">{tagline}</p>
      </div>

      <!-- Screenshot carousel -->
      {screenshots && screenshots.length > 0 && (
        <div class="gl-carousel" id="glCarousel">
          <div class="gl-carousel-track" id="glCarouselTrack">
            {screenshots.map((src, i) => (
              <div class="gl-carousel-slide">
                <img src={src} alt={`${gameName} screenshot ${i + 1}`} width="320" height="560" loading={i === 0 ? 'eager' : 'lazy'} />
              </div>
            ))}
          </div>
          <div class="gl-carousel-dots" id="glCarouselDots">
            {screenshots.map((_, i) => (
              <button class={`gl-dot ${i === 0 ? 'active' : ''}`} data-slide={i} type="button" aria-label={`Slide ${i + 1}`} />
            ))}
          </div>
        </div>
      )}

      <!-- CTA — always in first fold -->
      <button class="gl-cta" id="glPlayBtn" type="button" aria-label={`Play ${gameName}`}>
        <svg class="gl-cta-icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
        Play Now
      </button>
      <div class="gl-free-badge">Free · No Ads · No Download</div>
    </div>

    <!-- Below fold: Features, screenshot, how-to-play (scrollable extras) -->
    <div class="gl-extras">
      <!-- Features (if provided) -->
      {features && features.length > 0 && (
        <div class="gl-features">
          {features.map((f) => (
            <div class="gl-feature">
              <span class="gl-feature-icon">{f.icon}</span>
              <div class="gl-feature-text">
                <div class="gl-feature-title">{f.title}</div>
                <div class="gl-feature-desc">{f.desc}</div>
              </div>
            </div>
          ))}
        </div>
      )}

      <!-- Screenshot slot (optional) -->
      {screenshotSrc && (
        <div class="gl-screenshot">
          <img src={screenshotSrc} alt={`${gameName} gameplay screenshot`} width="400" height="250" />
        </div>
      )}

      <!-- How to Play (if provided) -->
      {howToPlay && (
        <div class="gl-how">
          <div class="gl-how-label">How to Play</div>
          <p class="gl-how-text">{howToPlay}</p>
        </div>
      )}
    </div>
  </div>
</section>

<script is:inline>
(function() {
  // Mark that this page has a landing section
  document.body.classList.add('gl-has-landing');

  // If user has played before, skip landing and go straight to game
  var played = localStorage.getItem('gl_played_' + document.body.dataset.gameId);
  if (played) {
    var landing = document.getElementById('gameLanding');
    if (landing) landing.style.display = 'none';
    document.body.classList.add('gl-playing');
  }

  var btn = document.getElementById('glPlayBtn');
  if (btn) {
    btn.addEventListener('click', function() {
      var landing = document.getElementById('gameLanding');
      if (landing) {
        landing.style.opacity = '0';
        landing.style.transform = 'translateY(-20px)';
        setTimeout(function() {
          landing.style.display = 'none';
          document.body.classList.add('gl-playing');
        }, 200);
      }
      var gameId = document.body.dataset.gameId || '';
      if (gameId) localStorage.setItem('gl_played_' + gameId, '1');
    });
  }

  // Carousel: auto-advance + swipe + dots
  var track = document.getElementById('glCarouselTrack');
  var dotsEl = document.getElementById('glCarouselDots');
  if (track && dotsEl) {
    var dots = dotsEl.querySelectorAll('.gl-dot');
    var slideCount = dots.length;
    var current = 0;
    var startX = 0;

    function goTo(idx) {
      current = ((idx % slideCount) + slideCount) % slideCount;
      track.style.transform = 'translateX(-' + (current * 100) + '%)';
      dots.forEach(function(d, i) { d.classList.toggle('active', i === current); });
    }

    // Dot clicks
    dots.forEach(function(d) {
      d.addEventListener('click', function() { goTo(parseInt(d.dataset.slide)); });
    });

    // Auto-advance every 3s
    var timer = setInterval(function() { goTo(current + 1); }, 3000);

    // Swipe
    track.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; clearInterval(timer); }, { passive: true });
    track.addEventListener('touchend', function(e) {
      var diff = e.changedTouches[0].clientX - startX;
      if (Math.abs(diff) > 40) goTo(current + (diff < 0 ? 1 : -1));
      timer = setInterval(function() { goTo(current + 1); }, 3000);
    }, { passive: true });
  }
})();
</script>

<style is:global>
  /* GameLanding: hide game + SEO when landing is visible (pure CSS, no JS dependency).
     Uses adjacent sibling: #gameLanding is followed by [data-nosnippet] in DOM.
     When #gameLanding is display:none (gl-playing), these rules don't match. */
  #gameLanding ~ [data-nosnippet] {
    display: none !important;
  }
  #gameLanding ~ .game-seo-content {
    display: none !important;
  }
  #gameLanding ~ .more-games {
    display: none !important;
  }

  /* When playing (landing hidden), restore game content */
  body.gl-playing [data-nosnippet] {
    display: block !important;
  }
  body.gl-playing .game-seo-content {
    display: block !important;
  }
  body.gl-playing .more-games {
    display: block !important;
  }

  /* Allow scrolling when landing is visible */
  body:has(#gameLanding:not([style*="display: none"])) {
    overflow: auto !important;
    overflow-x: hidden !important;
    touch-action: auto !important;
  }
</style>

<style define:vars={{ themeColor }}>
  .gl-landing {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 16px;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .gl-container {
    max-width: 480px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* First fold: always fits in viewport */
  .gl-first-fold {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    min-height: calc(100dvh - 62px);
    padding: 12px 0;
  }

  /* Below-fold extras (scrollable) */
  .gl-extras {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    padding: 24px 0 40px;
    width: 100%;
  }

  /* Hero */
  .gl-hero {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .gl-icon {
    font-size: 56px;
    line-height: 1;
    filter: drop-shadow(0 4px 16px color-mix(in srgb, var(--themeColor) 30%, transparent));
  }

  .gl-title {
    font-size: 32px;
    font-weight: 900;
    color: #fff;
    margin: 0;
    letter-spacing: -0.5px;
  }

  .gl-tagline {
    font-size: 15px;
    color: rgba(255,255,255,0.75);
    margin: 0;
    max-width: 340px;
    line-height: 1.5;
    text-align: center;
  }

  /* Carousel */
  .gl-carousel {
    width: 100%;
    max-width: 280px;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 16px;
    border: 1px solid rgba(255,255,255,0.12);
    position: relative;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }

  @media (min-width: 768px) {
    .gl-carousel {
      max-width: 340px;
    }
  }

  .gl-carousel-track {
    display: flex;
    height: 100%;
    transition: transform 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
    will-change: transform;
  }

  .gl-carousel-slide {
    min-width: 100%;
    flex-shrink: 0;
    height: 100%;
  }

  .gl-carousel-slide img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: top;
  }

  .gl-carousel-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    padding: 10px 0;
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(0,0,0,0.5));
  }

  .gl-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: rgba(255,255,255,0.35);
    cursor: pointer;
    padding: 0;
    transition: background 0.2s, transform 0.2s;
  }

  .gl-dot.active {
    background: #fff;
    transform: scale(1.3);
  }

  /* Features */
  .gl-features {
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: 100%;
  }

  .gl-feature {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
  }

  .gl-feature-icon {
    font-size: 24px;
    flex-shrink: 0;
  }

  .gl-feature-text {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .gl-feature-title {
    font-size: 14px;
    font-weight: 700;
    color: #fff;
  }

  .gl-feature-desc {
    font-size: 12px;
    color: rgba(255,255,255,0.65); /* 3.5:1+ contrast */
  }

  /* Screenshot */
  .gl-screenshot {
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .gl-screenshot img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* How to play */
  .gl-how {
    width: 100%;
    text-align: center;
  }

  .gl-how-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: rgba(255,255,255,0.6); /* 3:1+ contrast */
    margin-bottom: 8px;
  }

  .gl-how-text {
    font-size: 14px;
    color: rgba(255,255,255,0.7);
    line-height: 1.6;
    margin: 0;
  }

  /* CTA Button — always visible in first fold */
  .gl-cta {
    width: 100%;
    max-width: 320px;
    padding: 16px 24px;
    font-size: 18px;
    font-weight: 800;
    color: #fff;
    background: var(--themeColor);
    border: none;
    border-radius: 14px;
    cursor: pointer;
    letter-spacing: 0.5px;
    box-shadow: 0 4px 20px color-mix(in srgb, var(--themeColor) 40%, transparent);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }

  .gl-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 28px color-mix(in srgb, var(--themeColor) 50%, transparent);
  }

  .gl-cta:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 3px;
  }

  .gl-cta:active {
    transform: scale(0.97);
  }

  .gl-cta-icon {
    display: inline-block;
    vertical-align: -2px;
    margin-right: 4px;
  }

  .gl-free-badge {
    font-size: 12px;
    color: rgba(255,255,255,0.55); /* 3:1+ contrast */
    letter-spacing: 0.5px;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .gl-cta { transition: none; }
    .gl-cta:hover { transform: none; }
    .gl-cta:active { transform: none; }
    .gl-landing { transition: none; }
  }

  /* When playing, hide landing and allow game to use full viewport */
  :global(body.gl-playing) .gl-landing {
    display: none !important;
  }

  /* Hide/show rules are in the separate is:global style block above */

  /* Small screens — tighten first fold spacing */
  @media (max-height: 600px) {
    .gl-first-fold {
      gap: 16px;
      padding: 12px 0;
    }
    .gl-icon { font-size: 40px; }
    .gl-title { font-size: 26px; }
    .gl-cta {
      padding: 14px 20px;
      font-size: 16px;
    }
  }

  @media (max-height: 480px) {
    .gl-first-fold { gap: 12px; }
    .gl-desc { font-size: 13px; }
    .gl-icon { font-size: 32px; }
    .gl-title { font-size: 22px; }
  }
</style>
