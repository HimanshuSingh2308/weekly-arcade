---
/**
 * BaseLayout — shared HTML shell for all pages.
 * Handles: charset, viewport, base styles, reduced motion.
 */
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover"
    />
    <title>{title}</title>

    <!-- Preload Firebase modular SDK (ESM) — start download before auth.js runs -->
    <link rel="modulepreload" href="https://www.gstatic.com/firebasejs/10.14.1/firebase-app.js">
    <link rel="modulepreload" href="https://www.gstatic.com/firebasejs/10.14.1/firebase-auth.js">

    <!-- Google Analytics 4 + Google Ads -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-YCS3JQN8ZH"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-YCS3JQN8ZH');
      gtag('config', 'AW-11149451572');
    </script>

    <slot name="head" />
  </head>
  <body>
    <!-- Native bridge for Capacitor (no-op on web) -->
    <script is:inline src="/js/native-bridge.js"></script>

    <!-- App loading overlay (shows on first native launch) -->
    <div id="appLoadingOverlay" style="display:none;position:fixed;inset:0;z-index:9999;background:#0f0f1a;flex-direction:column;align-items:center;justify-content:center;gap:16px;">
      <div style="position:relative;width:60px;height:180px;">
        <div style="position:absolute;bottom:0;left:0;width:60px;height:160px;border:2px solid rgba(255,255,255,0.12);border-top:none;border-radius:0 0 28px 28px;background:rgba(255,255,255,0.03);"></div>
        <div class="lb" style="bottom:8px;background:radial-gradient(circle at 35% 35%,#a78bfa,#7c3aed);animation-delay:0.2s"></div>
        <div class="lb" style="bottom:48px;background:radial-gradient(circle at 35% 35%,#60a5fa,#2563eb);animation-delay:0.6s"></div>
        <div class="lb" style="bottom:88px;background:radial-gradient(circle at 35% 35%,#34d399,#059669);animation-delay:1.0s"></div>
        <div class="lb" style="bottom:128px;background:radial-gradient(circle at 35% 35%,#fbbf24,#d97706);animation-delay:1.4s"></div>
      </div>
      <div style="font-size:36px;">🎮</div>
      <div style="font-size:22px;font-weight:900;color:#fff;font-family:system-ui;">Weekly Arcade</div>
      <div style="width:160px;height:3px;background:rgba(255,255,255,0.1);border-radius:2px;overflow:hidden;">
        <div style="height:100%;width:0%;background:linear-gradient(90deg,#8B5CF6,#F7B731);border-radius:2px;animation:lfill 2.5s ease-out forwards;"></div>
      </div>
      <div id="loadStatus" style="font-size:10px;color:rgba(255,255,255,0.4);">Loading games...</div>
    </div>
    <style is:inline>
      .lb{position:absolute;left:10px;width:40px;height:40px;border-radius:50%;opacity:0;animation:ldrop 0.4s ease-in forwards}
      @keyframes ldrop{0%{opacity:1;transform:translateY(-100px)}60%{transform:translateY(6px)}80%{transform:translateY(-3px)}100%{opacity:1;transform:translateY(0)}}
      @keyframes lfill{0%{width:0}30%{width:40%}60%{width:70%}90%{width:92%}100%{width:100%}}
    </style>
    <script is:inline>
      (function(){
        if(!window.Capacitor||!window.Capacitor.isNativePlatform||!window.Capacitor.isNativePlatform())return;
        var o=document.getElementById('appLoadingOverlay');
        if(!o)return;
        o.style.display='flex';
        var msgs=['Loading games...','Preparing puzzles...','Setting up leaderboards...','Ready!'];
        var s=document.getElementById('loadStatus'),i=0;
        var t=setInterval(function(){i++;if(i<msgs.length&&s)s.textContent=msgs[i];else clearInterval(t);},600);
        window.addEventListener('load',function(){
          setTimeout(function(){
            o.style.transition='opacity 0.4s';o.style.opacity='0';
            setTimeout(function(){o.remove();},500);
          },Math.max(0,2500-performance.now()));
        });
      })();
    </script>

    <slot />
  </body>
</html>

<style is:global>
  /* ── Reset (shared across ALL pages) ── */
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html,
  body {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  html::-webkit-scrollbar,
  body::-webkit-scrollbar {
    display: none;
  }

  /* ── Accessibility: Respect reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
