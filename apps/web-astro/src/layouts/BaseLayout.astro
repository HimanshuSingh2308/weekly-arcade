---
/**
 * BaseLayout — shared HTML shell for all pages.
 * Handles: charset, viewport, base styles, reduced motion.
 */
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover"
    />
    <title>{title}</title>

    <!-- Preload Firebase modular SDK (ESM) — start download before auth.js runs -->
    <link rel="modulepreload" href="https://www.gstatic.com/firebasejs/10.14.1/firebase-app.js">
    <link rel="modulepreload" href="https://www.gstatic.com/firebasejs/10.14.1/firebase-auth.js">

    <!-- Google Analytics 4 + Google Ads -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-YCS3JQN8ZH"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-YCS3JQN8ZH');
      gtag('config', 'AW-11149451572');
    </script>

    <slot name="head" />
  </head>
  <body>
    <!-- Native bridge for Capacitor (no-op on web) -->
    <script is:inline src="/js/native-bridge.js"></script>

    <!-- App splash overlay (native only) — logo assembles on brand blue gradient -->
    <div id="appSplash" style="display:none;position:fixed;inset:0;z-index:9999;background:linear-gradient(145deg,#1a2456,#2a3d7e);flex-direction:column;align-items:center;justify-content:center;gap:0;">
      <!-- Assembly area: pieces animate into position -->
      <div style="position:relative;width:240px;height:200px;">
        <!-- W piece — slides from left -->
        <div id="spW" style="position:absolute;left:0;top:40px;font-size:120px;font-weight:900;font-family:system-ui;color:#10B981;opacity:0;transform:translateX(-80px);line-height:1;">W</div>
        <!-- A piece — slides from right -->
        <div id="spA" style="position:absolute;right:0;top:40px;font-size:120px;font-weight:900;font-family:system-ui;color:#e94560;opacity:0;transform:translateX(80px);line-height:1;">A</div>
        <!-- Controller — drops from above -->
        <div id="spCtrl" style="position:absolute;left:50%;top:20px;transform:translateX(-50%) translateY(-60px);opacity:0;font-size:48px;">🎮</div>
        <!-- Arrow — shoots up from center -->
        <div id="spArrow" style="position:absolute;left:50%;top:0;transform:translateX(-50%) translateY(40px) scale(0);opacity:0;width:0;height:0;border-left:16px solid transparent;border-right:16px solid transparent;border-bottom:28px solid #F7B731;"></div>
      </div>
      <!-- Title — fades in last -->
      <div id="spTitle" style="font-size:22px;font-weight:900;color:#fff;font-family:system-ui;opacity:0;margin-top:8px;">Weekly Arcade</div>
      <!-- Progress bar -->
      <div style="width:140px;height:3px;background:rgba(255,255,255,0.1);border-radius:2px;overflow:hidden;margin-top:16px;">
        <div id="spBar" style="height:100%;width:0%;background:linear-gradient(90deg,#10B981,#8B5CF6,#e94560);border-radius:2px;"></div>
      </div>
      <div id="spStatus" style="font-size:10px;color:rgba(255,255,255,0.4);font-family:system-ui;margin-top:8px;">Assembling...</div>
    </div>
    <script is:inline>
      (function(){
        if(!window.Capacitor||!window.Capacitor.isNativePlatform||!window.Capacitor.isNativePlatform())return;
        var s=document.getElementById('appSplash');
        if(!s)return;
        s.style.display='flex';
        var spW=document.getElementById('spW');
        var spA=document.getElementById('spA');
        var spCtrl=document.getElementById('spCtrl');
        var spArrow=document.getElementById('spArrow');
        var spTitle=document.getElementById('spTitle');
        var spBar=document.getElementById('spBar');
        var spStatus=document.getElementById('spStatus');
        var ease='cubic-bezier(0.34,1.56,0.64,1)';

        // Step 1 (0ms): W slides in from left
        setTimeout(function(){
          spW.style.transition='opacity 0.4s, transform 0.6s '+ease;
          spW.style.opacity='1'; spW.style.transform='translateX(0)';
        },200);

        // Step 2 (300ms): A slides in from right
        setTimeout(function(){
          spA.style.transition='opacity 0.4s, transform 0.6s '+ease;
          spA.style.opacity='1'; spA.style.transform='translateX(0)';
        },500);

        // Step 3 (700ms): Controller drops from above with bounce
        setTimeout(function(){
          spCtrl.style.transition='opacity 0.3s, transform 0.5s '+ease;
          spCtrl.style.opacity='1'; spCtrl.style.transform='translateX(-50%) translateY(0)';
        },900);

        // Step 4 (1100ms): Arrow shoots up
        setTimeout(function(){
          spArrow.style.transition='opacity 0.2s, transform 0.4s '+ease;
          spArrow.style.opacity='1'; spArrow.style.transform='translateX(-50%) translateY(0) scale(1)';
        },1300);

        // Step 5 (1500ms): Title fades in
        setTimeout(function(){
          spTitle.style.transition='opacity 0.4s ease-out';
          spTitle.style.opacity='1';
        },1600);

        // Progress bar
        setTimeout(function(){
          spBar.style.transition='width 1.8s ease-out';
          spBar.style.width='100%';
        },400);

        // Status text
        var msgs=['Assembling...','Loading games...','Ready!'];
        var i=0;
        var t=setInterval(function(){i++;if(i<msgs.length)spStatus.textContent=msgs[i];else clearInterval(t);},800);

        // Fade out
        window.addEventListener('load',function(){
          setTimeout(function(){
            s.style.transition='opacity 0.5s ease-out';
            s.style.opacity='0';
            setTimeout(function(){s.remove();},600);
          },Math.max(0,2800-performance.now()));
        });
      })();
    </script>

    <slot />
  </body>
</html>

<style is:global>
  /* ── Reset (shared across ALL pages) ── */
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html,
  body {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  html::-webkit-scrollbar,
  body::-webkit-scrollbar {
    display: none;
  }

  /* ── Accessibility: Respect reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
