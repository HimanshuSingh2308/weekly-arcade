---
/**
 * BaseLayout — shared HTML shell for all pages.
 * Handles: charset, viewport, base styles, reduced motion.
 */
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover"
    />
    <title>{title}</title>

    <!-- Preload Firebase modular SDK (ESM) — start download before auth.js runs -->
    <link rel="modulepreload" href="https://www.gstatic.com/firebasejs/10.14.1/firebase-app.js">
    <link rel="modulepreload" href="https://www.gstatic.com/firebasejs/10.14.1/firebase-auth.js">

    <!-- Google Analytics 4 + Google Ads -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-YCS3JQN8ZH"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-YCS3JQN8ZH');
      gtag('config', 'AW-11149451572');
    </script>

    <slot name="head" />
  </head>
  <body>
    <!-- Native bridge for Capacitor (no-op on web) -->
    <script is:inline src="/js/native-bridge.js"></script>

    <!-- App splash overlay — animated logo video on brand blue gradient -->
    <div id="appSplash" style="display:none;position:fixed;inset:0;z-index:9999;background:linear-gradient(145deg,#1a2456,#2a3d7e);flex-direction:column;align-items:center;justify-content:center;gap:16px;">
      <video id="splashVideo" autoplay muted playsinline preload="auto" width="240" height="240" style="border-radius:20px;opacity:0;transform:scale(0.9);">
        <source src="/images/splash-logo.mp4" type="video/mp4">
      </video>
      <div id="spTitle" style="font-size:22px;font-weight:900;color:#fff;font-family:system-ui;opacity:0;">Weekly Arcade</div>
      <div style="width:140px;height:3px;background:rgba(255,255,255,0.1);border-radius:2px;overflow:hidden;">
        <div id="spBar" style="height:100%;width:0%;background:linear-gradient(90deg,#10B981,#8B5CF6,#e94560);border-radius:2px;"></div>
      </div>
      <div id="spStatus" style="font-size:10px;color:rgba(255,255,255,0.4);font-family:system-ui;">Loading...</div>
    </div>
    <script is:inline>
      (function(){
        var isNative=window.Capacitor&&window.Capacitor.isNativePlatform&&window.Capacitor.isNativePlatform();
        if(!isNative)return;
        var s=document.getElementById('appSplash');
        if(!s)return;
        s.style.display='flex';

        var vid=document.getElementById('splashVideo');
        var title=document.getElementById('spTitle');
        var bar=document.getElementById('spBar');
        var status=document.getElementById('spStatus');

        // Video fade in with scale
        setTimeout(function(){
          vid.style.transition='opacity 0.5s ease-out, transform 0.6s cubic-bezier(0.34,1.56,0.64,1)';
          vid.style.opacity='1';
          vid.style.transform='scale(1)';
        },100);

        // Title fade in
        setTimeout(function(){
          title.style.transition='opacity 0.5s ease-out';
          title.style.opacity='1';
        },800);

        // Progress bar
        setTimeout(function(){
          bar.style.transition='width 4s ease-out';
          bar.style.width='100%';
        },200);

        // Status text
        var msgs=['Loading...','Preparing games...','Almost ready...'];
        var i=0;
        var t=setInterval(function(){i++;if(i<msgs.length)status.textContent=msgs[i];else clearInterval(t);},1500);

        // After video ends, redirect to live URL for smooth nav + instant updates.
        // Local files are only used for the splash — everything else loads from CDN.
        var liveUrl='https://weeklyarcade.games';
        var isLocal=window.location.protocol==='capacitor:'||window.location.hostname==='localhost';

        function afterSplash(){
          if(isLocal){
            // Redirect to live URL (smooth nav, instant web updates)
            window.location.href=liveUrl;
          } else {
            // Already on live URL — just fade out overlay
            s.style.transition='opacity 0.5s ease-out';
            s.style.opacity='0';
            setTimeout(function(){s.remove();},600);
          }
        }

        vid.addEventListener('ended',function(){afterSplash();});
        // Fallback: redirect after 6s if video stalls
        setTimeout(function(){afterSplash();},6000);
      })();
    </script>

    <slot />
  </body>
</html>

<style is:global>
  /* ── Reset (shared across ALL pages) ── */
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html,
  body {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  html::-webkit-scrollbar,
  body::-webkit-scrollbar {
    display: none;
  }

  /* ── Accessibility: Respect reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
