---
/**
 * GameLayout — wraps every game page.
 *
 * Provides: BaseLayout, SEOHead, GameHeader, shared body styles,
 * shared JS modules (api-client, auth, game-cloud, game-header),
 * gameCloud fallback, and MoreGames section.
 *
 * Games only need to provide their specific HTML, CSS, and game logic.
 */
import BaseLayout from './BaseLayout.astro';
import SEOHead from '../components/SEOHead.astro';
import GameHeader from '../components/GameHeader.astro';
import GameCloudFallback from '../components/GameCloudFallback.astro';
import MoreGames from '../components/MoreGames.astro';
import GameSEOContent from '../components/GameSEOContent.astro';

interface Props {
  /** Page <title> */
  title: string;
  /** Game display name */
  gameName: string;
  /** Game ID for leaderboard/cloud (e.g. 'snake') */
  gameId: string;
  /** Emoji icon shown in header */
  icon?: string;
  /** Meta description */
  description: string;
  /** Meta keywords */
  keywords: string;
  /** URL path (e.g. '/games/snake/') */
  url: string;
  /** Theme color for PWA / meta */
  themeColor: string;
  /** Schema.org genres */
  genres: string[];
  /** Accent color CSS variable override */
  accentColor?: string;
  /** Schema.org rating */
  ratingValue?: string;
  ratingCount?: string;
  /** SEO: gameplay tips */
  tips?: string[];
  /** SEO: how to play description */
  howToPlay?: string;
  /** SEO: similar games for "games like X" queries */
  similarTo?: string[];
  /** SEO: extended game description for content depth */
  aboutGame?: string;
  /** SEO: per-game FAQ items */
  faq?: { q: string; a: string }[];
}

const {
  title,
  gameName,
  gameId,
  icon,
  description,
  keywords,
  url,
  themeColor,
  genres,
  accentColor,
  ratingValue,
  ratingCount,
  tips,
  howToPlay,
  similarTo,
  aboutGame,
  faq,
} = Astro.props;
---

<BaseLayout title={title}>
  <Fragment slot="head">
    <SEOHead
      title={title}
      description={description}
      keywords={keywords}
      url={url}
      themeColor={themeColor}
      gameName={gameName}
      genres={genres}
      ratingValue={ratingValue}
      ratingCount={ratingCount}
    />
    <!-- Game-specific head content (custom CSS vars, extra styles) -->
    <slot name="head" />
  </Fragment>

  <GameHeader title={gameName} icon={icon} />

  <!-- Set game ID on body for landing section localStorage key -->
  <script is:inline define:vars={{ gameId }}>
    document.body.dataset.gameId = gameId;
  </script>

  <!-- Optional landing/marketing section (outside nosnippet for SEO indexing) -->
  <slot name="landing" />

  <!-- Game-specific body content (nosnippet prevents Google indexing HUD/UI text) -->
  <div data-nosnippet>
    <slot />
  </div>

  <GameSEOContent gameName={gameName} gameId={gameId} tips={tips} howToPlay={howToPlay} similarTo={similarTo} aboutGame={aboutGame} faq={faq} />

  <MoreGames exclude={gameId} />

  <!-- Shared JS modules (order matters) -->
  <script is:inline src="/js/api-client.js"></script>
  <script is:inline src="/js/auth.js"></script>
  <script is:inline src="/js/game-cloud.js"></script>
  <script is:inline src="/js/game-header.js"></script>

  <!-- Fallback polyfill (single instance, was duplicated in every game) -->
  <GameCloudFallback />

  <!-- Game-specific scripts -->
  <slot name="scripts" />
</BaseLayout>

<style is:global define:vars={{ accentColor: accentColor || '#e94560' }}>
  /* ── Shared game body styles (eliminates ~30 duplicated lines per game) ── */
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, system-ui, sans-serif;
    background: var(--bg-primary, #0f0f1a);
    color: var(--text-primary, #eee);
    min-height: 100dvh;
    min-height: -webkit-fill-available;
    overflow: hidden;
    touch-action: none;
    -webkit-tap-highlight-color: transparent;
    -webkit-user-select: none;
    user-select: none;
    overscroll-behavior: none;
  }
</style>
