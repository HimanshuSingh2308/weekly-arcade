{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@weekly-arcade/source"],
    "baseUrl": ".",
    "paths": {
      "@weekly-arcade/shared": ["packages/shared/src/index.ts"],
      "@weekly-arcade/game-wordle": ["packages/game-wordle/src/index.ts"]
    }
  }
}
