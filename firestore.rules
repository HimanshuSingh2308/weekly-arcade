rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection
    match /users/{userId} {
      // Users can read their own data
      allow read: if request.auth != null && request.auth.uid == userId;

      // Users can update their own data (but not create/delete via client)
      // SECURITY: Prevent client-side manipulation of server-managed fields
      allow update: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['totalXP', 'playerLevel', 'uid', 'email', 'createdAt', 'currentPlayStreak', 'lastPlayedDate']);

      // Game states subcollection
      match /gameStates/{gameId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Leaderboards are publicly readable
    match /leaderboards/{leaderboardId} {
      allow read: if true;
      // Only backend can write (via Admin SDK)
      allow write: if false;

      // Leaderboard entries subcollection (one doc per user per leaderboard)
      match /entries/{entryId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // Scores are publicly readable
    match /scores/{scoreId} {
      allow read: if true;
      // Only backend can write (via Admin SDK)
      allow write: if false;
    }

    // Achievements are readable by the owner
    match /achievements/{achievementId} {
      allow read: if request.auth != null &&
        resource.data.odId == request.auth.uid;
      // Only backend can write (via Admin SDK)
      allow write: if false;
    }

    // ============ CUSTOMIZATION SYSTEM ============

    // Customization item catalog - publicly readable
    match /customizationItems/{itemId} {
      allow read: if true;
      // Only backend can write (via Admin SDK)
      allow write: if false;
    }

    // User inventory - readable by owner only
    match /userInventory/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // Only backend can write (via Admin SDK)
      allow write: if false;

      // Items subcollection
      match /items/{itemId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }

    // User equipped items - readable by owner only
    match /userEquipped/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;

      // Games subcollection
      match /games/{gameId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }

    // Coin transactions - readable by owner only
    match /coinTransactions/{transactionId} {
      allow read: if request.auth != null &&
        resource.data.odId == request.auth.uid;
      // Only backend can write (via Admin SDK)
      allow write: if false;
    }

    // ============ SCORE ARCHIVES ============

    // Consolidated score summaries — readable by owner, server-only writes
    match /scoreArchives/{archiveId} {
      allow read: if request.auth != null &&
        resource.data.odId == request.auth.uid;
      allow write: if false;
    }

    // ============ MULTIPLAYER ============

    // Sessions — authenticated users can read, server-only writes
    match /sessions/{sessionId} {
      allow read: if request.auth != null;
      allow write: if false;

      // Game state — authenticated users can read, server-only writes
      match /gameState/{docId} {
        allow read: if request.auth != null;
        allow write: if false;
      }

      // Moves — authenticated users can read, server-only writes
      match /moves/{moveId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // Invitations — recipient and sender can read their own
    match /invitations/{invitationId} {
      allow read: if request.auth != null &&
        (resource.data.toUid == request.auth.uid || resource.data.fromUid == request.auth.uid);
      allow write: if false;
    }

    // Matchmaking queue — server-only
    match /matchmakingQueue/{entryId} {
      allow read, write: if false;
    }

    // Match results — publicly readable
    match /matchResults/{resultId} {
      allow read: if true;
      allow write: if false;
    }

    // Anti-cheat reports — server-only
    match /antiCheatReports/{reportId} {
      allow read, write: if false;
    }

    // ============ PUSH NOTIFICATIONS ============

    // Push tokens - server-only (Admin SDK)
    match /push-tokens/{docId} {
      allow read, write: if false;
    }

    // Notification logs - server-only (Admin SDK)
    match /notification-logs/{docId} {
      allow read, write: if false;
    }
  }
}
